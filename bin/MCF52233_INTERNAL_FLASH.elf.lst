; 2137:  		step++; 
; 2138:  		break; 
; 2139:  		 
; 2140:  	case 2: 
; 2141:  		if (move_done(0x03)) {  
; 2142:  			delay_count = get_var(VAR_DELAY_MOVE); 
; 2143:  			step++;  
; 2144:  		} 
; 2145:  		break; 
; 2146:   
; 2147:  	case 3:  
; 2148:  		if (IsStopped()) { step++; } 
; 2149:  		break; 
; 2150:   
; 2151:  	case 4: 
