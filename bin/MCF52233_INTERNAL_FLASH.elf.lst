; 1603:  void MotionStop() 
; 1604:  { 
; 1605:  	char axis = 0; 
; 1606:  	 
; 1607:  	for (axis = 0; axis < MAX_AXIS; ++axis) 
; 1608:  	{ 
; 1609:  		MoveStop(axis); 
