;  791:  			++step; 
;  792:  		} 
;  793:  		break; 
;  794:  		 
;  795:  	case 2: 
;  796:  		HoldMotors(); 
;  797:  		step = 0; 
;  798:  		return ERROR_STOPPED; 
;  799:  		 
;  800:  	default: 
;  801:  		step = 0; 
;  802:  		return NORMAL_FINISHED; 
;  803:  	} 
;  804:  	 
;  805:  	return NORMAL_RUNNING; 
;  806:  } 
