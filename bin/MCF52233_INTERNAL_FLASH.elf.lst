; 1753:  	} 
; 1754:  } 
; 1755:   
; 1756:  // g_MoveOffset[] ļ│ĆņłśņŚÉ ņ£äņ╣śļź╝ ņĀĆņ×źĒĢ┤ ļåōĻ│Ā, ĻĘĖ ņ£äņ╣śļĪ£ ņØ┤ļÅÖĒĢ£ļŗż  
; 1757:  char CommGripUngrip() 
; 1758:  { 
; 1759:  	static char step = 0; 
; 1760:  	int  axis = 0; 
; 1761:  	char flag = 1; 
; 1762:  	char move_start = 0; 
; 1763:  	char move_status = 0; 
; 1764:  	 
; 1765:  	switch (step) 
; 1766:  	{ 
