; 1893:  char CommShake() 
; 1894:  { 
; 1895:  	const int POINT_SHAKE_1 = 6; 
; 1896:  	const int POINT_SHAKE_2 = 7; 
; 1897:  	const int POINT_LOAD = 3; 
; 1898:  	const int VAR_NUM_MOVE = 6; 
; 1899:  	const int VAR_DELAY_MOVE = 7; 
; 1900:   
; 1901:  	static char step = 0; 
; 1902:  	static int delay_count = 0; 
; 1903:  	static int shake_count = 0; 
; 1904:   
; 1905:  	int move_start = 0; 
; 1906:  	 
; 1907:  	switch (step) 
; 1908:  	{ 
; 1909:  		// Error handling  
; 1910:  	case 91: StopMotors(); step++; break; 
; 1911:  	case 92: if (IsStopped()) { step++; } break; 
; 1912:  	case 93: HoldMotors(); step = 0; return ERROR_STOPPED;  
; 1913:   
; 1914:  		// 
; 1915:  	case 0:  
; 1916:  		delay_count = 0; 
; 1917:  		shake_count = get_var(VAR_NUM_MOVE); 
; 1918:  		step = 1;  
; 1919:  		break; 
; 1920:   
; 1921:  		// pd6ņ£╝ļĪ£ ņØ┤ļÅÖ  
; 1922:  	case 1: 
; 1923:  		move_start = move_pd(POINT_SHAKE_1, 0x03); 
; 1924:  		if (move_start)  
; 1925:  		{ 
; 1926:  			SetErrorCode(ERR_MOTOR_ERROR); 
; 1927:  			step = 91; 
; 1928:  			return NORMAL_RUNNING; 
; 1929:  		} 
; 1930:  		DelayMoveStart(); 
; 1931:  		step++; 
; 1932:  		break; 
; 1933:  		 
; 1934:  	case 2: 
; 1935:  		if (move_done(0x03)) {  
; 1936:  			delay_count = get_var(VAR_DELAY_MOVE); 
; 1937:  			step++;  
; 1938:  		} 
; 1939:  		break; 
; 1940:   
; 1941:  	case 3:  
; 1942:  		if (IsStopped()) { step++; } 
; 1943:  		break; 
; 1944:   
; 1945:  	case 4: 
; 1946:  		if (--delay_count > 0) { Delay1ms(); } 
; 1947:  		else { step++; } 
; 1948:  		break; 
; 1949:   
; 1950:  		// pd7ļĪ£ ņØ┤ļÅÖ  
; 1951:  	case 5: 
; 1952:  		move_start = move_pd(POINT_SHAKE_2, 0x03); 
; 1953:  		if (move_start) 
; 1954:  		{ 
; 1955:  			SetErrorCode(ERR_MOTOR_ERROR); 
; 1956:  			step = 91; 
; 1957:  			return NORMAL_RUNNING; 
; 1958:  		} 
; 1959:  		DelayMoveStart(); 
; 1960:  		step++; 
; 1961:  		break; 
; 1962:   
; 1963:  	case 6: 
; 1964:  		if (move_done(0x03)) { 
; 1965:  			delay_count = get_var(VAR_DELAY_MOVE); 
; 1966:  			step++; 
; 1967:  		} 
; 1968:  		break; 
; 1969:   
; 1970:  	case 7: 
; 1971:  		if (IsStopped()) { step++; } 
; 1972:  		break; 
; 1973:   
; 1974:  	case 8: 
; 1975:  		if (--delay_count > 0) { Delay1ms(); } 
; 1976:  		else { step++; } 
; 1977:  		break; 
; 1978:   
; 1979:  		// count ĒÖĢņØĖ (var 6) 
; 1980:  	case 9: 
; 1981:  		if (--shake_count > 0) { step = 1; } 
; 1982:  		else { step++; } 
; 1983:  		break; 
; 1984:   
; 1985:  		// load ņ£äņ╣ś(3)ļĪ£ ņØ┤ļÅÖ  
; 1986:  	case 10: 
; 1987:  		move_start = move_pd(POINT_LOAD, 0x03); 
; 1988:  		if (move_start) 
; 1989:  		{ 
; 1990:  			SetErrorCode(ERR_MOTOR_ERROR); 
; 1991:  			step = 91; 
; 1992:  			return NORMAL_RUNNING; 
; 1993:  		} 
; 1994:  		DelayMoveStart(); 
; 1995:  		step++; 
; 1996:  		break; 
; 1997:   
; 1998:  	case 11: 
; 1999:  		if (move_done(0x03)) { step++; } 
; 2000:  		break; 
; 2001:   
; 2002:  	case 12: 
; 2003:  		if (IsStopped()) { step++; } 
; 2004:   
; 2005:  	case 13: 
; 2006:  		HoldMotors(); 
; 2007:  		g_MovePointDataNo = 0; 
; 2008:  		g_MoveOffset[X_AXIS] = g_MoveOffset[Y_AXIS] = g_MoveOffset[Z_AXIS] = 0; 
; 2009:  		step = 0; 
; 2010:  		return NORMAL_FINISHED; 
; 2011:   
; 2012:  	default: 
; 2013:  		step = 0; 
; 2014:  		return NORMAL_FINISHED; 
; 2015:  	} 
; 2016:   
; 2017:  	CHECK_USER_STOP(); 
; 2018:   
; 2019:  	return 0; 
; 2020:  } 
