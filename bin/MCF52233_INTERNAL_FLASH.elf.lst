;  521:  				GoToError(); 
;  522:  				break;		 
;  523:  			} 
;  524:  		} 
;  525:  	} 
;  526:  } 
;  527:   
;  528:  unsigned char GetInput(char ch) 
;  529:  { 
;  530:  	unsigned char res = 0; 
;  531:  	unsigned short val = 0; 
;  532:  	 
;  533:  	if (ch < 0 || ch > 1) 
;  534:  	{ 
;  535:  		return res; 
;  536:  	} 
;  537:  	 
;  538:  	val = ~GetInput16(); 
;  539:  	 
;  540:  	res = (val >> (8*ch)) & 0xFF; 
;  541:  	 
;  542:  	return res; 
;  543:  } 
;  544:   
;  545:  unsigned char GetOutput(char ch) 
;  546:  { 
;  547:  	unsigned char res = 0; 
;  548:  	unsigned short val = 0; 
;  549:  	 
;  550:  	if (ch < 0 || ch > 1) 
;  551:  	{ 
;  552:  		return res; 
;  553:  	} 
;  554:  	 
;  555:  	//val = ~GetOutput12(); 
;  556:  	val = ~GetOutput8(); 
;  557:  	 
;  558:  	res = (val >> (8*ch)) & 0xFF; 
;  559:  	 
;  560:  	return res; 
;  561:  } 
;  562:   
;  563:  void SetOutput(char ch, unsigned char data) 
;  564:  { 
;  565:  	//unsigned short cur = GetOutput12();		// active low 
;  566:  	unsigned short cur = GetOutput8(); 
;  567:  	unsigned short data2 = 0xFF & (~data);	// active high -> active low 
;  568:  	 
;  569:  	if (ch < 0 || ch > 1) 
;  570:  	{ 
;  571:  		return; 
;  572:  	} 
;  573:  	 
;  574:  	cur = cur & (unsigned short)(~(0xFF << (8*ch))); 
;  575:  	data2 = cur | (unsigned short)(data2 << (8*ch)); 
;  576:  	 
;  577:  	// SetOutput12(data2); 
;  578:  	SetOutput8(data2); 
;  579:  } 
;  580:   
;  581:  unsigned char GetInput2(char ch) 
;  582:  { 
;  583:  	unsigned char res = 0; 
;  584:   
;  585:  	if (ch < 1 || ch > MAX_DI) 
;  586:  	{ 
;  587:  		return res; 
;  588:  	} 
;  589:  	 
;  590:  	res = GetInput(ch-1);	// GetInput() : ch = 0-base 
;  591:  	 
;  592:  	return res; 
;  593:  } 
;  594:   
;  595:  unsigned char GetOutput2(char ch) 
;  596:  { 
;  597:  	unsigned char res = 0; 
;  598:   
;  599:  	if (ch < 1 || ch > MAX_DO) 
;  600:  	{ 
;  601:  		return res; 
;  602:  	} 
;  603:  	 
;  604:  	res = GetOutput(ch-1);	// GetOutput() : ch = 0-base 
;  605:   
;  606:  	return res;	 
;  607:  } 
;  608:   
;  609:  void SetOutput2(char ch, unsigned char data) 
;  610:  { 
;  611:  	if (ch < 1 || ch > MAX_DO) 
;  612:  	{ 
;  613:  		return; 
;  614:  	} 
;  615:  	 
;  616:  	SetOutput(ch-1, data); 
;  617:  } 
;  618:   
;  619:  char GetDI(char ch) 
