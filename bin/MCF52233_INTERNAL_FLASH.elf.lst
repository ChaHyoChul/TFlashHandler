;  569:  	 
;  570:  	if (ch < 0 || ch > 1) 
;  571:  	{ 
;  572:  		return; 
;  573:  	} 
;  574:  	 
;  575:  	cur = cur & (unsigned short)(~(0xFF << (8*ch))); 
