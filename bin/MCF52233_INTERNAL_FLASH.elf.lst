;  452:  	case COMM_ORIGIN: 
;  453:  	case COMM_ERROR_STOP: 
;  454:  		return; 
;  455:  	} 
;  456:  	 
;  457:  	// check limit sensor 
;  458:  	 
;  459:  	if (g_MotionCommand == COMM_IDLE) 
;  460:  	{ 
;  461:  		for (axis = 0; axis < MAX_AXIS; ++axis) 
