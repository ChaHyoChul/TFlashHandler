;  708:  	 
;  709:  	if (flag < 0 || flag > 1) 
;  710:  	{ 
;  711:  		return; 
;  712:  	} 
;  713:  	 
;  714:  	g_OriginCompletedAxes[axis] = flag; 
;  715:  	 
;  716:  	UpdateOriginCompletedStatus(); 
;  717:  } 
