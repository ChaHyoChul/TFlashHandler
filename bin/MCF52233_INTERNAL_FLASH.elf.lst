; 1862:  		SetOriginCompletedFlag(org_axis, 1); 
; 1863:  		step++; 
; 1864:  		break; 
; 1865:   
; 1866:  	case 16: 
; 1867:  		if (--org_axis >= X_AXIS) { step = 1; } 
; 1868:  		else { step++; } 
; 1869:  		break; 
; 1870:   
; 1871:  	case 17: 
