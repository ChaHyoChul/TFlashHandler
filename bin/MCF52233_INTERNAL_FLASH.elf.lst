; 1615:  unsigned char GetRawDir(char axis, unsigned char dir) 
; 1616:  { 
; 1617:  	unsigned char retDir = dir; 
; 1618:   
; 1619:  	// change the direction for X-axis 
; 1620:  	if (axis == X_AXIS) 
; 1621:  	{ 
; 1622:  		retDir = 1 - retDir; 
; 1623:  	} 
; 1624:  	 
; 1625:  	return retDir; 
; 1626:  } 
; 1627:   
; 1628:  unsigned char InverseDir(unsigned char dir) 
; 1629:  { 
; 1630:  	return 1 - dir; 
; 1631:  } 
; 1632:   
; 1633:  void SetMoveOffset(char axis, int offset) 
; 1634:  { 
