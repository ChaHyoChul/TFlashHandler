;  538:   
;  539:  unsigned char GetInput(char ch) 
;  540:  { 
;  541:  	unsigned char res = 0; 
;  542:  	unsigned short val = 0; 
;  543:  	 
;  544:  	if (ch < 0 || ch > 1) 
;  545:  	{ 
;  546:  		return res; 
;  547:  	} 
;  548:  	 
;  549:  	val = ~GetInput16(); 
;  550:  	 
;  551:  	res = (val >> (8*ch)) & 0xFF; 
;  552:  	 
;  553:  	return res; 
;  554:  } 
;  555:   
;  556:  unsigned char GetOutput(char ch) 
;  557:  { 
;  558:  	unsigned char res = 0; 
;  559:  	unsigned short val = 0; 
;  560:  	 
;  561:  	if (ch < 0 || ch > 1) 
;  562:  	{ 
;  563:  		return res; 
;  564:  	} 
;  565:  	 
;  566:  	//val = ~GetOutput12(); 
;  567:  	val = ~GetOutput8(); 
;  568:  	 
;  569:  	res = (val >> (8*ch)) & 0xFF; 
;  570:  	 
;  571:  	return res; 
;  572:  } 
;  573:   
;  574:  void SetOutput(char ch, unsigned char data) 
;  575:  { 
;  576:  	//unsigned short cur = GetOutput12();		// active low 
;  577:  	unsigned short cur = GetOutput8(); 
;  578:  	unsigned short data2 = 0xFF & (~data);	// active high -> active low 
;  579:  	 
;  580:  	if (ch < 0 || ch > 1) 
;  581:  	{ 
;  582:  		return; 
;  583:  	} 
;  584:  	 
;  585:  	cur = cur & (unsigned short)(~(0xFF << (8*ch))); 
;  586:  	data2 = cur | (unsigned short)(data2 << (8*ch)); 
;  587:  	 
;  588:  	// SetOutput12(data2); 
;  589:  	SetOutput8(data2); 
;  590:  } 
;  591:   
;  592:  unsigned char GetInput2(char ch) 
;  593:  { 
;  594:  	unsigned char res = 0; 
;  595:   
;  596:  	if (ch < 1 || ch > MAX_DI) 
;  597:  	{ 
;  598:  		return res; 
;  599:  	} 
;  600:  	 
;  601:  	res = GetInput(ch-1);	// GetInput() : ch = 0-base 
;  602:  	 
;  603:  	return res; 
;  604:  } 
;  605:   
;  606:  unsigned char GetOutput2(char ch) 
;  607:  { 
;  608:  	unsigned char res = 0; 
;  609:   
;  610:  	if (ch < 1 || ch > MAX_DO) 
;  611:  	{ 
;  612:  		return res; 
;  613:  	} 
;  614:  	 
;  615:  	res = GetOutput(ch-1);	// GetOutput() : ch = 0-base 
;  616:   
;  617:  	return res;	 
;  618:  } 
;  619:   
;  620:  void SetOutput2(char ch, unsigned char data) 
;  621:  { 
;  622:  	if (ch < 1 || ch > MAX_DO) 
;  623:  	{ 
;  624:  		return; 
;  625:  	} 
;  626:  	 
;  627:  	SetOutput(ch-1, data); 
;  628:  } 
;  629:   
;  630:  char GetDI(char ch) 
;  631:  { 
;  632:  	char res = 0; 
;  633:   
;  634:  	if (ch >= 0 && ch < MAX_DI) 
;  635:  	{ 
;  636:  		res = (((GetInput16() >> ch) & 1) == SENS_ON); 
;  637:  	} 
;  638:  	 
;  639:  	return res; 
;  640:  } 
;  641:   
;  642:  char GetDO(char ch) 
;  643:  { 
;  644:  	char res = 0; 
;  645:   
;  646:  	if (ch >= 0 && ch < MAX_DO) 
;  647:  	{ 
;  648:  		//res = (((GetOutput12() >> ch) & 1) == SENS_ON); 
;  649:  		res = (((GetOutput8() >> ch) & 1) == SENS_ON); 
;  650:  	} 
;  651:  	 
;  652:  	return res; 
;  653:  } 
;  654:   
;  655:  void SetDO(char ch, char flag) 
;  656:  { 
;  657:  	char res = 0; 
;  658:  	int value = 0; 
;  659:   
;  660:  	if (ch >= 0 && ch < MAX_DO) 
;  661:  	{ 
;  662:  		value = (1 << ch); 
;  663:  		if (flag) 
;  664:  		{ 
;  665:  			//SetOutput12(GetOutput12() & ~value); 
;  666:  			SetOutput8(GetOutput8() & ~value); 
;  667:  		} 
;  668:  		else 
;  669:  		{ 
;  670:  			//SetOutput12(GetOutput12() | value); 
;  671:  			SetOutput8(GetOutput8() | value); 
;  672:  		} 
;  673:  	} 
;  674:  } 
;  675:   
;  676:  unsigned char GetDIBit(char ch, char bit) 
;  677:  { 
;  678:  	unsigned char res = GetInput2(ch); 
;  679:  	 
;  680:  	res = (res >> bit) & 1; 
;  681:  	 
;  682:  	return res; 
;  683:  } 
;  684:   
;  685:  unsigned char GetDOBit(char ch, char bit) 
;  686:  { 
;  687:  	unsigned char res = GetOutput2(ch); 
;  688:  	 
;  689:  	res = (res >> bit) & 1; 
;  690:  	 
;  691:  	return res;	 
;  692:  } 
;  693:   
;  694:  void SetDOBit(char ch, char bit, char flag) 
;  695:  { 
;  696:  	unsigned char res = GetOutput2(ch); 
;  697:  	 
;  698:  	if (flag == 0) 
;  699:  	{ 
;  700:  		res = res & (unsigned char)(~(1 << bit)); 
;  701:  	} 
;  702:  	else 
;  703:  	{ 
;  704:  		res = res | (1 << bit); 
;  705:  	} 
;  706:  	 
;  707:  	SetOutput2(ch, res); 
;  708:  } 
;  709:   
;  710:  void UpdateOriginCompletedStatus() 
;  711:  { 
;  712:  	char axis = 0; 
;  713:  	char flag = 1; 
;  714:   
;  715:  	for (axis = 0; axis < MAX_AXIS; ++axis) 
;  716:  	{ 
;  717:  		if (g_OriginNeed[axis] && g_OriginCompletedAxes[axis] == 0) 
;  718:  		{ 
;  719:  			flag = 0; 
;  720:  			break; 
;  721:  		} 
;  722:  	} 
;  723:  	 
;  724:  	g_OriginCompleted = flag; 
;  725:  } 
;  726:   
;  727:  void SetOriginCompletedFlag(char axis, char flag) 
;  728:  { 
;  729:  	if (axis < 0 || axis >= MAX_AXIS) 
;  730:  	{ 
;  731:  		return; 
;  732:  	} 
;  733:  	 
;  734:  	if (flag < 0 || flag > 1) 
;  735:  	{ 
;  736:  		return; 
;  737:  	} 
;  738:  	 
;  739:  	g_OriginCompletedAxes[axis] = flag; 
;  740:  	 
;  741:  	UpdateOriginCompletedStatus(); 
;  742:  } 
