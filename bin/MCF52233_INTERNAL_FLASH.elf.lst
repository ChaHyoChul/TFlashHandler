; 1155:  	case 22: 
; 1156:  		step = 0; 
; 1157:   
; 1158:  		for (axis = 0; axis < MAX_AXIS; ++axis) 
; 1159:  		{ 
; 1160:  			SetOriginCompletedFlag(axis, 1); 
; 1161:  		} 
; 1162:   
; 1163:  		return NORMAL_FINISHED;	// ’┐Į’┐Į’┐Į’┐Į : Move Origin ’┐Į’┐Į’┐Į’┐Į ’┐ĮŽĘ’┐Į 
; 1164:   
; 1165:  	default: 
; 1166:  		return NORMAL_FINISHED; 
; 1167:   
; 1168:  	} 
; 1169:  	 
; 1170:  	CHECK_USER_STOP(); 
; 1171:  	 
; 1172:  	return NORMAL_RUNNING; 
; 1173:  } 
