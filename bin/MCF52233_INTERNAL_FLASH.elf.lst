; 1911:  				SetErrorCode(ERR_MOTOR_ERROR); 
; 1912:  				step = 91; 
; 1913:  				return NORMAL_RUNNING; 
; 1914:  			} 
; 1915:  			DelayMoveStart(); 
; 1916:  			step++; 
; 1917:  		} 
; 1918:  		else  
; 1919:  		{ 
; 1920:  			step = 3; 
; 1921:  		} 
; 1922:  		break; 
; 1923:  		 
; 1924:  	case 1: 
; 1925:  		if (move_done(0x04))  
; 1926:  		{ 
; 1927:  			step++; 
; 1928:  		} 
; 1929:  		break; 
; 1930:   
; 1931:  	case 2: 
; 1932:  		if (IsStopped()) 
; 1933:  		{ 
; 1934:  			step++; 
; 1935:  		} 
; 1936:  		break; 
; 1937:   
; 1938:  	case 3: 
; 1939:  		SetHoldTorque(Z_AXIS); 
; 1940:  		g_MovePointDataNo = 0; 
