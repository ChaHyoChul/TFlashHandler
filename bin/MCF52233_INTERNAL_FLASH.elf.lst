;  433:  		{ 
;  434:  			return; 
;  435:  		} 
;  436:  		break; 
;  437:  	case COMM_ORIGIN: 
;  438:  	case COMM_ERROR_STOP: 
;  439:  		return; 
;  440:  	} 
;  441:  	 
;  442:  	// check limit sensor 
;  443:  	 
;  444:  	if (g_MotionCommand == COMM_IDLE) 
;  445:  	{ 
;  446:  		for (axis = 0; axis < MAX_AXIS; ++axis) 
;  447:  		{ 
;  448:  			if (GetMoveStatus(axis) != MOVE_STS_STOP) 
;  449:  			{ 
;  450:  				switch (get_axis_sensor(axis)) 
;  451:  				{ 
;  452:  				case 0: 
;  453:  					break; 
;  454:  					 
;  455:  				case 1:	// POS LIMIT 
;  456:  					if (MovVar[axis].m_ucDir == g_MotionParam[axis].m_ucMoveDir) 
;  457:  					{ 
;  458:  						SetErrorCode(ERR_OVER_RUN); 
;  459:  						StopMotors(); 
;  460:  					} 
;  461:  					break; 
;  462:  					 
;  463:  				case 2: // NEG LIMIT 
;  464:  					if (MovVar[axis].m_ucDir != g_MotionParam[axis].m_ucMoveDir) 
;  465:  					{ 
;  466:  						SetErrorCode(ERR_OVER_RUN); 
;  467:  						StopMotors(); 
;  468:  					} 
;  469:  					break; 
;  470:  					 
;  471:  				default: 
;  472:  					SetErrorCode(ERR_OVER_RUN); 
;  473:  					StopMotors(); 
;  474:  					break;		 
;  475:  				} 
;  476:  			} 
;  477:  		} 
;  478:  	} 
;  479:  	else 
;  480:  	{ 
;  481:  		for (axis = 0; axis < MAX_AXIS; ++axis) 
;  482:  		{ 
;  483:  			switch (get_axis_sensor(axis)) 
;  484:  			{ 
;  485:  			case 0: 
;  486:  				break; 
;  487:  				 
;  488:  			case 1:	// POS LIMIT 
;  489:  				if (g_MoveOffset[axis] > 0) 
;  490:  				{ 
