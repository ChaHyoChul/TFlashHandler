;  489:  					StopMotors(); 
;  490:  					break;		 
;  491:  				} 
;  492:  			} 
;  493:  		} 
;  494:  	} 
;  495:  	else 
;  496:  	{ 
;  497:  		for (axis = 0; axis < MAX_AXIS; ++axis) 
