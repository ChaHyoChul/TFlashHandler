; 1444:  				debugf("Axis(%d) Distance = %d", axis, MovVar[axis].m_uS); 
; 1445:  				debugf("Axis(%d) Direction = %d", axis, MovVar[axis].m_ucDir); 
; 1446:  				debugf("Axis(%d) Vmax = %d", axis, MovVar[axis].m_uVmax); 
; 1447:  				debugf("Axis(%d) Vmin = %d", axis, MovVar[axis].m_uVmin); 
; 1448:  				debugf("Axis(%d) Accel = %d", axis, MovVar[axis].m_uAcel); 
; 1449:  				debugf("Axis(%d) Move Torque = %d", axis, MovVar[axis].m_ucMoveTorq); 
; 1450:  				debugf("Axis(%d) Hold Torque = %d", axis, MovVar[axis].m_ucHoldTorq); 
; 1451:  				 
; 1452:  				debugf("MoveStart(%d)", axis); 
