;  298:  			sprintf(str, "%s 000\r\n", g_LastCommand);	 
;  299:  		} 
;  300:  		else 
;  301:  		{ 
;  302:  			sprintf(str, "%s\r\n", g_LastCommand); 
;  303:  		} 
;  304:  	} 
;  305:  	else if (g_ErrorCode < 1000) 
;  306:  	{ 
;  307:  		sprintf(str, "%s %03d\r\n", g_LastCommand, g_ErrorCode); 
;  308:  	} 
;  309:  	else 
;  310:  	{ 
;  311:  		sprintf(str, "%s E%02d\r\n", g_LastCommand, g_ErrorCode-1000); 
;  312:  	} 
;  313:   
;  314:  	send(str); 
;  315:  	 
;  316:  	strcpy(g_LastCommand, ""); 
;  317:  } 
