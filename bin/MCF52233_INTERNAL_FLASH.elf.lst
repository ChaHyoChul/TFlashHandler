; 2153:  		else { step++; } 
; 2154:  		break; 
; 2155:   
; 2156:  		// pd7ëĄ ėīë  
; 2157:  	case 5: 
; 2158:  		move_start = move_pd(POINT_SHAKE_2, 0x03); 
; 2159:  		if (move_start) 
; 2160:  		{ 
; 2161:  			SetErrorCode(ERR_MOTOR_ERROR); 
; 2162:  			step = 91; 
; 2163:  			return NORMAL_RUNNING; 
; 2164:  		} 
; 2165:  		DelayMoveStart(); 
; 2166:  		step++; 
; 2167:  		break; 
; 2168:   
; 2169:  	case 6: 
; 2170:  		if (move_done(0x03)) { 
; 2171:  			delay_count = get_var(VAR_DELAY_MOVE); 
; 2172:  			step++; 
; 2173:  		} 
; 2174:  		break; 
; 2175:   
; 2176:  	case 7: 
; 2177:  		if (IsStopped()) { step++; } 
; 2178:  		break; 
; 2179:   
; 2180:  	case 8: 
; 2181:  		if (--delay_count > 0) { Delay1ms(); } 
; 2182:  		else { step++; } 
; 2183:  		break; 
; 2184:   
; 2185:  		// count íėļ (var 6) 
; 2186:  	case 9: 
; 2187:  		if (--shake_count > 0) { step = 1; } 
; 2188:  		else { step++; } 
; 2189:  		break; 
; 2190:   
; 2191:  		// load ėėđ(3)ëĄ ėīë  
; 2192:  	case 10: 
; 2193:  		move_start = move_pd(POINT_LOAD, 0x03); 
; 2194:  		if (move_start) 
; 2195:  		{ 
; 2196:  			SetErrorCode(ERR_MOTOR_ERROR); 
; 2197:  			step = 91; 
