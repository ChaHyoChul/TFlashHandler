; 1885:  // g_MoveOffset[] ļ│ĆņłśņŚÉ ņ£äņ╣śļź╝ ņĀĆņ×źĒĢ┤ ļåōĻ│Ā, ĻĘĖ ņ£äņ╣śļĪ£ ņØ┤ļÅÖĒĢ£ļŗż  
; 1886:  char CommGripUngrip() 
; 1887:  { 
; 1888:  	static char step = 0; 
; 1889:  	int  axis = 0; 
; 1890:  	char flag = 1; 
; 1891:  	char move_start = 0; 
; 1892:  	char move_status = 0; 
; 1893:  	 
; 1894:  	switch (step) 
; 1895:  	{ 
; 1896:  		// Error handling  
; 1897:  	case 91: StopMotors(); step++; break; 
; 1898:  	case 92: if (IsStopped()) { step++; } break; 
; 1899:  	case 93: HoldMotors(); step = 0; return ERROR_STOPPED; 
; 1900:   
; 1901:  		// Start 
; 1902:  		// move_offset Ļ░ÆņØ┤ 0ņØ┤ļ®┤ MoveStart() ĒĢ©ņłśņŚÉņä£ 3ļ▓ł ņŚÉļ¤¼ ļ░£ņāØ   
; 1903:  		// offset = target_pos - current_pos  
; 1904:  		// point data 2ļ▓ł. ZņČĢ ņ£äņ╣ś ņé¼ņÜ®  
; 1905:  	case 0: 
; 1906:  		if (g_MovePointDataNo != 0) 
; 1907:  		{ 
; 1908:  			move_start = move_pd(g_MovePointDataNo, 0x04); 
; 1909:  			if (move_start)  
; 1910:  			{ 
; 1911:  				SetErrorCode(ERR_MOTOR_ERROR); 
; 1912:  				step = 91; 
; 1913:  				return NORMAL_RUNNING; 
; 1914:  			} 
; 1915:  			DelayMoveStart(); 
; 1916:  			step++; 
; 1917:  		} 
; 1918:  		else  
; 1919:  		{ 
; 1920:  			step = 3; 
; 1921:  		} 
; 1922:  		break; 
; 1923:  		 
; 1924:  	case 1: 
; 1925:  		if (move_done(0x04))  
; 1926:  		{ 
; 1927:  			step++; 
; 1928:  		} 
; 1929:  		break; 
; 1930:   
; 1931:  	case 2: 
; 1932:  		if (IsStopped()) 
; 1933:  		{ 
; 1934:  			step++; 
; 1935:  		} 
; 1936:  		break; 
; 1937:   
; 1938:  	case 3: 
; 1939:  		SetHoldTorque(Z_AXIS); 
; 1940:  		g_MovePointDataNo = 0; 
; 1941:  		g_MoveOffset[Z_AXIS] = 0; 
; 1942:  		step = 0; 
; 1943:  		return NORMAL_FINISHED; 
; 1944:   
; 1945:  	default: 
; 1946:  		step = 0; 
; 1947:  		return NORMAL_FINISHED; 
; 1948:  	} 
; 1949:   
; 1950:  	CHECK_USER_STOP(); 
; 1951:   
; 1952:  	return 0; 
; 1953:  } 
