; 1723:  		MovVar[Z_AXIS].m_ucDir = g_MotionParam[Z_AXIS].m_ucOrgDir; 
; 1724:  		SetSpeed(Z_AXIS, SPEED_ORG); 
; 1725:   
; 1726:  		if (NEG_LIMIT(Z_AXIS) != SENS_ON && MoveStart(Z_AXIS))  
