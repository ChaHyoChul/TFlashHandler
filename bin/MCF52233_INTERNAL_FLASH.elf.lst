; 1907:  		g_MoveOffset[g_OriginAxis] = (0.2 - get_motor_pos(g_OriginAxis)) / g_MotionParam[g_OriginAxis].m_fScaleFactor;  
; 1908:  		SetMoveOffset(g_OriginAxis, g_MoveOffset[g_OriginAxis]); 
; 1909:  		move_status = MoveStart(g_OriginAxis); 
; 1910:  		if (move_status) { 
; 1911:  			SetErrorCode(ERR_MOTOR_ERROR); 
