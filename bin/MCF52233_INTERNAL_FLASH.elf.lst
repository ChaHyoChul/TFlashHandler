; 1713:   			MovVar[axis].m_uAcel = g_MotionParam[axis].m_uJogAcel; 
; 1714:   			break; 
; 1715:   			 
; 1716:   		case SPEED_NORMAL: 
; 1717:   			MovVar[axis].m_uVmax = g_MotionParam[axis].m_uNorVmax; 
; 1718:   			MovVar[axis].m_uVmin = g_MotionParam[axis].m_uNorVmin; 
; 1719:   			MovVar[axis].m_uAcel = g_MotionParam[axis].m_uNorAcel; 
; 1720:   			break; 
; 1721:    
; 1722:   		case SPEED_SCAN: 
; 1723:   			MovVar[axis].m_uVmax = ((double)scan_rate/100) * g_MotionParam[axis].m_uNorVmax; 
; 1724:   			MovVar[axis].m_uVmin = ((double)scan_rate/100) * g_MotionParam[axis].m_uNorVmin; 
