;  513:   
;  514:  unsigned char GetInput(char ch) 
;  515:  { 
;  516:  	unsigned char res = 0; 
;  517:  	unsigned short val = 0; 
;  518:  	 
;  519:  	if (ch < 0 || ch > 1) 
;  520:  	{ 
;  521:  		return res; 
;  522:  	} 
;  523:  	 
;  524:  	val = ~GetInput16(); 
;  525:  	 
;  526:  	res = (val >> (8*ch)) & 0xFF; 
;  527:  	 
;  528:  	return res; 
;  529:  } 
;  530:   
;  531:  unsigned char GetOutput(char ch) 
;  532:  { 
;  533:  	unsigned char res = 0; 
;  534:  	unsigned short val = 0; 
;  535:  	 
;  536:  	if (ch < 0 || ch > 1) 
;  537:  	{ 
;  538:  		return res; 
;  539:  	} 
;  540:  	 
;  541:  	//val = ~GetOutput12(); 
;  542:  	val = ~GetOutput8(); 
;  543:  	 
;  544:  	res = (val >> (8*ch)) & 0xFF; 
;  545:  	 
;  546:  	return res; 
;  547:  } 
;  548:   
;  549:  void SetOutput(char ch, unsigned char data) 
;  550:  { 
;  551:  	//unsigned short cur = GetOutput12();		// active low 
;  552:  	unsigned short cur = GetOutput8(); 
;  553:  	unsigned short data2 = 0xFF & (~data);	// active high -> active low 
;  554:  	 
;  555:  	if (ch < 0 || ch > 1) 
;  556:  	{ 
;  557:  		return; 
;  558:  	} 
;  559:  	 
;  560:  	cur = cur & (unsigned short)(~(0xFF << (8*ch))); 
;  561:  	data2 = cur | (unsigned short)(data2 << (8*ch)); 
;  562:  	 
;  563:  	// SetOutput12(data2); 
;  564:  	SetOutput8(data2); 
;  565:  } 
;  566:   
;  567:  unsigned char GetInput2(char ch) 
;  568:  { 
;  569:  	unsigned char res = 0; 
;  570:   
;  571:  	if (ch < 1 || ch > MAX_DI) 
;  572:  	{ 
;  573:  		return res; 
;  574:  	} 
;  575:  	 
;  576:  	res = GetInput(ch-1);	// GetInput() : ch = 0-base 
;  577:  	 
;  578:  	return res; 
;  579:  } 
;  580:   
;  581:  unsigned char GetOutput2(char ch) 
;  582:  { 
;  583:  	unsigned char res = 0; 
;  584:   
;  585:  	if (ch < 1 || ch > MAX_DO) 
;  586:  	{ 
;  587:  		return res; 
;  588:  	} 
;  589:  	 
;  590:  	res = GetOutput(ch-1);	// GetOutput() : ch = 0-base 
;  591:   
;  592:  	return res;	 
;  593:  } 
;  594:   
;  595:  void SetOutput2(char ch, unsigned char data) 
;  596:  { 
;  597:  	if (ch < 1 || ch > MAX_DO) 
;  598:  	{ 
;  599:  		return; 
;  600:  	} 
;  601:  	 
;  602:  	SetOutput(ch-1, data); 
;  603:  } 
;  604:   
;  605:  char GetDI(char ch) 
;  606:  { 
;  607:  	char res = 0; 
;  608:   
;  609:  	if (ch >= 0 && ch < MAX_DI) 
;  610:  	{ 
;  611:  		res = (((GetInput16() >> ch) & 1) == SENS_ON); 
;  612:  	} 
;  613:  	 
;  614:  	return res; 
;  615:  } 
;  616:   
;  617:  char GetDO(char ch) 
;  618:  { 
;  619:  	char res = 0; 
;  620:   
;  621:  	if (ch >= 0 && ch < MAX_DO) 
;  622:  	{ 
;  623:  		//res = (((GetOutput12() >> ch) & 1) == SENS_ON); 
;  624:  		res = (((GetOutput8() >> ch) & 1) == SENS_ON); 
;  625:  	} 
;  626:  	 
;  627:  	return res; 
;  628:  } 
;  629:   
;  630:  void SetDO(char ch, char flag) 
;  631:  { 
;  632:  	char res = 0; 
;  633:  	int value = 0; 
;  634:   
;  635:  	if (ch >= 0 && ch < MAX_DO) 
;  636:  	{ 
;  637:  		value = (1 << ch); 
;  638:  		if (flag) 
;  639:  		{ 
;  640:  			//SetOutput12(GetOutput12() & ~value); 
;  641:  			SetOutput8(GetOutput8() & ~value); 
;  642:  		} 
;  643:  		else 
;  644:  		{ 
;  645:  			//SetOutput12(GetOutput12() | value); 
;  646:  			SetOutput8(GetOutput8() | value); 
;  647:  		} 
;  648:  	} 
;  649:  } 
;  650:   
;  651:  unsigned char GetDIBit(char ch, char bit) 
;  652:  { 
;  653:  	unsigned char res = GetInput2(ch); 
;  654:  	 
;  655:  	res = (res >> bit) & 1; 
;  656:  	 
;  657:  	return res; 
;  658:  } 
;  659:   
;  660:  unsigned char GetDOBit(char ch, char bit) 
;  661:  { 
;  662:  	unsigned char res = GetOutput2(ch); 
;  663:  	 
;  664:  	res = (res >> bit) & 1; 
;  665:  	 
;  666:  	return res;	 
;  667:  } 
;  668:   
;  669:  void SetDOBit(char ch, char bit, char flag) 
;  670:  { 
;  671:  	unsigned char res = GetOutput2(ch); 
;  672:  	 
;  673:  	if (flag == 0) 
;  674:  	{ 
;  675:  		res = res & (unsigned char)(~(1 << bit)); 
;  676:  	} 
;  677:  	else 
;  678:  	{ 
;  679:  		res = res | (1 << bit); 
;  680:  	} 
;  681:  	 
;  682:  	SetOutput2(ch, res); 
;  683:  } 
;  684:   
;  685:  void UpdateOriginCompletedStatus() 
;  686:  { 
;  687:  	char axis = 0; 
;  688:  	char flag = 1; 
;  689:   
;  690:  	for (axis = 0; axis < MAX_AXIS; ++axis) 
;  691:  	{ 
;  692:  		if (g_OriginNeed[axis] && g_OriginCompletedAxes[axis] == 0) 
;  693:  		{ 
;  694:  			flag = 0; 
;  695:  			break; 
;  696:  		} 
;  697:  	} 
;  698:  	 
;  699:  	g_OriginCompleted = flag; 
;  700:  } 
;  701:   
;  702:  void SetOriginCompletedFlag(char axis, char flag) 
;  703:  { 
;  704:  	if (axis < 0 || axis >= MAX_AXIS) 
;  705:  	{ 
;  706:  		return; 
;  707:  	} 
;  708:  	 
;  709:  	if (flag < 0 || flag > 1) 
;  710:  	{ 
;  711:  		return; 
;  712:  	} 
;  713:  	 
;  714:  	g_OriginCompletedAxes[axis] = flag; 
;  715:  	 
;  716:  	UpdateOriginCompletedStatus(); 
;  717:  } 
;  718:   
;  719:  char IsOriginCompleted() 
;  720:  { 
;  721:  	return g_OriginCompleted; 
;  722:  } 
;  723:   
;  724:  char IsStopped() 
;  725:  { 
;  726:  	char axis = 0; 
;  727:  	char moveStatus = 0; 
;  728:  	 
;  729:  	for (axis = 0; axis < MAX_AXIS; ++axis) 
;  730:  	{ 
;  731:  		moveStatus = GetMoveStatus(axis); 
;  732:  		if (moveStatus != MOVE_STS_STOP) 
;  733:  		{ 
;  734:  			return 0; 
;  735:  		} 
;  736:  	} 
;  737:  	 
;  738:  	return 1; 
;  739:  } 
;  740:   
;  741:  void HoldMotors() 
;  742:  { 
;  743:  	char axis = 0; 
;  744:  	 
;  745:  	for (axis = 0; axis < MAX_AXIS; ++axis) 
;  746:  	{ 
;  747:  		SetHoldTorque(axis); 
;  748:  	} 
;  749:  } 
;  750:   
;  751:  void StopMotors() 
;  752:  { 
;  753:  	char axis = 0; 
;  754:  	 
;  755:  	for (axis = 0; axis < MAX_AXIS; ++axis) 
;  756:  	{ 
;  757:  		MoveStop(axis); 
;  758:  	} 
;  759:  } 
