;  644:  void SetDO(char ch, char flag) 
;  645:  { 
;  646:  	char res = 0; 
;  647:  	int value = 0; 
;  648:   
;  649:  	if (ch >= 0 && ch < MAX_DO) 
;  650:  	{ 
;  651:  		value = (1 << ch); 
;  652:  		if (flag) 
;  653:  		{ 
;  654:  			//SetOutput12(GetOutput12() & ~value); 
;  655:  			SetOutput8(GetOutput8() & ~value); 
;  656:  		} 
;  657:  		else 
;  658:  		{ 
;  659:  			//SetOutput12(GetOutput12() | value); 
;  660:  			SetOutput8(GetOutput8() | value); 
