; 2210:   
; 2211:  	case 13: 
; 2212:  		HoldMotors(); 
; 2213:  		g_MovePointDataNo = 0; 
; 2214:  		g_MoveOffset[X_AXIS] = g_MoveOffset[Y_AXIS] = g_MoveOffset[Z_AXIS] = 0; 
; 2215:  		step = 0; 
; 2216:  		return NORMAL_FINISHED; 
; 2217:   
; 2218:  	default: 
; 2219:  		step = 0; 
; 2220:  		return NORMAL_FINISHED; 
; 2221:  	} 
; 2222:   
; 2223:  	CHECK_USER_STOP(); 
; 2224:   
