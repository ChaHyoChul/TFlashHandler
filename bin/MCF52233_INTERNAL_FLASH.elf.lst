;  766:  { 
;  767:  	char axis = 0; 
;  768:  	 
;  769:  	for (axis = 0; axis < MAX_AXIS; ++axis) 
;  770:  	{ 
;  771:  		MoveStop(axis); 
;  772:  	} 
;  773:  } 
;  774:   
;  775:   
;  776:  char CommErrorStop() 
