;  400:  	} 
;  401:  	 
;  402:  	// system out 
;  403:  	SetDO(0, is_stopped == 0); 
;  404:  	SetDO(1, is_stopped); 
;  405:  	SetDO(2, g_OriginCompleted); 
;  406:  	SetDO(3, g_ErrorCode == ERR_OVER_RUN); 
