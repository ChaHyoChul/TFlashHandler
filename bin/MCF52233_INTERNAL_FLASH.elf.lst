;  562:   
;  563:  void SetOutput(char ch, unsigned char data) 
;  564:  { 
;  565:  	//unsigned short cur = GetOutput12();		// active low 
;  566:  	unsigned short cur = GetOutput8(); 
;  567:  	unsigned short data2 = 0xFF & (~data);	// active high -> active low 
;  568:  	 
;  569:  	if (ch < 0 || ch > 1) 
;  570:  	{ 
;  571:  		return; 
;  572:  	} 
;  573:  	 
;  574:  	cur = cur & (unsigned short)(~(0xFF << (8*ch))); 
;  575:  	data2 = cur | (unsigned short)(data2 << (8*ch)); 
;  576:  	 
;  577:  	// SetOutput12(data2); 
;  578:  	SetOutput8(data2); 
;  579:  } 
;  580:   
;  581:  unsigned char GetInput2(char ch) 
;  582:  { 
;  583:  	unsigned char res = 0; 
;  584:   
;  585:  	if (ch < 1 || ch > MAX_DI) 
;  586:  	{ 
;  587:  		return res; 
;  588:  	} 
;  589:  	 
;  590:  	res = GetInput(ch-1);	// GetInput() : ch = 0-base 
;  591:  	 
;  592:  	return res; 
;  593:  } 
;  594:   
;  595:  unsigned char GetOutput2(char ch) 
;  596:  { 
;  597:  	unsigned char res = 0; 
;  598:   
;  599:  	if (ch < 1 || ch > MAX_DO) 
;  600:  	{ 
;  601:  		return res; 
;  602:  	} 
;  603:  	 
;  604:  	res = GetOutput(ch-1);	// GetOutput() : ch = 0-base 
;  605:   
;  606:  	return res;	 
;  607:  } 
;  608:   
;  609:  void SetOutput2(char ch, unsigned char data) 
;  610:  { 
;  611:  	if (ch < 1 || ch > MAX_DO) 
;  612:  	{ 
;  613:  		return; 
;  614:  	} 
;  615:  	 
;  616:  	SetOutput(ch-1, data); 
;  617:  } 
;  618:   
;  619:  char GetDI(char ch) 
;  620:  { 
;  621:  	char res = 0; 
;  622:   
;  623:  	if (ch >= 0 && ch < MAX_DI) 
;  624:  	{ 
;  625:  		res = (((GetInput16() >> ch) & 1) == SENS_ON); 
;  626:  	} 
;  627:  	 
;  628:  	return res; 
;  629:  } 
;  630:   
;  631:  char GetDO(char ch) 
;  632:  { 
;  633:  	char res = 0; 
;  634:   
;  635:  	if (ch >= 0 && ch < MAX_DO) 
;  636:  	{ 
;  637:  		//res = (((GetOutput12() >> ch) & 1) == SENS_ON); 
;  638:  		res = (((GetOutput8() >> ch) & 1) == SENS_ON); 
;  639:  	} 
;  640:  	 
;  641:  	return res; 
;  642:  } 
;  643:   
;  644:  void SetDO(char ch, char flag) 
;  645:  { 
;  646:  	char res = 0; 
;  647:  	int value = 0; 
;  648:   
;  649:  	if (ch >= 0 && ch < MAX_DO) 
;  650:  	{ 
;  651:  		value = (1 << ch); 
;  652:  		if (flag) 
;  653:  		{ 
;  654:  			//SetOutput12(GetOutput12() & ~value); 
;  655:  			SetOutput8(GetOutput8() & ~value); 
;  656:  		} 
;  657:  		else 
;  658:  		{ 
;  659:  			//SetOutput12(GetOutput12() | value); 
;  660:  			SetOutput8(GetOutput8() | value); 
;  661:  		} 
;  662:  	} 
;  663:  } 
;  664:   
;  665:  unsigned char GetDIBit(char ch, char bit) 
;  666:  { 
;  667:  	unsigned char res = GetInput2(ch); 
;  668:  	 
;  669:  	res = (res >> bit) & 1; 
;  670:  	 
;  671:  	return res; 
;  672:  } 
;  673:   
;  674:  unsigned char GetDOBit(char ch, char bit) 
;  675:  { 
;  676:  	unsigned char res = GetOutput2(ch); 
;  677:  	 
;  678:  	res = (res >> bit) & 1; 
;  679:  	 
;  680:  	return res;	 
;  681:  } 
;  682:   
;  683:  void SetDOBit(char ch, char bit, char flag) 
;  684:  { 
;  685:  	unsigned char res = GetOutput2(ch); 
;  686:  	 
;  687:  	if (flag == 0) 
;  688:  	{ 
;  689:  		res = res & (unsigned char)(~(1 << bit)); 
;  690:  	} 
;  691:  	else 
;  692:  	{ 
;  693:  		res = res | (1 << bit); 
;  694:  	} 
;  695:  	 
;  696:  	SetOutput2(ch, res); 
;  697:  } 
