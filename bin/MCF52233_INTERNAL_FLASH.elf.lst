;  422:  				MoveStop(axis); 
;  423:  			} 
;  424:  			g_OriginCompleted = 0; 
;  425:  			return; 
;  426:  		} 
;  427:  	} 
;  428:   
;  429:  	switch (g_MotionCommand) 
;  430:  	{ 
;  431:  	case COMM_IDLE: 
;  432:  		if (IsStopped()) 
;  433:  		{ 
;  434:  			return; 
;  435:  		} 
;  436:  		break; 
;  437:  	case COMM_ORIGIN: 
;  438:  	case COMM_ERROR_STOP: 
;  439:  		return; 
;  440:  	} 
