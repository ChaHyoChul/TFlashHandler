; 1134:  		} 
; 1135:  		 
; 1136:  		++timerCount; 
; 1137:  		Delay1ms(); 
; 1138:  		break; 
; 1139:  		 
; 1140:  	case 22: 
; 1141:  		step = 0; 
; 1142:   
; 1143:  		for (axis = 0; axis < MAX_AXIS; ++axis) 
; 1144:  		{ 
; 1145:  			SetOriginCompletedFlag(axis, 1); 
; 1146:  		} 
; 1147:   
; 1148:  		return NORMAL_FINISHED;	// ’┐Į’┐Į’┐Į’┐Į : Move Origin ’┐Į’┐Į’┐Į’┐Į ’┐ĮŽĘ’┐Į 
; 1149:   
; 1150:  	default: 
; 1151:  		return NORMAL_FINISHED; 
; 1152:   
; 1153:  	} 
; 1154:  	 
; 1155:  	CHECK_USER_STOP(); 
; 1156:  	 
; 1157:  	return NORMAL_RUNNING; 
; 1158:  } 
