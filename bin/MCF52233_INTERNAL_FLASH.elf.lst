;  528:   
;  529:  unsigned char GetInput(char ch) 
;  530:  { 
;  531:  	unsigned char res = 0; 
;  532:  	unsigned short val = 0; 
;  533:  	 
;  534:  	if (ch < 0 || ch > 1) 
;  535:  	{ 
;  536:  		return res; 
;  537:  	} 
;  538:  	 
;  539:  	val = ~GetInput16(); 
;  540:  	 
;  541:  	res = (val >> (8*ch)) & 0xFF; 
;  542:  	 
;  543:  	return res; 
;  544:  } 
;  545:   
;  546:  unsigned char GetOutput(char ch) 
;  547:  { 
;  548:  	unsigned char res = 0; 
;  549:  	unsigned short val = 0; 
;  550:  	 
;  551:  	if (ch < 0 || ch > 1) 
;  552:  	{ 
;  553:  		return res; 
;  554:  	} 
;  555:  	 
;  556:  	//val = ~GetOutput12(); 
;  557:  	val = ~GetOutput8(); 
;  558:  	 
;  559:  	res = (val >> (8*ch)) & 0xFF; 
;  560:  	 
;  561:  	return res; 
;  562:  } 
;  563:   
;  564:  void SetOutput(char ch, unsigned char data) 
;  565:  { 
;  566:  	//unsigned short cur = GetOutput12();		// active low 
;  567:  	unsigned short cur = GetOutput8(); 
;  568:  	unsigned short data2 = 0xFF & (~data);	// active high -> active low 
;  569:  	 
;  570:  	if (ch < 0 || ch > 1) 
;  571:  	{ 
;  572:  		return; 
;  573:  	} 
;  574:  	 
;  575:  	cur = cur & (unsigned short)(~(0xFF << (8*ch))); 
;  576:  	data2 = cur | (unsigned short)(data2 << (8*ch)); 
;  577:  	 
;  578:  	// SetOutput12(data2); 
;  579:  	SetOutput8(data2); 
;  580:  } 
;  581:   
;  582:  unsigned char GetInput2(char ch) 
;  583:  { 
;  584:  	unsigned char res = 0; 
;  585:   
;  586:  	if (ch < 1 || ch > MAX_DI) 
;  587:  	{ 
;  588:  		return res; 
;  589:  	} 
;  590:  	 
;  591:  	res = GetInput(ch-1);	// GetInput() : ch = 0-base 
;  592:  	 
;  593:  	return res; 
;  594:  } 
;  595:   
;  596:  unsigned char GetOutput2(char ch) 
;  597:  { 
;  598:  	unsigned char res = 0; 
;  599:   
;  600:  	if (ch < 1 || ch > MAX_DO) 
;  601:  	{ 
;  602:  		return res; 
;  603:  	} 
;  604:  	 
;  605:  	res = GetOutput(ch-1);	// GetOutput() : ch = 0-base 
;  606:   
;  607:  	return res;	 
;  608:  } 
;  609:   
;  610:  void SetOutput2(char ch, unsigned char data) 
;  611:  { 
;  612:  	if (ch < 1 || ch > MAX_DO) 
;  613:  	{ 
;  614:  		return; 
;  615:  	} 
;  616:  	 
;  617:  	SetOutput(ch-1, data); 
;  618:  } 
;  619:   
;  620:  char GetDI(char ch) 
;  621:  { 
;  622:  	char res = 0; 
;  623:   
;  624:  	if (ch >= 0 && ch < MAX_DI) 
;  625:  	{ 
;  626:  		res = (((GetInput16() >> ch) & 1) == SENS_ON); 
;  627:  	} 
;  628:  	 
;  629:  	return res; 
;  630:  } 
;  631:   
;  632:  char GetDO(char ch) 
;  633:  { 
;  634:  	char res = 0; 
;  635:   
;  636:  	if (ch >= 0 && ch < MAX_DO) 
;  637:  	{ 
;  638:  		//res = (((GetOutput12() >> ch) & 1) == SENS_ON); 
;  639:  		res = (((GetOutput8() >> ch) & 1) == SENS_ON); 
;  640:  	} 
;  641:  	 
;  642:  	return res; 
;  643:  } 
;  644:   
;  645:  void SetDO(char ch, char flag) 
;  646:  { 
;  647:  	char res = 0; 
;  648:  	int value = 0; 
;  649:   
;  650:  	if (ch >= 0 && ch < MAX_DO) 
;  651:  	{ 
;  652:  		value = (1 << ch); 
;  653:  		if (flag) 
;  654:  		{ 
;  655:  			//SetOutput12(GetOutput12() & ~value); 
;  656:  			SetOutput8(GetOutput8() & ~value); 
;  657:  		} 
;  658:  		else 
;  659:  		{ 
;  660:  			//SetOutput12(GetOutput12() | value); 
;  661:  			SetOutput8(GetOutput8() | value); 
;  662:  		} 
;  663:  	} 
;  664:  } 
;  665:   
;  666:  unsigned char GetDIBit(char ch, char bit) 
;  667:  { 
;  668:  	unsigned char res = GetInput2(ch); 
;  669:  	 
;  670:  	res = (res >> bit) & 1; 
;  671:  	 
;  672:  	return res; 
;  673:  } 
;  674:   
;  675:  unsigned char GetDOBit(char ch, char bit) 
;  676:  { 
;  677:  	unsigned char res = GetOutput2(ch); 
;  678:  	 
;  679:  	res = (res >> bit) & 1; 
;  680:  	 
;  681:  	return res;	 
;  682:  } 
;  683:   
;  684:  void SetDOBit(char ch, char bit, char flag) 
;  685:  { 
;  686:  	unsigned char res = GetOutput2(ch); 
;  687:  	 
;  688:  	if (flag == 0) 
;  689:  	{ 
;  690:  		res = res & (unsigned char)(~(1 << bit)); 
;  691:  	} 
;  692:  	else 
;  693:  	{ 
;  694:  		res = res | (1 << bit); 
;  695:  	} 
;  696:  	 
;  697:  	SetOutput2(ch, res); 
;  698:  } 
;  699:   
;  700:  void UpdateOriginCompletedStatus() 
;  701:  { 
;  702:  	char axis = 0; 
;  703:  	char flag = 1; 
;  704:   
;  705:  	for (axis = 0; axis < MAX_AXIS; ++axis) 
;  706:  	{ 
;  707:  		if (g_OriginNeed[axis] && g_OriginCompletedAxes[axis] == 0) 
;  708:  		{ 
;  709:  			flag = 0; 
;  710:  			break; 
;  711:  		} 
;  712:  	} 
;  713:  	 
;  714:  	g_OriginCompleted = flag; 
;  715:  } 
;  716:   
;  717:  void SetOriginCompletedFlag(char axis, char flag) 
;  718:  { 
;  719:  	if (axis < 0 || axis >= MAX_AXIS) 
;  720:  	{ 
;  721:  		return; 
;  722:  	} 
;  723:  	 
;  724:  	if (flag < 0 || flag > 1) 
;  725:  	{ 
;  726:  		return; 
;  727:  	} 
;  728:  	 
;  729:  	g_OriginCompletedAxes[axis] = flag; 
;  730:  	 
;  731:  	UpdateOriginCompletedStatus(); 
;  732:  } 
;  733:   
;  734:  char IsOriginCompleted() 
;  735:  { 
;  736:  	return g_OriginCompleted; 
;  737:  } 
;  738:   
;  739:  char IsStopped() 
;  740:  { 
;  741:  	char axis = 0; 
;  742:  	char moveStatus = 0; 
;  743:  	 
;  744:  	for (axis = 0; axis < MAX_AXIS; ++axis) 
;  745:  	{ 
;  746:  		moveStatus = GetMoveStatus(axis); 
;  747:  		if (moveStatus != MOVE_STS_STOP) 
;  748:  		{ 
;  749:  			return 0; 
;  750:  		} 
;  751:  	} 
;  752:  	 
;  753:  	return 1; 
;  754:  } 
;  755:   
;  756:  void HoldMotors() 
;  757:  { 
;  758:  	char axis = 0; 
;  759:  	 
;  760:  	for (axis = 0; axis < MAX_AXIS; ++axis) 
;  761:  	{ 
;  762:  		SetHoldTorque(axis); 
;  763:  	} 
;  764:  } 
;  765:   
;  766:  void StopMotors() 
;  767:  { 
;  768:  	char axis = 0; 
;  769:  	 
;  770:  	for (axis = 0; axis < MAX_AXIS; ++axis) 
;  771:  	{ 
;  772:  		MoveStop(axis); 
;  773:  	} 
;  774:  } 
;  775:   
;  776:   
;  777:  char CommErrorStop() 
;  778:  { 
;  779:  	static int step = 0; 
;  780:  	 
;  781:  	switch (step) 
;  782:  	{ 
;  783:  	// Error Handling 
;  784:  	case 0: 
;  785:  		StopMotors(); 
;  786:  		++step; 
;  787:  		break; 
;  788:  	 
;  789:  	case 1: 
;  790:  		if (IsStopped()) 
;  791:  		{ 
;  792:  			++step; 
;  793:  		} 
;  794:  		break; 
;  795:  		 
;  796:  	case 2: 
;  797:  		HoldMotors(); 
;  798:  		step = 0; 
;  799:  		return ERROR_STOPPED; 
;  800:  		 
;  801:  	default: 
;  802:  		step = 0; 
;  803:  		return NORMAL_FINISHED; 
;  804:  	} 
;  805:  	 
;  806:  	return NORMAL_RUNNING; 
;  807:  } 
