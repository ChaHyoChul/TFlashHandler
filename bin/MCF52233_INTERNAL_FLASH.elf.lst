; 1521:   
; 1522:  		step = 0; 
; 1523:  		 
; 1524:  		return NORMAL_FINISHED;	// ’┐Į’┐Į’┐Į’┐Į : Move Origin ’┐Į’┐Į’┐Į’┐Į ’┐ĮŽĘ’┐Į 
; 1525:   
; 1526:  	default: 
; 1527:  		step = 0; 
; 1528:  		return NORMAL_FINISHED;	// ’┐Į’┐Į’┐Į’┐Į : Move Origin ’┐Į’┐Į’┐Į’┐Į ’┐Į’┐Į? 
; 1529:  	} 
; 1530:   
; 1531:  	CHECK_USER_STOP(); 
; 1532:  	 
; 1533:  	return 0; 
; 1534:  } 
