;  742:  { 
;  743:  	char axis = 0; 
;  744:  	 
;  745:  	for (axis = 0; axis < MAX_AXIS; ++axis) 
;  746:  	{ 
;  747:  		SetHoldTorque(axis); 
;  748:  	} 
;  749:  } 
;  750:   
;  751:  void StopMotors() 
;  752:  { 
;  753:  	char axis = 0; 
;  754:  	 
;  755:  	for (axis = 0; axis < MAX_AXIS; ++axis) 
;  756:  	{ 
;  757:  		MoveStop(axis); 
;  758:  	} 
;  759:  } 
;  760:   
;  761:   
;  762:  char CommErrorStop() 
;  763:  { 
;  764:  	static int step = 0; 
;  765:  	 
;  766:  	switch (step) 
;  767:  	{ 
;  768:  	// Error Handling 
;  769:  	case 0: 
;  770:  		StopMotors(); 
;  771:  		++step; 
;  772:  		break; 
;  773:  	 
;  774:  	case 1: 
;  775:  		if (IsStopped()) 
;  776:  		{ 
;  777:  			++step; 
;  778:  		} 
;  779:  		break; 
;  780:  		 
;  781:  	case 2: 
;  782:  		HoldMotors(); 
;  783:  		step = 0; 
;  784:  		return ERROR_STOPPED; 
;  785:  		 
;  786:  	default: 
;  787:  		step = 0; 
;  788:  		return NORMAL_FINISHED; 
;  789:  	} 
;  790:  	 
;  791:  	return NORMAL_RUNNING; 
;  792:  } 
