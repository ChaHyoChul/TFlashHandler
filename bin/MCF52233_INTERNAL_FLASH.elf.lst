; 1613:  } 
; 1614:   
; 1615:  unsigned char GetRawDir(char axis, unsigned char dir) 
; 1616:  { 
; 1617:  	unsigned char retDir = dir; 
; 1618:   
; 1619:  	// change the direction for X-axis 
; 1620:  	if (axis == X_AXIS) 
; 1621:  	{ 
; 1622:  		retDir = 1 - retDir; 
; 1623:  	} 
; 1624:  	 
; 1625:  	return retDir; 
; 1626:  } 
; 1627:   
; 1628:  unsigned char InverseDir(unsigned char dir) 
; 1629:  { 
; 1630:  	return 1 - dir; 
; 1631:  } 
; 1632:   
; 1633:  void SetMoveOffset(char axis, int offset) 
; 1634:  { 
; 1635:  	unsigned char dir = g_MotionParam[axis].m_ucMoveDir; 
; 1636:  	if (offset < 0) 
; 1637:  	{ 
; 1638:  		dir = InverseDir(dir); 
; 1639:  		offset = -offset; 
; 1640:  	} 
; 1641:  	 
; 1642:  	MovVar[axis].m_uS    = offset; 
; 1643:  	MovVar[axis].m_ucDir = dir; 
; 1644:  } 
; 1645:   
; 1646:  void SetSpeed(char axis, int type) 
; 1647:  { 
; 1648:  	int scan_rate = get_var(VAR_SCAN_SPEED); 
; 1649:   
; 1650:  	if (scan_rate < 1 || scan_rate > 100) 
; 1651:  	{ 
; 1652:  		scan_rate = 100; 
; 1653:  	} 
; 1654:  	 
; 1655:  	if (axis < 0 || axis >= MAX_AXIS) 
; 1656:  	{ 
; 1657:  		return; 
; 1658:  	} 
