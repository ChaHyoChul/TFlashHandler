;  348:  		} 
;  349:  		GoToIdle(); 
;  350:  		break; 
;  351:  	 
;  352:  	case ERROR_STOPPED: 
;  353:  		SendResponse(); 
;  354:  		GoToIdle(); 
;  355:  		break; 
;  356:  	} 
;  357:  } 
;  358:   
;  359:  /////////////////////////////////////////////////////////// 
;  360:  // 1ms Timer Interrupt ’┐Į’┐Į ’┐Į╠┐’┐Į’┐Į’┐Į ’┐Į’┐Į’┐Į ’┐Į’┐Į’┐Į’┐Į ─┐’┐Į’┐Į’┐Į ├│’┐Į’┐Į ’┐Į’┐ĮŲŠ 
;  361:  /////////////////////////////////////////////////////////// 
;  362:  void MainControl() 
;  363:  { 
;  364:  	char res = 0; 
;  365:   
;  366:  	switch (g_MotionCommand) 
;  367:  	{ 
;  368:  	case COMM_IDLE:		break; 
;  369:  	case COMM_ORIGIN:	res = CommOrigin();	UpdateState(res);	break; 
;  370:  	case COMM_PTP:		res = CommMove();	UpdateState(res);	break; 
;  371:  	case COMM_ORIGIN_A:	res = CommOriginAxis();	UpdateState(res);	break; 
;  372:  	case COMM_ERROR_STOP:	res = CommErrorStop();	UpdateState(res);	break; 
;  373:   
;  374:  	case COMM_HOME:		res = CommHome(); UpdateState(res); break; 
;  375:  	case COMM_MGRI:		res = CommGripUngrip(); UpdateState(res); break; 
;  376:  	case COMM_MUNG:		res = CommGripUngrip(); UpdateState(res); break; 
;  377:  	case COMM_MLOA:		res = CommMoveXY(); UpdateState(res); break; 
;  378:  	case COMM_MASP:		res = CommMoveXY(); UpdateState(res); break; 
;  379:  	case COMM_MDIS:		res = CommMoveXY(); UpdateState(res); break; 
;  380:  	case COMM_MSHA:		res = CommShake(); UpdateState(res); break; 
;  381:  	case COMM_MWAS:		res = CommWaste(); UpdateState(res); break; 
;  382:  	} 
;  383:  	 
;  384:  	if (g_UserStop > 0) 
;  385:  	{ 
;  386:  		--g_UserStop; 
;  387:  	} 
;  388:  	 
;  389:  	if (g_GoToError > 0) 
;  390:  	{ 
;  391:  		if (g_UserStop < 3) 
;  392:  		{ 
;  393:  			g_MotionCommand = COMM_ERROR_STOP; 
;  394:  			g_GoToError = 0; 
;  395:  		} 
;  396:  	} 
;  397:  } 
;  398:   
;  399:  void SystemCheck() 
;  400:  { 
;  401:  	char res = 0; 
;  402:  	char axis = 0; 
;  403:  	char userEmo = 0; 
;  404:  	char is_stopped = 0; 
;  405:  	char use_UserEMO = 0; 
;  406:  	 
;  407:  	if (g_MotionCommand == COMM_IDLE && IsStopped()) 
;  408:  	{ 
;  409:  		is_stopped = 1; 
;  410:  	} 
;  411:  	 
;  412:  	// system out 
;  413:  	SetDO(0, is_stopped == 0); 
;  414:  	SetDO(1, is_stopped); 
;  415:  	SetDO(2, g_OriginCompleted); 
;  416:  	SetDO(3, g_ErrorCode == ERR_OVER_RUN); 
;  417:  	SetDO(4, g_ErrorCode != 0); 
;  418:  	 
;  419:  	 
;  420:  	if (use_UserEMO)	// currently not used (1.00.016) 
;  421:  	{ 
;  422:  		// User Emergency 
;  423:  		userEmo = GetDI(0); 
;  424:  	 
;  425:  		if (userEmo == 0) // reverse, 0=EMO, 1=Normal 
;  426:  		{ 
;  427:  			SetErrorCode(ERR_EMERGENCY); 
;  428:  			GoToError(); 
;  429:  			for (axis = 0; axis < MAX_AXIS; ++axis) 
;  430:  			{ 
;  431:  				MovVar[g_OriginAxis].m_uAcel = EMERGENCY_STOP_DECEL; 
;  432:  				MoveStop(axis); 
;  433:  			} 
;  434:  			g_OriginCompleted = 0; 
;  435:  			return; 
;  436:  		} 
;  437:  	} 
;  438:   
;  439:  	switch (g_MotionCommand) 
;  440:  	{ 
;  441:  	case COMM_IDLE: 
;  442:  		if (IsStopped()) 
;  443:  		{ 
;  444:  			return; 
;  445:  		} 
;  446:  		break; 
;  447:  	case COMM_ORIGIN: 
;  448:  	case COMM_ERROR_STOP: 
;  449:  		return; 
;  450:  	} 
;  451:  	 
;  452:  	// check limit sensor 
;  453:  	 
;  454:  	if (g_MotionCommand == COMM_IDLE) 
;  455:  	{ 
;  456:  		for (axis = 0; axis < MAX_AXIS; ++axis) 
;  457:  		{ 
;  458:  			if (GetMoveStatus(axis) != MOVE_STS_STOP) 
;  459:  			{ 
;  460:  				switch (get_axis_sensor(axis)) 
;  461:  				{ 
;  462:  				case 0: 
;  463:  					break; 
;  464:  					 
;  465:  				case 1:	// POS LIMIT 
;  466:  					if (MovVar[axis].m_ucDir == g_MotionParam[axis].m_ucMoveDir) 
;  467:  					{ 
;  468:  						SetErrorCode(ERR_OVER_RUN); 
;  469:  						StopMotors(); 
;  470:  					} 
;  471:  					break; 
;  472:  					 
;  473:  				case 2: // NEG LIMIT 
;  474:  					if (MovVar[axis].m_ucDir != g_MotionParam[axis].m_ucMoveDir) 
;  475:  					{ 
;  476:  						SetErrorCode(ERR_OVER_RUN); 
;  477:  						StopMotors(); 
;  478:  					} 
;  479:  					break; 
;  480:  					 
;  481:  				default: 
;  482:  					SetErrorCode(ERR_OVER_RUN); 
;  483:  					StopMotors(); 
;  484:  					break;		 
;  485:  				} 
;  486:  			} 
;  487:  		} 
;  488:  	} 
;  489:  	else 
;  490:  	{ 
;  491:  		for (axis = 0; axis < MAX_AXIS; ++axis) 
;  492:  		{ 
;  493:  			switch (get_axis_sensor(axis)) 
;  494:  			{ 
;  495:  			case 0: 
;  496:  				break; 
;  497:  				 
;  498:  			case 1:	// POS LIMIT 
;  499:  				if (g_MoveOffset[axis] > 0) 
;  500:  				{ 
;  501:  					SetErrorCode(ERR_OVER_RUN); 
;  502:  					GoToError(); 
;  503:  				} 
;  504:  				break; 
;  505:  				 
;  506:  			case 2: // NEG LIMIT 
;  507:  				if (g_MoveOffset[axis] < 0) 
;  508:  				{ 
;  509:  					SetErrorCode(ERR_OVER_RUN); 
;  510:  					GoToError(); 
;  511:  				} 
;  512:  				break; 
;  513:  				 
;  514:  			default: 
;  515:  				SetErrorCode(ERR_OVER_RUN); 
;  516:  				GoToError(); 
;  517:  				break;		 
;  518:  			} 
;  519:  		} 
;  520:  	} 
;  521:  } 
;  522:   
;  523:  unsigned char GetInput(char ch) 
;  524:  { 
;  525:  	unsigned char res = 0; 
;  526:  	unsigned short val = 0; 
;  527:  	 
;  528:  	if (ch < 0 || ch > 1) 
;  529:  	{ 
;  530:  		return res; 
;  531:  	} 
;  532:  	 
;  533:  	val = ~GetInput16(); 
;  534:  	 
;  535:  	res = (val >> (8*ch)) & 0xFF; 
;  536:  	 
;  537:  	return res; 
;  538:  } 
;  539:   
;  540:  unsigned char GetOutput(char ch) 
;  541:  { 
;  542:  	unsigned char res = 0; 
;  543:  	unsigned short val = 0; 
;  544:  	 
;  545:  	if (ch < 0 || ch > 1) 
;  546:  	{ 
;  547:  		return res; 
;  548:  	} 
;  549:  	 
;  550:  	//val = ~GetOutput12(); 
;  551:  	val = ~GetOutput8(); 
;  552:  	 
;  553:  	res = (val >> (8*ch)) & 0xFF; 
;  554:  	 
;  555:  	return res; 
;  556:  } 
;  557:   
;  558:  void SetOutput(char ch, unsigned char data) 
;  559:  { 
;  560:  	//unsigned short cur = GetOutput12();		// active low 
;  561:  	unsigned short cur = GetOutput8(); 
;  562:  	unsigned short data2 = 0xFF & (~data);	// active high -> active low 
;  563:  	 
;  564:  	if (ch < 0 || ch > 1) 
;  565:  	{ 
;  566:  		return; 
;  567:  	} 
;  568:  	 
;  569:  	cur = cur & (unsigned short)(~(0xFF << (8*ch))); 
;  570:  	data2 = cur | (unsigned short)(data2 << (8*ch)); 
;  571:  	 
;  572:  	// SetOutput12(data2); 
;  573:  	SetOutput8(data2); 
;  574:  } 
;  575:   
;  576:  unsigned char GetInput2(char ch) 
;  577:  { 
;  578:  	unsigned char res = 0; 
;  579:   
;  580:  	if (ch < 1 || ch > MAX_DI) 
;  581:  	{ 
;  582:  		return res; 
;  583:  	} 
;  584:  	 
;  585:  	res = GetInput(ch-1);	// GetInput() : ch = 0-base 
;  586:  	 
;  587:  	return res; 
;  588:  } 
;  589:   
;  590:  unsigned char GetOutput2(char ch) 
;  591:  { 
;  592:  	unsigned char res = 0; 
;  593:   
;  594:  	if (ch < 1 || ch > MAX_DO) 
;  595:  	{ 
;  596:  		return res; 
;  597:  	} 
;  598:  	 
;  599:  	res = GetOutput(ch-1);	// GetOutput() : ch = 0-base 
;  600:   
;  601:  	return res;	 
;  602:  } 
;  603:   
;  604:  void SetOutput2(char ch, unsigned char data) 
;  605:  { 
;  606:  	if (ch < 1 || ch > MAX_DO) 
;  607:  	{ 
;  608:  		return; 
;  609:  	} 
;  610:  	 
;  611:  	SetOutput(ch-1, data); 
;  612:  } 
;  613:   
;  614:  char GetDI(char ch) 
;  615:  { 
;  616:  	char res = 0; 
;  617:   
;  618:  	if (ch >= 0 && ch < MAX_DI) 
;  619:  	{ 
;  620:  		res = (((GetInput16() >> ch) & 1) == SENS_ON); 
;  621:  	} 
;  622:  	 
;  623:  	return res; 
;  624:  } 
;  625:   
;  626:  char GetDO(char ch) 
;  627:  { 
;  628:  	char res = 0; 
;  629:   
;  630:  	if (ch >= 0 && ch < MAX_DO) 
;  631:  	{ 
;  632:  		//res = (((GetOutput12() >> ch) & 1) == SENS_ON); 
;  633:  		res = (((GetOutput8() >> ch) & 1) == SENS_ON); 
;  634:  	} 
;  635:  	 
;  636:  	return res; 
;  637:  } 
;  638:   
;  639:  void SetDO(char ch, char flag) 
;  640:  { 
;  641:  	char res = 0; 
;  642:  	int value = 0; 
;  643:   
;  644:  	if (ch >= 0 && ch < MAX_DO) 
;  645:  	{ 
;  646:  		value = (1 << ch); 
;  647:  		if (flag) 
;  648:  		{ 
;  649:  			//SetOutput12(GetOutput12() & ~value); 
;  650:  			SetOutput8(GetOutput8() & ~value); 
;  651:  		} 
;  652:  		else 
;  653:  		{ 
;  654:  			//SetOutput12(GetOutput12() | value); 
;  655:  			SetOutput8(GetOutput8() | value); 
;  656:  		} 
;  657:  	} 
;  658:  } 
;  659:   
;  660:  unsigned char GetDIBit(char ch, char bit) 
;  661:  { 
;  662:  	unsigned char res = GetInput2(ch); 
;  663:  	 
;  664:  	res = (res >> bit) & 1; 
;  665:  	 
;  666:  	return res; 
;  667:  } 
;  668:   
;  669:  unsigned char GetDOBit(char ch, char bit) 
;  670:  { 
;  671:  	unsigned char res = GetOutput2(ch); 
;  672:  	 
;  673:  	res = (res >> bit) & 1; 
;  674:  	 
;  675:  	return res;	 
;  676:  } 
;  677:   
;  678:  void SetDOBit(char ch, char bit, char flag) 
;  679:  { 
;  680:  	unsigned char res = GetOutput2(ch); 
;  681:  	 
;  682:  	if (flag == 0) 
;  683:  	{ 
;  684:  		res = res & (unsigned char)(~(1 << bit)); 
;  685:  	} 
;  686:  	else 
;  687:  	{ 
;  688:  		res = res | (1 << bit); 
;  689:  	} 
;  690:  	 
;  691:  	SetOutput2(ch, res); 
;  692:  } 
;  693:   
;  694:  void UpdateOriginCompletedStatus() 
;  695:  { 
;  696:  	char axis = 0; 
;  697:  	char flag = 1; 
;  698:   
;  699:  	for (axis = 0; axis < MAX_AXIS; ++axis) 
;  700:  	{ 
;  701:  		if (g_OriginNeed[axis] && g_OriginCompletedAxes[axis] == 0) 
;  702:  		{ 
;  703:  			flag = 0; 
;  704:  			break; 
;  705:  		} 
;  706:  	} 
;  707:  	 
;  708:  	g_OriginCompleted = flag; 
;  709:  } 
;  710:   
;  711:  void SetOriginCompletedFlag(char axis, char flag) 
;  712:  { 
;  713:  	if (axis < 0 || axis >= MAX_AXIS) 
;  714:  	{ 
;  715:  		return; 
;  716:  	} 
;  717:  	 
;  718:  	if (flag < 0 || flag > 1) 
;  719:  	{ 
;  720:  		return; 
;  721:  	} 
;  722:  	 
;  723:  	g_OriginCompletedAxes[axis] = flag; 
;  724:  	 
;  725:  	UpdateOriginCompletedStatus(); 
;  726:  } 
;  727:   
;  728:  char IsOriginCompleted() 
;  729:  { 
;  730:  	return g_OriginCompleted; 
;  731:  } 
;  732:   
;  733:  char IsStopped() 
;  734:  { 
;  735:  	char axis = 0; 
;  736:  	char moveStatus = 0; 
;  737:  	 
;  738:  	for (axis = 0; axis < MAX_AXIS; ++axis) 
;  739:  	{ 
;  740:  		moveStatus = GetMoveStatus(axis); 
;  741:  		if (moveStatus != MOVE_STS_STOP) 
;  742:  		{ 
;  743:  			return 0; 
;  744:  		} 
;  745:  	} 
;  746:  	 
;  747:  	return 1; 
;  748:  } 
;  749:   
;  750:  void HoldMotors() 
;  751:  { 
;  752:  	char axis = 0; 
;  753:  	 
;  754:  	for (axis = 0; axis < MAX_AXIS; ++axis) 
;  755:  	{ 
;  756:  		SetHoldTorque(axis); 
;  757:  	} 
;  758:  } 
;  759:   
;  760:  void StopMotors() 
;  761:  { 
;  762:  	char axis = 0; 
;  763:  	 
;  764:  	for (axis = 0; axis < MAX_AXIS; ++axis) 
;  765:  	{ 
;  766:  		MoveStop(axis); 
;  767:  	} 
;  768:  } 
;  769:   
;  770:   
;  771:  char CommErrorStop() 
;  772:  { 
;  773:  	static int step = 0; 
;  774:  	 
;  775:  	switch (step) 
;  776:  	{ 
;  777:  	// Error Handling 
;  778:  	case 0: 
;  779:  		StopMotors(); 
;  780:  		++step; 
;  781:  		break; 
;  782:  	 
;  783:  	case 1: 
;  784:  		if (IsStopped()) 
;  785:  		{ 
;  786:  			++step; 
;  787:  		} 
;  788:  		break; 
;  789:  		 
;  790:  	case 2: 
;  791:  		HoldMotors(); 
;  792:  		step = 0; 
;  793:  		return ERROR_STOPPED; 
;  794:  		 
;  795:  	default: 
;  796:  		step = 0; 
;  797:  		return NORMAL_FINISHED; 
;  798:  	} 
;  799:  	 
;  800:  	return NORMAL_RUNNING; 
;  801:  } 
