;  437:  				MoveStop(axis); 
;  438:  			} 
;  439:  			g_OriginCompleted = 0; 
;  440:  			return; 
;  441:  		} 
;  442:  	} 
;  443:   
;  444:  	switch (g_MotionCommand) 
;  445:  	{ 
;  446:  	case COMM_IDLE: 
;  447:  		if (IsStopped()) 
;  448:  		{ 
;  449:  			return; 
;  450:  		} 
;  451:  		break; 
;  452:  	case COMM_ORIGIN: 
;  453:  	case COMM_ERROR_STOP: 
;  454:  		return; 
;  455:  	} 
;  456:  	 
;  457:  	// check limit sensor 
;  458:  	 
;  459:  	if (g_MotionCommand == COMM_IDLE) 
;  460:  	{ 
;  461:  		for (axis = 0; axis < MAX_AXIS; ++axis) 
;  462:  		{ 
;  463:  			if (GetMoveStatus(axis) != MOVE_STS_STOP) 
;  464:  			{ 
;  465:  				switch (get_axis_sensor(axis)) 
;  466:  				{ 
;  467:  				case 0: 
;  468:  					break; 
;  469:  					 
;  470:  				case 1:	// POS LIMIT 
;  471:  					if (MovVar[axis].m_ucDir == g_MotionParam[axis].m_ucMoveDir) 
;  472:  					{ 
;  473:  						SetErrorCode(ERR_OVER_RUN); 
;  474:  						StopMotors(); 
;  475:  					} 
;  476:  					break; 
;  477:  					 
;  478:  				case 2: // NEG LIMIT 
;  479:  					if (MovVar[axis].m_ucDir != g_MotionParam[axis].m_ucMoveDir) 
;  480:  					{ 
;  481:  						SetErrorCode(ERR_OVER_RUN); 
;  482:  						StopMotors(); 
;  483:  					} 
;  484:  					break; 
;  485:  					 
;  486:  				default: 
;  487:  					SetErrorCode(ERR_OVER_RUN); 
;  488:  					StopMotors(); 
;  489:  					break;		 
;  490:  				} 
;  491:  			} 
;  492:  		} 
;  493:  	} 
;  494:  	else 
;  495:  	{ 
;  496:  		for (axis = 0; axis < MAX_AXIS; ++axis) 
;  497:  		{ 
;  498:  			switch (get_axis_sensor(axis)) 
;  499:  			{ 
;  500:  			case 0: 
;  501:  				break; 
;  502:  				 
;  503:  			case 1:	// POS LIMIT 
;  504:  				if (g_MoveOffset[axis] > 0) 
;  505:  				{ 
;  506:  					SetErrorCode(ERR_OVER_RUN); 
;  507:  					GoToError(); 
;  508:  				} 
;  509:  				break; 
;  510:  				 
;  511:  			case 2: // NEG LIMIT 
;  512:  				if (g_MoveOffset[axis] < 0) 
;  513:  				{ 
;  514:  					SetErrorCode(ERR_OVER_RUN); 
;  515:  					GoToError(); 
;  516:  				} 
;  517:  				break; 
;  518:  				 
;  519:  			default: 
