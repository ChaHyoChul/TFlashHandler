;  332:   
;  333:  void UpdateState(char state) 
;  334:  { 
;  335:  	switch (state) 
;  336:  	{ 
;  337:  	case NORMAL_RUNNING: 
;  338:  		break; 
;  339:  	 
;  340:  	case NORMAL_FINISHED: 
;  341:  		if (g_ResponseSend == 0) 
;  342:  		{ 
;  343:  			SendResponse(); 
;  344:  		} 
;  345:  		else 
;  346:  		{ 
;  347:  			g_ResponseSend = 0; 
;  348:  		} 
;  349:  		GoToIdle(); 
;  350:  		break; 
;  351:  	 
;  352:  	case ERROR_STOPPED: 
;  353:  		SendResponse(); 
;  354:  		GoToIdle(); 
;  355:  		break; 
;  356:  	} 
;  357:  } 
;  358:   
;  359:  /////////////////////////////////////////////////////////// 
;  360:  // 1ms Timer Interrupt ’┐Į’┐Į ’┐Į╠┐’┐Į’┐Į’┐Į ’┐Į’┐Į’┐Į ’┐Į’┐Į’┐Į’┐Į ─┐’┐Į’┐Į’┐Į ├│’┐Į’┐Į ’┐Į’┐ĮŲŠ 
;  361:  /////////////////////////////////////////////////////////// 
;  362:  void MainControl() 
;  363:  { 
;  364:  	char res = 0; 
;  365:  	 
;  366:  	switch (g_MotionCommand) 
;  367:  	{ 
;  368:  	case COMM_IDLE:		break; 
;  369:  	case COMM_ORIGIN:	res = CommOrigin();	UpdateState(res);	break; 
;  370:  	case COMM_PTP:		res = CommMove();	UpdateState(res);	break; 
;  371:  	case COMM_ORIGIN_A:	res = CommOriginAxis();	UpdateState(res);	break; 
;  372:  	case COMM_ERROR_STOP:	res = CommErrorStop();	UpdateState(res);	break; 
;  373:  	} 
;  374:  	 
;  375:  	if (g_UserStop > 0) 
;  376:  	{ 
;  377:  		--g_UserStop; 
;  378:  	} 
;  379:  	 
;  380:  	if (g_GoToError > 0) 
;  381:  	{ 
;  382:  		if (g_UserStop < 3) 
;  383:  		{ 
;  384:  			g_MotionCommand = COMM_ERROR_STOP; 
;  385:  			g_GoToError = 0; 
;  386:  		} 
;  387:  	} 
;  388:  } 
;  389:   
;  390:  void SystemCheck() 
;  391:  { 
;  392:  	char res = 0; 
;  393:  	char axis = 0; 
;  394:  	char userEmo = 0; 
;  395:  	char is_stopped = 0; 
;  396:  	char use_UserEMO = 0; 
;  397:  	 
;  398:  	if (g_MotionCommand == COMM_IDLE && IsStopped()) 
;  399:  	{ 
;  400:  		is_stopped = 1; 
;  401:  	} 
;  402:  	 
;  403:  	// system out 
;  404:  	SetDO(0, is_stopped == 0); 
;  405:  	SetDO(1, is_stopped); 
;  406:  	SetDO(2, g_OriginCompleted); 
;  407:  	SetDO(3, g_ErrorCode == ERR_OVER_RUN); 
;  408:  	SetDO(4, g_ErrorCode != 0); 
;  409:  	 
;  410:  	 
;  411:  	if (use_UserEMO)	// currently not used (1.00.016) 
;  412:  	{ 
;  413:  		// User Emergency 
;  414:  		userEmo = GetDI(0); 
;  415:  	 
;  416:  		if (userEmo == 0) // reverse, 0=EMO, 1=Normal 
;  417:  		{ 
;  418:  			SetErrorCode(ERR_EMERGENCY); 
;  419:  			GoToError(); 
;  420:  			for (axis = 0; axis < MAX_AXIS; ++axis) 
;  421:  			{ 
;  422:  				MovVar[g_OriginAxis].m_uAcel = EMERGENCY_STOP_DECEL; 
;  423:  				MoveStop(axis); 
;  424:  			} 
;  425:  			g_OriginCompleted = 0; 
;  426:  			return; 
;  427:  		} 
;  428:  	} 
;  429:   
;  430:  	switch (g_MotionCommand) 
;  431:  	{ 
;  432:  	case COMM_IDLE: 
;  433:  		if (IsStopped()) 
;  434:  		{ 
;  435:  			return; 
;  436:  		} 
;  437:  		break; 
;  438:  	case COMM_ORIGIN: 
;  439:  	case COMM_ERROR_STOP: 
;  440:  		return; 
;  441:  	} 
;  442:  	 
;  443:  	// check limit sensor 
;  444:  	 
;  445:  	if (g_MotionCommand == COMM_IDLE) 
;  446:  	{ 
;  447:  		for (axis = 0; axis < MAX_AXIS; ++axis) 
;  448:  		{ 
;  449:  			if (GetMoveStatus(axis) != MOVE_STS_STOP) 
;  450:  			{ 
;  451:  				switch (get_axis_sensor(axis)) 
;  452:  				{ 
;  453:  				case 0: 
;  454:  					break; 
;  455:  					 
;  456:  				case 1:	// POS LIMIT 
;  457:  					if (MovVar[axis].m_ucDir == g_MotionParam[axis].m_ucMoveDir) 
;  458:  					{ 
;  459:  						SetErrorCode(ERR_OVER_RUN); 
