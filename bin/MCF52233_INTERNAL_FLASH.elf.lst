;  460:  			return; 
;  461:  		} 
;  462:  		break; 
;  463:  	case COMM_ORIGIN: 
;  464:  	case COMM_ERROR_STOP: 
;  465:  		return; 
;  466:  	} 
;  467:  	 
;  468:  	// check limit sensor 
;  469:  	 
;  470:  	if (g_MotionCommand == COMM_IDLE) 
;  471:  	{ 
;  472:  		for (axis = 0; axis < MAX_AXIS; ++axis) 
;  473:  		{ 
;  474:  			if (GetMoveStatus(axis) != MOVE_STS_STOP) 
