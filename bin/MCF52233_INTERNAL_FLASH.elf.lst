; 1669:  			MovVar[axis].m_uVmin = g_MotionParam[axis].m_uJogVmin; 
; 1670:  			MovVar[axis].m_uAcel = g_MotionParam[axis].m_uJogAcel; 
; 1671:  			break; 
; 1672:  			 
; 1673:  		case SPEED_NORMAL: 
; 1674:  			MovVar[axis].m_uVmax = g_MotionParam[axis].m_uNorVmax; 
; 1675:  			MovVar[axis].m_uVmin = g_MotionParam[axis].m_uNorVmin; 
; 1676:  			MovVar[axis].m_uAcel = g_MotionParam[axis].m_uNorAcel; 
; 1677:  			break; 
; 1678:   
; 1679:  		case SPEED_SCAN: 
; 1680:  			MovVar[axis].m_uVmax = ((double)scan_rate/100) * g_MotionParam[axis].m_uNorVmax; 
; 1681:  			MovVar[axis].m_uVmin = ((double)scan_rate/100) * g_MotionParam[axis].m_uNorVmin; 
