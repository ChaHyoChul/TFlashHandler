;  332:   
;  333:  void UpdateState(char state) 
;  334:  { 
;  335:  	switch (state) 
;  336:  	{ 
;  337:  	case NORMAL_RUNNING: 
;  338:  		break; 
;  339:  	 
;  340:  	case NORMAL_FINISHED: 
;  341:  		if (g_ResponseSend == 0) 
;  342:  		{ 
;  343:  			SendResponse(); 
;  344:  		} 
;  345:  		else 
;  346:  		{ 
;  347:  			g_ResponseSend = 0; 
;  348:  		} 
;  349:  		GoToIdle(); 
;  350:  		break; 
;  351:  	 
;  352:  	case ERROR_STOPPED: 
;  353:  		SendResponse(); 
;  354:  		GoToIdle(); 
;  355:  		break; 
;  356:  	} 
;  357:  } 
;  358:   
;  359:  /////////////////////////////////////////////////////////// 
;  360:  // 1ms Timer Interrupt ’┐Į’┐Į ’┐Į╠┐’┐Į’┐Į’┐Į ’┐Į’┐Į’┐Į ’┐Į’┐Į’┐Į’┐Į ─┐’┐Į’┐Į’┐Į ├│’┐Į’┐Į ’┐Į’┐ĮŲŠ 
;  361:  /////////////////////////////////////////////////////////// 
;  362:  void MainControl() 
;  363:  { 
;  364:  	char res = 0; 
;  365:   
;  366:  	switch (g_MotionCommand) 
;  367:  	{ 
;  368:  	case COMM_IDLE:		break; 
;  369:  	case COMM_ORIGIN:	res = CommOrigin();	UpdateState(res);	break; 
;  370:  	case COMM_PTP:		res = CommMove();	UpdateState(res);	break; 
;  371:  	case COMM_ORIGIN_A:	res = CommOriginAxis();	UpdateState(res);	break; 
;  372:  	case COMM_ERROR_STOP:	res = CommErrorStop();	UpdateState(res);	break; 
;  373:   
;  374:  	case COMM_HOME:		res = CommHome(); UpdateState(res); break; 
;  375:  	case COMM_MGRI:		res = CommGripUngrip(); UpdateState(res); break; 
;  376:  	case COMM_MUNG:		res = CommGripUngrip(); UpdateState(res); break; 
;  377:  	case COMM_MLOA:		res = CommMoveXY(); UpdateState(res); break; 
;  378:  	case COMM_MASP:		res = CommMoveXY(); UpdateState(res); break; 
;  379:  	case COMM_MDIS:		res = CommMoveXY(); UpdateState(res); break; 
;  380:  	case COMM_MSHA:		res = CommShake(); UpdateState(res); break; 
;  381:  	case COMM_MWAS:		res = CommWaste(); UpdateState(res); break; 
;  382:  	} 
;  383:  	 
;  384:  	if (g_UserStop > 0) 
;  385:  	{ 
;  386:  		--g_UserStop; 
;  387:  	} 
;  388:  	 
;  389:  	if (g_GoToError > 0) 
;  390:  	{ 
;  391:  		if (g_UserStop < 3) 
;  392:  		{ 
;  393:  			g_MotionCommand = COMM_ERROR_STOP; 
;  394:  			g_GoToError = 0; 
;  395:  		} 
;  396:  	} 
;  397:  } 
