;  473:  					StopMotors(); 
;  474:  					break;		 
;  475:  				} 
;  476:  			} 
;  477:  		} 
;  478:  	} 
;  479:  	else 
;  480:  	{ 
;  481:  		for (axis = 0; axis < MAX_AXIS; ++axis) 
