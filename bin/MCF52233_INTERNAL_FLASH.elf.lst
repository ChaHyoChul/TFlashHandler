; 1663:  			MovVar[axis].m_uVmin = g_MotionParam[axis].m_uOrgVmax;	// ņåŹļÅäĻ░Ć ļŖÉļĀżņä£ max Ļ░ÆņØä ņé¼ņÜ®ĒĢ┤ļÅä ļÉ©  
; 1664:  			MovVar[axis].m_uAcel = g_MotionParam[axis].m_uOrgAcel; 
