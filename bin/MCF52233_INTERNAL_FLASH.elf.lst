;  741:  { 
;  742:  	char axis = 0; 
;  743:  	 
;  744:  	for (axis = 0; axis < MAX_AXIS; ++axis) 
;  745:  	{ 
;  746:  		SetHoldTorque(axis); 
;  747:  	} 
