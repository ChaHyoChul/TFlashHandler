;  750:  { 
;  751:  	char axis = 0; 
;  752:  	char moveStatus = 0; 
;  753:  	 
;  754:  	for (axis = 0; axis < MAX_AXIS; ++axis) 
;  755:  	{ 
;  756:  		moveStatus = GetMoveStatus(axis); 
;  757:  		if (moveStatus != MOVE_STS_STOP) 
;  758:  		{ 
;  759:  			return 0; 
;  760:  		} 
;  761:  	} 
;  762:  	 
;  763:  	return 1; 
;  764:  } 
