;  767:  { 
;  768:  	char axis = 0; 
;  769:  	 
;  770:  	for (axis = 0; axis < MAX_AXIS; ++axis) 
;  771:  	{ 
;  772:  		MoveStop(axis); 
;  773:  	} 
;  774:  } 
