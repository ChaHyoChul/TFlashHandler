;  512:   
;  513:  unsigned char GetInput(char ch) 
;  514:  { 
;  515:  	unsigned char res = 0; 
;  516:  	unsigned short val = 0; 
;  517:  	 
;  518:  	if (ch < 0 || ch > 1) 
;  519:  	{ 
;  520:  		return res; 
;  521:  	} 
;  522:  	 
;  523:  	val = ~GetInput16(); 
;  524:  	 
;  525:  	res = (val >> (8*ch)) & 0xFF; 
;  526:  	 
;  527:  	return res; 
;  528:  } 
;  529:   
;  530:  unsigned char GetOutput(char ch) 
;  531:  { 
;  532:  	unsigned char res = 0; 
;  533:  	unsigned short val = 0; 
;  534:  	 
;  535:  	if (ch < 0 || ch > 1) 
;  536:  	{ 
;  537:  		return res; 
;  538:  	} 
;  539:  	 
;  540:  	//val = ~GetOutput12(); 
;  541:  	val = ~GetOutput8(); 
;  542:  	 
;  543:  	res = (val >> (8*ch)) & 0xFF; 
;  544:  	 
;  545:  	return res; 
;  546:  } 
;  547:   
;  548:  void SetOutput(char ch, unsigned char data) 
;  549:  { 
;  550:  	//unsigned short cur = GetOutput12();		// active low 
;  551:  	unsigned short cur = GetOutput8(); 
;  552:  	unsigned short data2 = 0xFF & (~data);	// active high -> active low 
;  553:  	 
;  554:  	if (ch < 0 || ch > 1) 
;  555:  	{ 
;  556:  		return; 
;  557:  	} 
;  558:  	 
;  559:  	cur = cur & (unsigned short)(~(0xFF << (8*ch))); 
;  560:  	data2 = cur | (unsigned short)(data2 << (8*ch)); 
;  561:  	 
;  562:  	// SetOutput12(data2); 
;  563:  	SetOutput8(data2); 
;  564:  } 
;  565:   
;  566:  unsigned char GetInput2(char ch) 
;  567:  { 
;  568:  	unsigned char res = 0; 
;  569:   
;  570:  	if (ch < 1 || ch > MAX_DI) 
;  571:  	{ 
;  572:  		return res; 
;  573:  	} 
;  574:  	 
;  575:  	res = GetInput(ch-1);	// GetInput() : ch = 0-base 
;  576:  	 
;  577:  	return res; 
;  578:  } 
;  579:   
;  580:  unsigned char GetOutput2(char ch) 
;  581:  { 
;  582:  	unsigned char res = 0; 
;  583:   
;  584:  	if (ch < 1 || ch > MAX_DO) 
;  585:  	{ 
;  586:  		return res; 
;  587:  	} 
;  588:  	 
;  589:  	res = GetOutput(ch-1);	// GetOutput() : ch = 0-base 
;  590:   
;  591:  	return res;	 
;  592:  } 
;  593:   
;  594:  void SetOutput2(char ch, unsigned char data) 
;  595:  { 
;  596:  	if (ch < 1 || ch > MAX_DO) 
;  597:  	{ 
;  598:  		return; 
;  599:  	} 
;  600:  	 
;  601:  	SetOutput(ch-1, data); 
;  602:  } 
;  603:   
;  604:  char GetDI(char ch) 
;  605:  { 
;  606:  	char res = 0; 
;  607:   
;  608:  	if (ch >= 0 && ch < MAX_DI) 
;  609:  	{ 
;  610:  		res = (((GetInput16() >> ch) & 1) == SENS_ON); 
;  611:  	} 
;  612:  	 
;  613:  	return res; 
;  614:  } 
;  615:   
;  616:  char GetDO(char ch) 
;  617:  { 
;  618:  	char res = 0; 
;  619:   
;  620:  	if (ch >= 0 && ch < MAX_DO) 
;  621:  	{ 
;  622:  		//res = (((GetOutput12() >> ch) & 1) == SENS_ON); 
;  623:  		res = (((GetOutput8() >> ch) & 1) == SENS_ON); 
;  624:  	} 
;  625:  	 
;  626:  	return res; 
;  627:  } 
;  628:   
;  629:  void SetDO(char ch, char flag) 
;  630:  { 
;  631:  	char res = 0; 
;  632:  	int value = 0; 
;  633:   
;  634:  	if (ch >= 0 && ch < MAX_DO) 
;  635:  	{ 
;  636:  		value = (1 << ch); 
;  637:  		if (flag) 
;  638:  		{ 
;  639:  			//SetOutput12(GetOutput12() & ~value); 
;  640:  			SetOutput8(GetOutput8() & ~value); 
;  641:  		} 
;  642:  		else 
;  643:  		{ 
;  644:  			//SetOutput12(GetOutput12() | value); 
;  645:  			SetOutput8(GetOutput8() | value); 
;  646:  		} 
;  647:  	} 
;  648:  } 
;  649:   
;  650:  unsigned char GetDIBit(char ch, char bit) 
;  651:  { 
;  652:  	unsigned char res = GetInput2(ch); 
;  653:  	 
;  654:  	res = (res >> bit) & 1; 
;  655:  	 
;  656:  	return res; 
;  657:  } 
;  658:   
;  659:  unsigned char GetDOBit(char ch, char bit) 
;  660:  { 
;  661:  	unsigned char res = GetOutput2(ch); 
;  662:  	 
;  663:  	res = (res >> bit) & 1; 
;  664:  	 
;  665:  	return res;	 
;  666:  } 
;  667:   
;  668:  void SetDOBit(char ch, char bit, char flag) 
;  669:  { 
;  670:  	unsigned char res = GetOutput2(ch); 
;  671:  	 
;  672:  	if (flag == 0) 
;  673:  	{ 
;  674:  		res = res & (unsigned char)(~(1 << bit)); 
;  675:  	} 
;  676:  	else 
;  677:  	{ 
;  678:  		res = res | (1 << bit); 
;  679:  	} 
;  680:  	 
;  681:  	SetOutput2(ch, res); 
;  682:  } 
;  683:   
;  684:  void UpdateOriginCompletedStatus() 
;  685:  { 
;  686:  	char axis = 0; 
;  687:  	char flag = 1; 
;  688:   
;  689:  	for (axis = 0; axis < MAX_AXIS; ++axis) 
;  690:  	{ 
;  691:  		if (g_OriginNeed[axis] && g_OriginCompletedAxes[axis] == 0) 
;  692:  		{ 
;  693:  			flag = 0; 
;  694:  			break; 
;  695:  		} 
;  696:  	} 
;  697:  	 
;  698:  	g_OriginCompleted = flag; 
;  699:  } 
;  700:   
;  701:  void SetOriginCompletedFlag(char axis, char flag) 
;  702:  { 
;  703:  	if (axis < 0 || axis >= MAX_AXIS) 
;  704:  	{ 
;  705:  		return; 
;  706:  	} 
;  707:  	 
;  708:  	if (flag < 0 || flag > 1) 
;  709:  	{ 
;  710:  		return; 
;  711:  	} 
;  712:  	 
;  713:  	g_OriginCompletedAxes[axis] = flag; 
;  714:  	 
;  715:  	UpdateOriginCompletedStatus(); 
;  716:  } 
