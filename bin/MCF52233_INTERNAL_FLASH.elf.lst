; 1588:  	{ 
; 1589:  		SetHoldTorque(axis);		// Jog ’┐Įį╝’┐Į’┐Į’┐Į ’┐Į’┐Į’┐Į’┐Į’┐ĮŽ╣ŪĘ’┐Į Holding Current’┐Į’┐Į ’┐Į’┐Į’┐Į’┐Į’┐Į. 
; 1590:  	} 
