; 1728:  			return NORMAL_RUNNING; 
; 1729:  		} 
; 1730:  		else  
; 1731:  		{ 
; 1732:  			step++; 
; 1733:  		} 
; 1734:   
; 1735:  		DelayMoveStart(); 
; 1736:  		break; 
; 1737:   
; 1738:  	case 4: 
; 1739:  		if (HOME_SENSOR(Z_AXIS) == SENS_ON) 
