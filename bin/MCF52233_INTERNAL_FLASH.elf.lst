;  257:   
;  258:  void SendResponseRaw(char* command, int errorCode) 
;  259:  { 
;  260:  	char str[64] = ""; 
;  261:  	 
;  262:  	if (strlen(command) < 2) 
;  263:  	{ 
;  264:  		return; 
;  265:  	} 
;  266:  	 
;  267:  	if (errorCode == 0) 
;  268:  	{ 
;  269:  		if (strstr(command, "ERR") != 0) 
;  270:  		{ 
;  271:  			sprintf(str, "%s 000\r\n", command);	 
;  272:  		} 
;  273:  		else 
;  274:  		{ 
;  275:  			sprintf(str, "%s\r\n", command); 
;  276:  		} 
;  277:  	} 
;  278:  	else if (errorCode < 1000) 
;  279:  	{ 
;  280:  		sprintf(str, "%s %03d\r\n", command, errorCode); 
;  281:  	} 
;  282:  	else 
;  283:  	{ 
;  284:  		sprintf(str, "%s E%02d\r\n", command, errorCode-1000); 
;  285:  	} 
;  286:   
;  287:  	send(str); 
;  288:  } 
;  289:   
;  290:  void SendResponse() 
;  291:  { 
;  292:  	static char str[32] = ""; 
;  293:  	 
;  294:  	if (strlen(g_LastCommand) < 2) 
;  295:  	{ 
;  296:  		return; 
;  297:  	} 
;  298:  	 
;  299:  	if (g_ErrorCode == 0) 
;  300:  	{ 
;  301:  		if (strstr(g_LastCommand, "ERR") != 0) 
;  302:  		{ 
;  303:  			sprintf(str, "%s 000\r\n", g_LastCommand);	 
;  304:  		} 
;  305:  		else 
;  306:  		{ 
;  307:  			sprintf(str, "%s\r\n", g_LastCommand); 
;  308:  		} 
;  309:  	} 
;  310:  	else if (g_ErrorCode < 1000) 
;  311:  	{ 
;  312:  		sprintf(str, "%s %03d\r\n", g_LastCommand, g_ErrorCode); 
;  313:  	} 
;  314:  	else 
;  315:  	{ 
;  316:  		sprintf(str, "%s E%02d\r\n", g_LastCommand, g_ErrorCode-1000); 
;  317:  	} 
;  318:   
;  319:  	send(str); 
;  320:  	 
;  321:  	strcpy(g_LastCommand, ""); 
;  322:  } 
;  323:   
;  324:   
;  325:  void Delay1ms() 
;  326:  { 
;  327:  	DelayMS(1); 
;  328:  } 
;  329:   
;  330:  // 
;  331:  // MUST delay after MoveStart() 
;  332:  // 
;  333:  void DelayMoveStart() 
;  334:  { 
;  335:  	DelayMS(20); 
;  336:  } 
;  337:   
;  338:  void UpdateState(char state) 
;  339:  { 
;  340:  	switch (state) 
;  341:  	{ 
;  342:  	case NORMAL_RUNNING: 
;  343:  		break; 
;  344:  	 
;  345:  	case NORMAL_FINISHED: 
;  346:  		if (g_ResponseSend == 0) 
;  347:  		{ 
;  348:  			SendResponse(); 
;  349:  		} 
;  350:  		else 
;  351:  		{ 
;  352:  			g_ResponseSend = 0; 
;  353:  		} 
;  354:  		GoToIdle(); 
;  355:  		break; 
;  356:  	 
;  357:  	case ERROR_STOPPED: 
;  358:  		SendResponse(); 
;  359:  		GoToIdle(); 
;  360:  		break; 
;  361:  	} 
;  362:  } 
