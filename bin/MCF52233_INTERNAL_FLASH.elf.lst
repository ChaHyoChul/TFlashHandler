;  453:  				case 0: 
;  454:  					break; 
;  455:  					 
;  456:  				case 1:	// POS LIMIT 
;  457:  					if (MovVar[axis].m_ucDir == g_MotionParam[axis].m_ucMoveDir) 
;  458:  					{ 
