; 1788:  		MovVar[org_axis].m_ucDir = g_MotionParam[org_axis].m_ucOrgDir;	 
; 1789:  		MovVar[org_axis].m_uAcel = 0; 
; 1790:   
; 1791:  		if (MoveStart(org_axis)) 
; 1792:  		{ 
; 1793:  			step = 91; 
; 1794:  			SetErrorCode(ERR_MOTOR_ERROR); 
; 1795:  			return NORMAL_RUNNING; 
; 1796:  		} 
; 1797:   
; 1798:  		DelayMoveStart(); 
; 1799:  		step++; 
; 1800:  		break; 
; 1801:   
; 1802:  		// HOME ņä╝ņä£Ļ░Ć Ļ░Éņ¦ĆļÉśļ®┤ ļ®łņČśļŗż  
; 1803:  	case 10: 
; 1804:  		if (HOME_SENSOR(org_axis) == SENS_ON) 
; 1805:  		{ 
; 1806:  			MoveStop(org_axis); 
; 1807:  			step++; 
; 1808:  		} 
; 1809:  		break; 
; 1810:   
; 1811:  	case 11: 
; 1812:  		if (IsStopped())  
; 1813:  		{ 
; 1814:  			step++; 
; 1815:  		} 
; 1816:  		break; 
; 1817:   
; 1818:  	case 12: 
