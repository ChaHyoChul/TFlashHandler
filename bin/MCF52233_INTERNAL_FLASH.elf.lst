;  785:  		StopMotors(); 
;  786:  		++step; 
;  787:  		break; 
;  788:  	 
;  789:  	case 1: 
;  790:  		if (IsStopped()) 
;  791:  		{ 
;  792:  			++step; 
;  793:  		} 
;  794:  		break; 
;  795:  		 
;  796:  	case 2: 
;  797:  		HoldMotors(); 
;  798:  		step = 0; 
;  799:  		return ERROR_STOPPED; 
;  800:  		 
;  801:  	default: 
;  802:  		step = 0; 
;  803:  		return NORMAL_FINISHED; 
;  804:  	} 
;  805:  	 
;  806:  	return NORMAL_RUNNING; 
;  807:  } 
