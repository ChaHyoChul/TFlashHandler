; 1573:  	if (dir == 0)	// inverse 
; 1574:  	{ 
; 1575:  		dir = InverseDir(g_MotionParam[axis].m_ucMoveDir); 
; 1576:  	} 
; 1577:  	else 
; 1578:  	{ 
; 1579:  		dir = g_MotionParam[axis].m_ucMoveDir; 
; 1580:  	} 
; 1581:  	 
; 1582:   
; 1583:  	MovVar[axis].m_uS    = g_MotionParam[axis].m_uOrgSLimit; 
; 1584:  	MovVar[axis].m_ucDir = dir; 
; 1585:  	SetSpeed(axis, SPEED_JOG); 
; 1586:  	MovVar[axis].m_ucMoveTorq = g_MotionParam[axis].m_ucMoveTorque; //(axis == Z_AXIS) ? MOVE_TORQUE : MOVE_TORQUE_3A; 
; 1587:  	 
; 1588:  	if (MoveStart(axis)) 
; 1589:  	{ 
; 1590:  		SetHoldTorque(axis);		// Jog ’┐Įį╝’┐Į’┐Į’┐Į ’┐Į’┐Į’┐Į’┐Į’┐ĮŽ╣ŪĘ’┐Į Holding Current’┐Į’┐Į ’┐Į’┐Į’┐Į’┐Į’┐Į. 
; 1591:  	} 
; 1592:  	 
; 1593:  	DelayMoveStart(); 
; 1594:  } 
