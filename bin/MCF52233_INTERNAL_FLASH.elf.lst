;  375:  // 1ms Timer Interrupt ïŋ―ïŋ― ïŋ―Ėŋïŋ―ïŋ―ïŋ― ïŋ―ïŋ―ïŋ― ïŋ―ïŋ―ïŋ―ïŋ― Äŋïŋ―ïŋ―ïŋ― Ãģïŋ―ïŋ― ïŋ―ïŋ―Æū 
;  376:  /////////////////////////////////////////////////////////// 
;  377:  void MainControl() 
;  378:  { 
;  379:  	char res = 0; 
;  380:   
;  381:  	switch (g_MotionCommand) 
;  382:  	{ 
;  383:  	case COMM_IDLE:		break; 
;  384:  	case COMM_ORIGIN:	res = CommOrigin();	UpdateState(res);	break; 
;  385:  	case COMM_PTP:		res = CommMove();	UpdateState(res);	break; 
;  386:  	case COMM_ORIGIN_A:	res = CommOriginAxis();	UpdateState(res);	break; 
;  387:  	case COMM_ERROR_STOP:	res = CommErrorStop();	UpdateState(res);	break; 
;  388:   
;  389:  	case COMM_HOME:		res = CommHome(); UpdateState(res); break; 
;  390:  	case COMM_MGRI:		res = CommGripUngrip(); UpdateState(res); break; 
;  391:  	case COMM_MUNG:		res = CommGripUngrip(); UpdateState(res); break; 
;  392:  	case COMM_MLOA:		res = CommMoveXY(); UpdateState(res); break; 
;  393:  	case COMM_MASP:		res = CommMoveXY(); UpdateState(res); break; 
;  394:  	case COMM_MDIS:		res = CommMoveXY(); UpdateState(res); break; 
;  395:  	case COMM_MSHA:		res = CommShake(); UpdateState(res); break; 
;  396:  	case COMM_MWAS:		res = CommWaste(); UpdateState(res); break; 
;  397:  	case COMM_MSEP:		res = CommSeparate(); UpdateState(res); break; 
;  398:  	} 
;  399:  	 
;  400:  	if (g_UserStop > 0) 
;  401:  	{ 
;  402:  		--g_UserStop; 
;  403:  	} 
;  404:  	 
;  405:  	if (g_GoToError > 0) 
;  406:  	{ 
;  407:  		if (g_UserStop < 3) 
;  408:  		{ 
;  409:  			g_MotionCommand = COMM_ERROR_STOP; 
;  410:  			g_GoToError = 0; 
;  411:  		} 
;  412:  	} 
;  413:  } 
