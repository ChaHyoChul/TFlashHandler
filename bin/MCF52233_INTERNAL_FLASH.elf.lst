;  370:  	case COMM_ORIGIN_A:	res = CommOriginAxis();	UpdateState(res);	break; 
;  371:  	case COMM_ERROR_STOP:	res = CommErrorStop();	UpdateState(res);	break; 
;  372:  	} 
;  373:  	 
;  374:  	if (g_UserStop > 0) 
