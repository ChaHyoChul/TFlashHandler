; 1655:  } 
; 1656:   
; 1657:  unsigned char GetRawDir(char axis, unsigned char dir) 
; 1658:  { 
; 1659:  	unsigned char retDir = dir; 
; 1660:   
; 1661:  	// change the direction for X-axis 
; 1662:  	if (axis == X_AXIS) 
; 1663:  	{ 
; 1664:  		retDir = 1 - retDir; 
; 1665:  	} 
; 1666:  	 
; 1667:  	return retDir; 
; 1668:  } 
; 1669:   
; 1670:  unsigned char InverseDir(unsigned char dir) 
; 1671:  { 
; 1672:  	return 1 - dir; 
; 1673:  } 
; 1674:   
; 1675:  void SetMoveOffset(char axis, int offset) 
; 1676:  { 
; 1677:  	unsigned char dir = g_MotionParam[axis].m_ucMoveDir; 
