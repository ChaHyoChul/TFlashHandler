; 1622:  		retDir = 1 - retDir; 
; 1623:  	} 
; 1624:  	 
; 1625:  	return retDir; 
; 1626:  } 
; 1627:   
; 1628:  unsigned char InverseDir(unsigned char dir) 
; 1629:  { 
; 1630:  	return 1 - dir; 
; 1631:  } 
