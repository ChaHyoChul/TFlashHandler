;  780:  		++step; 
;  781:  		break; 
;  782:  	 
;  783:  	case 1: 
;  784:  		if (IsStopped()) 
;  785:  		{ 
;  786:  			++step; 
;  787:  		} 
;  788:  		break; 
;  789:  		 
;  790:  	case 2: 
;  791:  		HoldMotors(); 
;  792:  		step = 0; 
;  793:  		return ERROR_STOPPED; 
;  794:  		 
;  795:  	default: 
;  796:  		step = 0; 
;  797:  		return NORMAL_FINISHED; 
;  798:  	} 
;  799:  	 
;  800:  	return NORMAL_RUNNING; 
;  801:  } 
