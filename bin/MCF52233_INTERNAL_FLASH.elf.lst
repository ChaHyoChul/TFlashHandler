; 1784:  				return NORMAL_RUNNING; 
; 1785:  			} 
; 1786:  			DelayMoveStart(); 
; 1787:  			step++; 
; 1788:  		} 
; 1789:  		else  
; 1790:  		{ 
; 1791:  			step = 3; 
; 1792:  		} 
; 1793:  		break; 
; 1794:  		 
; 1795:  	case 1: 
; 1796:  		if (move_done(0x04))  
; 1797:  		{ 
; 1798:  			step++; 
; 1799:  		} 
; 1800:  		break; 
; 1801:   
; 1802:  	case 2: 
; 1803:  		if (IsStopped()) 
; 1804:  		{ 
; 1805:  			step++; 
; 1806:  		} 
; 1807:  		break; 
; 1808:   
