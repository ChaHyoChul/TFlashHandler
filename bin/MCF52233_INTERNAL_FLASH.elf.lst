; 1691:  // Gripper(3) -> Rotation(2) -> Tile(1) ņł£ņä£ļĪ£ Origin ĒĢ£ļŗż  
; 1692:  char CommHome() 
; 1693:  { 
; 1694:  	static int nNegLimitOutPos[MAX_AXIS] = {0, 0, 0}; 
; 1695:  	static int nNegLimitInPos[MAX_AXIS]  = {0, 0, 0}; 
; 1696:  	static int org_axis = 0;	//  ņøÉņĀÉļ│ĄĻĘĆ ĒĢśļŖö ņČĢ ļ▓łĒśĖ Z->Y->X ņł£ņä£  
; 1697:  	static int step = 0; 
; 1698:  	 
; 1699:  	int axis = 0; 
; 1700:  	int temp = 0; 
; 1701:  	char move_status = 0; 
; 1702:  	 
; 1703:  	switch (step) 
; 1704:  	{ 
; 1705:  		// Error Handling  
; 1706:  	case 91: StopMotors(); step++; break; 
; 1707:  	case 92: if (IsStopped()) { step++; } 
; 1708:  	case 93: HoldMotors(); step = 0; return ERROR_STOPPED; 
; 1709:   
; 1710:  		// Start  
; 1711:  	case 0: 
; 1712:  		org_axis = Z_AXIS; 
; 1713:  		for (axis = 0; axis < MAX_AXIS; axis++) 
; 1714:  		{ 
; 1715:  			SetOriginCompletedFlag(axis, 0); 
; 1716:  		} 
; 1717:  		step = 1; 
; 1718:  		break; 
; 1719:   
; 1720:  	case 1: 
; 1721:  		step = 3; 
; 1722:  		break; 
; 1723:   
; 1724:  	case 3: 
; 1725:  		MovVar[org_axis].m_uS 	= g_MotionParam[org_axis].m_uOrgSLimit; 
; 1726:  		MovVar[org_axis].m_ucDir= g_MotionParam[org_axis].m_ucOrgDir; 
; 1727:  		SetSpeed(org_axis, SPEED_ORG); // torque ņäżņĀĢ  
; 1728:   
; 1729:  		if (NEG_LIMIT(org_axis) != SENS_ON && MoveStart(org_axis))  
; 1730:  		{ 
; 1731:  			step = 91; 
; 1732:  			return NORMAL_RUNNING; 
; 1733:  		} 
; 1734:  		else  
; 1735:  		{ 
; 1736:  			step++; 
; 1737:  		} 
; 1738:   
; 1739:  		DelayMoveStart(); 
; 1740:  		break; 
; 1741:   
; 1742:  		// Home ņä╝ņä£Ļ░Ć ON ļÉśļ®┤ ļ®łņČśļŗż  
; 1743:  	case 4: 
; 1744:  		if (HOME_SENSOR(org_axis) == SENS_ON) 
; 1745:  		{ 
; 1746:  			MoveStop(org_axis);  
; 1747:  			step++; 
; 1748:  		}	 
; 1749:  		break; 
; 1750:   
; 1751:  	case 5: 
; 1752:  		if (IsStopped()) { step++; }  
; 1753:  		break; 
; 1754:   
; 1755:  		// ļ░śļīĆ ļ░®Ē¢öņ£╝ļĪ£ ņØ┤ļÅÖ ņŗ£ņ×æ  
; 1756:  	case 6: 
; 1757:  		CounterReset(org_axis); 
; 1758:  		MovVar[org_axis].m_ucDir = (unsigned char)((~g_MotionParam[org_axis].m_ucOrgDir) & 1); 
; 1759:  		MovVar[org_axis].m_uAcel = 0;					 
; 1760:   
; 1761:  		if (MoveStart(org_axis)) 
; 1762:  		{ 
; 1763:  			step = 91; 
; 1764:  			SetErrorCode(ERR_MOTOR_ERROR); 
; 1765:  			return NORMAL_RUNNING; 
; 1766:  		} 
; 1767:   
; 1768:  		DelayMoveStart(); 
; 1769:  		step++; 
; 1770:  		break; 
; 1771:   
; 1772:  		// HOME ņä╝ņä£Ļ░Ć OFF ļÉśļ®┤ ļ®łņČśļŗż  
; 1773:  	case 7:	 
; 1774:  		if (HOME_SENSOR(org_axis) == SENS_OFF) 
; 1775:  		{ 
; 1776:  			MoveStop(org_axis); 
; 1777:  			step++; 
; 1778:  		} 
; 1779:  		break; 
; 1780:   
; 1781:  	case 8: 
; 1782:  		if (IsStopped()) { step++; }  
; 1783:  		break; 
; 1784:   
; 1785:  		// ņä╝ņä£ ļ░®Ē¢źņ£╝ļĪ£ ļŗżņŗ£ ņØ┤ļÅÖ ņŗ£ņ×æ  
; 1786:  	case 9:  
; 1787:  		nNegLimitOutPos[org_axis] = CounterRead(org_axis); 
; 1788:  		MovVar[org_axis].m_ucDir = g_MotionParam[org_axis].m_ucOrgDir;	 
; 1789:  		MovVar[org_axis].m_uAcel = 0; 
; 1790:   
; 1791:  		if (MoveStart(org_axis)) 
; 1792:  		{ 
; 1793:  			step = 91; 
; 1794:  			SetErrorCode(ERR_MOTOR_ERROR); 
; 1795:  			return NORMAL_RUNNING; 
; 1796:  		} 
; 1797:   
; 1798:  		DelayMoveStart(); 
; 1799:  		step++; 
; 1800:  		break; 
; 1801:   
; 1802:  		// HOME ņä╝ņä£Ļ░Ć Ļ░Éņ¦ĆļÉśļ®┤ ļ®łņČśļŗż  
; 1803:  	case 10: 
; 1804:  		if (HOME_SENSOR(org_axis) == SENS_ON) 
; 1805:  		{ 
; 1806:  			MoveStop(org_axis); 
; 1807:  			step++; 
; 1808:  		} 
; 1809:  		break; 
; 1810:   
; 1811:  	case 11: 
; 1812:  		if (IsStopped())  
; 1813:  		{ 
; 1814:  			step++; 
; 1815:  		} 
; 1816:  		break; 
; 1817:   
; 1818:  	case 12: 
; 1819:  		nNegLimitInPos[org_axis] = CounterRead(org_axis); 
; 1820:  		temp = ((nNegLimitInPos[org_axis] + nNegLimitOutPos[org_axis])/2) - nNegLimitInPos[org_axis];  
; 1821:  		if (temp < 0) 
; 1822:  		{ 
; 1823:  			temp = -temp; 
; 1824:  		} 
; 1825:  		MovVar[org_axis].m_uS = temp; 
; 1826:  		MovVar[org_axis].m_ucDir = (unsigned char)((~g_MotionParam[org_axis].m_ucOrgDir) & 1); 
; 1827:   
; 1828:  		SetSpeed(org_axis, SPEED_ORG); 
; 1829:   
; 1830:  		if (MoveStart(org_axis)) 
; 1831:  		{ 
; 1832:  			step = 91; 
; 1833:  			SetErrorCode(ERR_MOTOR_ERROR); 
; 1834:  			return NORMAL_RUNNING; 
; 1835:  		} 
; 1836:   
; 1837:  		DelayMoveStart(); 
; 1838:  		step++; 
; 1839:  		break; 
; 1840:   
; 1841:  	case 13: 
; 1842:  		move_status = GetMoveStatus(org_axis); 
; 1843:  		switch (move_status) 
; 1844:  		{ 
; 1845:  		case MOVE_STS_INPOS: 
; 1846:  			MoveStop(org_axis); 
; 1847:  			step++; 
; 1848:  			break; 
; 1849:  		case MOVE_STS_STOP: 
; 1850:  			step++; 
; 1851:  			break; 
; 1852:  		} 
; 1853:  		break; 
; 1854:   
; 1855:  	case 14: 
; 1856:  		if (IsStopped()) { step++; } 
; 1857:  		break; 
; 1858:   
; 1859:  	case 15: 
; 1860:  		CounterReset(org_axis); 
; 1861:  		SetSpeed(org_axis, SPEED_NORMAL); 
; 1862:  		SetOriginCompletedFlag(org_axis, 1); 
; 1863:  		step++; 
; 1864:  		break; 
; 1865:   
; 1866:  	case 16: 
; 1867:  		if (--org_axis >= X_AXIS) { step = 1; } 
; 1868:  		else { step++; } 
; 1869:  		break; 
; 1870:   
; 1871:  	case 17: 
; 1872:  		step = 0; 
; 1873:  		return NORMAL_FINISHED; 
; 1874:   
; 1875:  	default: 
; 1876:  		step = 0; 
; 1877:  		return NORMAL_FINISHED; 
; 1878:  	} 
; 1879:   
; 1880:  	CHECK_USER_STOP(); 
; 1881:   
; 1882:  	return NORMAL_RUNNING; 
; 1883:  } 
; 1884:   
; 1885:  // g_MoveOffset[] ļ│ĆņłśņŚÉ ņ£äņ╣śļź╝ ņĀĆņ×źĒĢ┤ ļåōĻ│Ā, ĻĘĖ ņ£äņ╣śļĪ£ ņØ┤ļÅÖĒĢ£ļŗż  
; 1886:  char CommGripUngrip() 
; 1887:  { 
; 1888:  	static char step = 0; 
; 1889:  	int  axis = 0; 
; 1890:  	char flag = 1; 
; 1891:  	char move_start = 0; 
; 1892:  	char move_status = 0; 
; 1893:  	 
; 1894:  	switch (step) 
; 1895:  	{ 
; 1896:  		// Error handling  
; 1897:  	case 91: StopMotors(); step++; break; 
; 1898:  	case 92: if (IsStopped()) { step++; } break; 
; 1899:  	case 93: HoldMotors(); step = 0; return ERROR_STOPPED; 
; 1900:   
; 1901:  		// Start 
; 1902:  		// move_offset Ļ░ÆņØ┤ 0ņØ┤ļ®┤ MoveStart() ĒĢ©ņłśņŚÉņä£ 3ļ▓ł ņŚÉļ¤¼ ļ░£ņāØ   
; 1903:  		// offset = target_pos - current_pos  
; 1904:  		// point data 2ļ▓ł. ZņČĢ ņ£äņ╣ś ņé¼ņÜ®  
; 1905:  	case 0: 
; 1906:  		if (g_MovePointDataNo != 0) 
; 1907:  		{ 
; 1908:  			move_start = move_pd(g_MovePointDataNo, 0x04); 
; 1909:  			if (move_start)  
; 1910:  			{ 
; 1911:  				SetErrorCode(ERR_MOTOR_ERROR); 
; 1912:  				step = 91; 
; 1913:  				return NORMAL_RUNNING; 
; 1914:  			} 
; 1915:  			DelayMoveStart(); 
; 1916:  			step++; 
; 1917:  		} 
; 1918:  		else  
; 1919:  		{ 
; 1920:  			step = 3; 
; 1921:  		} 
; 1922:  		break; 
; 1923:  		 
; 1924:  	case 1: 
; 1925:  		if (move_done(0x04))  
; 1926:  		{ 
; 1927:  			step++; 
; 1928:  		} 
; 1929:  		break; 
; 1930:   
; 1931:  	case 2: 
; 1932:  		if (IsStopped()) 
; 1933:  		{ 
; 1934:  			step++; 
; 1935:  		} 
; 1936:  		break; 
; 1937:   
; 1938:  	case 3: 
; 1939:  		SetHoldTorque(Z_AXIS); 
; 1940:  		g_MovePointDataNo = 0; 
; 1941:  		g_MoveOffset[Z_AXIS] = 0; 
; 1942:  		step = 0; 
; 1943:  		return NORMAL_FINISHED; 
; 1944:   
; 1945:  	default: 
; 1946:  		step = 0; 
; 1947:  		return NORMAL_FINISHED; 
; 1948:  	} 
; 1949:   
; 1950:  	CHECK_USER_STOP(); 
; 1951:   
; 1952:  	return 0; 
; 1953:  } 
; 1954:   
; 1955:  //  
; 1956:  char CommMoveXY() 
; 1957:  { 
; 1958:  	static char step = 0; 
; 1959:  	int  axis = 0; 
; 1960:  	char flag = 1; 
; 1961:  	char move_start = 0; 
; 1962:  	char move_status = 0; 
; 1963:  	POINT_DATA pd; 
; 1964:   
; 1965:  	switch (step) 
; 1966:  	{ 
; 1967:  		// Error handling  
; 1968:  	case 91: StopMotors(); step++; break; 
; 1969:  	case 92: if (IsStopped()) { step++; } break; 
; 1970:  	case 93: HoldMotors(); step = 0; return ERROR_STOPPED;  
; 1971:   
; 1972:  	case 0: 
; 1973:  		if (g_MovePointDataNo != 0) 
; 1974:  		{ 
; 1975:  			move_start = move_pd(g_MovePointDataNo, 0x03); 
; 1976:  			if (move_start) 
; 1977:  			{ 
; 1978:  				SetErrorCode(ERR_MOTOR_ERROR); 
; 1979:  				step = 91; 
; 1980:  				return NORMAL_RUNNING; 
; 1981:  			} 
; 1982:  			DelayMoveStart(); 
; 1983:  			step++; 
; 1984:  		} 
; 1985:  		else  
; 1986:  		{ 
; 1987:  			step = 3; 
; 1988:  		} 
; 1989:  		break; 
; 1990:   
; 1991:  	case 1: 
; 1992:  		if (move_done(0x03)) { step++; }  
; 1993:  		break; 
; 1994:   
; 1995:  	case 2: 
; 1996:  		if (IsStopped()) { step++; } 
; 1997:  		break; 
; 1998:   
; 1999:  	case 3: 
; 2000:  		for (axis = 0; axis < 2; axis++) 
; 2001:  		{ 
; 2002:  			SetHoldTorque(axis); 
; 2003:  			g_MovePointDataNo = 0; 
; 2004:  			g_MoveOffset[axis] = 0; 
; 2005:  		} 
; 2006:  		step = 0; 
; 2007:  		return NORMAL_FINISHED; 
; 2008:   
; 2009:  	default: 
; 2010:  		step = 0; 
; 2011:  		return NORMAL_FINISHED; 
; 2012:  	} 
; 2013:   
; 2014:  	CHECK_USER_STOP(); 
; 2015:   
; 2016:  	return 0; 
; 2017:  } 
