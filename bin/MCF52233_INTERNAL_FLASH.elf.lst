;  470:  					} 
;  471:  					break; 
;  472:  					 
;  473:  				case 2: // NEG LIMIT 
;  474:  					if (MovVar[axis].m_ucDir != g_MotionParam[axis].m_ucMoveDir) 
;  475:  					{ 
