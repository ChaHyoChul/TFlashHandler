;  739:  { 
;  740:  	char axis = 0; 
;  741:  	char moveStatus = 0; 
;  742:  	 
;  743:  	for (axis = 0; axis < MAX_AXIS; ++axis) 
;  744:  	{ 
;  745:  		moveStatus = GetMoveStatus(axis); 
;  746:  		if (moveStatus != MOVE_STS_STOP) 
;  747:  		{ 
;  748:  			return 0; 
;  749:  		} 
;  750:  	} 
;  751:  	 
;  752:  	return 1; 
