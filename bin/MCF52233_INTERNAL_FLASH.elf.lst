;  252:  void SendResponseRaw(char* command, int errorCode) 
;  253:  { 
;  254:  	char str[64] = ""; 
;  255:  	 
;  256:  	if (strlen(command) < 2) 
;  257:  	{ 
;  258:  		return; 
;  259:  	} 
;  260:  	 
;  261:  	if (errorCode == 0) 
;  262:  	{ 
;  263:  		if (strstr(command, "ERR") != 0) 
;  264:  		{ 
;  265:  			snprintf(str, 63, "%s 000\r\n", command);	 
;  266:  		} 
;  267:  		else 
;  268:  		{ 
;  269:  			snprintf(str, 63, "%s\r\n", command); 
;  270:  		} 
;  271:  	} 
;  272:  	else if (errorCode < 1000) 
;  273:  	{ 
;  274:  		snprintf(str, 63, "%s %03d\r\n", command, errorCode); 
;  275:  	} 
;  276:  	else 
;  277:  	{ 
;  278:  		snprintf(str, 63, "%s E%02d\r\n", command, errorCode-1000); 
;  279:  	} 
;  280:   
;  281:  	send(str); 
;  282:  } 
