;  462:  					break; 
;  463:  					 
;  464:  				case 2: // NEG LIMIT 
;  465:  					if (MovVar[axis].m_ucDir != g_MotionParam[axis].m_ucMoveDir) 
;  466:  					{ 
;  467:  						SetErrorCode(ERR_OVER_RUN); 
