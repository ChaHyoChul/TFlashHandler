; 1623:  	 
; 1624:  	return retDir; 
; 1625:  } 
; 1626:   
; 1627:  unsigned char InverseDir(unsigned char dir) 
; 1628:  { 
; 1629:  	return 1 - dir; 
; 1630:  } 
