;  522:   
;  523:  unsigned char GetInput(char ch) 
;  524:  { 
;  525:  	unsigned char res = 0; 
;  526:  	unsigned short val = 0; 
;  527:  	 
;  528:  	if (ch < 0 || ch > 1) 
;  529:  	{ 
;  530:  		return res; 
;  531:  	} 
;  532:  	 
;  533:  	val = ~GetInput16(); 
;  534:  	 
;  535:  	res = (val >> (8*ch)) & 0xFF; 
;  536:  	 
;  537:  	return res; 
;  538:  } 
;  539:   
;  540:  unsigned char GetOutput(char ch) 
;  541:  { 
;  542:  	unsigned char res = 0; 
;  543:  	unsigned short val = 0; 
;  544:  	 
;  545:  	if (ch < 0 || ch > 1) 
;  546:  	{ 
;  547:  		return res; 
;  548:  	} 
;  549:  	 
;  550:  	//val = ~GetOutput12(); 
;  551:  	val = ~GetOutput8(); 
;  552:  	 
;  553:  	res = (val >> (8*ch)) & 0xFF; 
;  554:  	 
;  555:  	return res; 
;  556:  } 
;  557:   
;  558:  void SetOutput(char ch, unsigned char data) 
;  559:  { 
;  560:  	//unsigned short cur = GetOutput12();		// active low 
;  561:  	unsigned short cur = GetOutput8(); 
;  562:  	unsigned short data2 = 0xFF & (~data);	// active high -> active low 
;  563:  	 
;  564:  	if (ch < 0 || ch > 1) 
;  565:  	{ 
;  566:  		return; 
;  567:  	} 
;  568:  	 
;  569:  	cur = cur & (unsigned short)(~(0xFF << (8*ch))); 
;  570:  	data2 = cur | (unsigned short)(data2 << (8*ch)); 
;  571:  	 
;  572:  	// SetOutput12(data2); 
;  573:  	SetOutput8(data2); 
;  574:  } 
;  575:   
;  576:  unsigned char GetInput2(char ch) 
;  577:  { 
;  578:  	unsigned char res = 0; 
;  579:   
;  580:  	if (ch < 1 || ch > MAX_DI) 
;  581:  	{ 
;  582:  		return res; 
;  583:  	} 
;  584:  	 
;  585:  	res = GetInput(ch-1);	// GetInput() : ch = 0-base 
;  586:  	 
;  587:  	return res; 
;  588:  } 
;  589:   
;  590:  unsigned char GetOutput2(char ch) 
;  591:  { 
;  592:  	unsigned char res = 0; 
;  593:   
;  594:  	if (ch < 1 || ch > MAX_DO) 
;  595:  	{ 
;  596:  		return res; 
;  597:  	} 
;  598:  	 
;  599:  	res = GetOutput(ch-1);	// GetOutput() : ch = 0-base 
;  600:   
;  601:  	return res;	 
;  602:  } 
;  603:   
;  604:  void SetOutput2(char ch, unsigned char data) 
;  605:  { 
;  606:  	if (ch < 1 || ch > MAX_DO) 
;  607:  	{ 
;  608:  		return; 
;  609:  	} 
;  610:  	 
;  611:  	SetOutput(ch-1, data); 
;  612:  } 
;  613:   
