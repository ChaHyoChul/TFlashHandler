; 2113:  	switch (step) 
; 2114:  	{ 
; 2115:  		// Error handling  
; 2116:  	case 91: StopMotors(); step++; break; 
; 2117:  	case 92: if (IsStopped()) { step++; } break; 
; 2118:  	case 93: HoldMotors(); step = 0; return ERROR_STOPPED;  
; 2119:   
; 2120:  		// 
