; 1829:  		nNegLimitOutPos[g_OriginAxis] = CounterRead(g_OriginAxis); 
; 1830:  		MovVar[g_OriginAxis].m_ucDir = g_MotionParam[g_OriginAxis].m_ucOrgDir;	 
