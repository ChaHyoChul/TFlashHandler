; 1583:  	MovVar[axis].m_ucDir = dir; 
; 1584:  	SetSpeed(axis, SPEED_JOG); 
; 1585:  	MovVar[axis].m_ucMoveTorq = g_MotionParam[axis].m_ucMoveTorque; //(axis == Z_AXIS) ? MOVE_TORQUE : MOVE_TORQUE_3A; 
; 1586:  	 
