; 1756:  // g_MoveOffset[] ļ│ĆņłśņŚÉ ņ£äņ╣śļź╝ ņĀĆņ×źĒĢ┤ ļåōĻ│Ā, ĻĘĖ ņ£äņ╣śļĪ£ ņØ┤ļÅÖĒĢ£ļŗż  
; 1757:  char CommGripUngrip() 
; 1758:  { 
