; 1690:  ///////////////////////////////////////////////////////////// 
; 1691:  // Gripper(3) -> Rotation(2) -> Tile(1) ņł£ņä£ļĪ£ Origin ĒĢ£ļŗż  
; 1692:  char CommHome() 
; 1693:  { 
; 1694:  	static int nNegLimitOutPos[MAX_AXIS] = {0, 0, 0}; 
; 1695:  	static int nNegLimitInPos[MAX_AXIS]  = {0, 0, 0}; 
; 1696:  	static int org_axis = 0;	//  ņøÉņĀÉļ│ĄĻĘĆ ĒĢśļŖö ņČĢ ļ▓łĒśĖ Z->Y->X ņł£ņä£  
; 1697:  	static int step = 0; 
; 1698:  	 
; 1699:  	int axis = 0; 
; 1700:  	int temp = 0; 
; 1701:  	char move_status = 0; 
; 1702:  	 
; 1703:  	switch (step) 
; 1704:  	{ 
; 1705:  		// Error Handling  
; 1706:  	case 91: StopMotors(); step++; break; 
; 1707:  	case 92: if (IsStopped()) { step++; } 
; 1708:  	case 93: HoldMotors(); step = 0; return ERROR_STOPPED; 
; 1709:   
; 1710:  		// Start  
; 1711:  	case 0: 
; 1712:  		org_axis = Z_AXIS; 
; 1713:  		for (axis = 0; axis < MAX_AXIS; axis++) 
; 1714:  		{ 
; 1715:  			SetOriginCompletedFlag(axis, 0); 
; 1716:  		} 
; 1717:  		step = 1; 
; 1718:  		break; 
; 1719:   
; 1720:  	case 1: 
; 1721:  		step = 3; 
; 1722:  		break; 
; 1723:   
; 1724:  	case 3: 
