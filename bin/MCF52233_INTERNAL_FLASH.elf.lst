; 1369:  	case 11: 
; 1370:  		if (IsStopped()) 
; 1371:  		{ 
; 1372:  			++step; 
; 1373:  			debugf("step=%d", step); 
; 1374:  		} 
; 1375:  		break; 
; 1376:  		 
; 1377:  	case 12: 
; 1378:  		CounterReset(g_OriginAxis);	// ’┐Į’┐Į’┐Į’┐Į’┐Į’┐Į’┐Į’┐Į ’┐Į’┐Į’┐Į’┐Į’┐Įč┤’┐Į. 
; 1379:  		SetSpeed(g_OriginAxis, SPEED_NORMAL); 
; 1380:  		 
; 1381:  		++step; 
; 1382:  		 
; 1383:  	case 13: 
; 1384:  		//CALL_FUNCTION(CommRST, 91); 
; 1385:  		++step; 
; 1386:  		break; 
; 1387:  		 
; 1388:  	case 14: 
; 1389:  		step = 0; 
; 1390:   
; 1391:  		SetOriginCompletedFlag(g_OriginAxis, 1); 
; 1392:   
; 1393:  		return NORMAL_FINISHED;	// ’┐Į’┐Į’┐Į’┐Į : Move Origin ’┐Į’┐Į’┐Į’┐Į ’┐ĮŽĘ’┐Į 
; 1394:   
; 1395:  	default: 
; 1396:  		return NORMAL_FINISHED; 
; 1397:   
; 1398:  	} 
; 1399:  	 
; 1400:  	CHECK_USER_STOP(); 
; 1401:  	 
; 1402:  	return NORMAL_RUNNING; 
; 1403:  } 
