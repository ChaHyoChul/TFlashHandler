;  752:  { 
;  753:  	char axis = 0; 
;  754:  	 
;  755:  	for (axis = 0; axis < MAX_AXIS; ++axis) 
;  756:  	{ 
;  757:  		MoveStop(axis); 
;  758:  	} 
;  759:  } 
