;  620:  		res = (((GetInput16() >> ch) & 1) == SENS_ON); 
;  621:  	} 
;  622:  	 
;  623:  	return res; 
;  624:  } 
;  625:   
;  626:  char GetDO(char ch) 
;  627:  { 
;  628:  	char res = 0; 
;  629:   
;  630:  	if (ch >= 0 && ch < MAX_DO) 
;  631:  	{ 
;  632:  		//res = (((GetOutput12() >> ch) & 1) == SENS_ON); 
;  633:  		res = (((GetOutput8() >> ch) & 1) == SENS_ON); 
;  634:  	} 
;  635:  	 
;  636:  	return res; 
;  637:  } 
;  638:   
;  639:  void SetDO(char ch, char flag) 
;  640:  { 
;  641:  	char res = 0; 
;  642:  	int value = 0; 
;  643:   
;  644:  	if (ch >= 0 && ch < MAX_DO) 
;  645:  	{ 
;  646:  		value = (1 << ch); 
;  647:  		if (flag) 
;  648:  		{ 
;  649:  			//SetOutput12(GetOutput12() & ~value); 
;  650:  			SetOutput8(GetOutput8() & ~value); 
;  651:  		} 
;  652:  		else 
;  653:  		{ 
;  654:  			//SetOutput12(GetOutput12() | value); 
;  655:  			SetOutput8(GetOutput8() | value); 
;  656:  		} 
;  657:  	} 
;  658:  } 
