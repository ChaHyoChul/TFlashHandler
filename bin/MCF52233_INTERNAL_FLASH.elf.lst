; 1756:  char CommGripUngrip() 
; 1757:  { 
; 1758:  	static char step = 0; 
; 1759:  	int  axis = 0; 
; 1760:  	char flag = 1; 
; 1761:  	char move_start = 0; 
; 1762:  	char move_status = 0; 
; 1763:  	 
; 1764:  	switch (step) 
; 1765:  	{ 
; 1766:  		// Error handling  
; 1767:  	case 91: StopMotors(); step++; break; 
; 1768:  	case 92: if (IsStopped()) { step++; } break; 
; 1769:  	case 93: HoldMotors(); step = 0; return ERROR_STOPPED; 
; 1770:   
; 1771:  		// Start 
; 1772:  		// move_offset Ļ░ÆņØ┤ 0ņØ┤ļ®┤ MoveStart() ĒĢ©ņłśņŚÉņä£ 3ļ▓ł ņŚÉļ¤¼ ļ░£ņāØ   
; 1773:  		// offset = target_pos - current_pos  
; 1774:  		// point data 2ļ▓ł. ZņČĢ ņ£äņ╣ś ņé¼ņÜ®  
; 1775:  	case 0: 
; 1776:  		if (g_MovePointDataNo != 0) 
; 1777:  		{ 
; 1778:  			move_start = move_pd(g_MovePointDataNo, 0x04); 
; 1779:  			if (move_start)  
; 1780:  			{ 
; 1781:  				SetErrorCode(ERR_MOTOR_ERROR); 
; 1782:  				step = 91; 
; 1783:  				return NORMAL_RUNNING; 
; 1784:  			} 
; 1785:  			DelayMoveStart(); 
; 1786:  			step++; 
; 1787:  		} 
; 1788:  		else  
; 1789:  		{ 
; 1790:  			step = 3; 
; 1791:  		} 
; 1792:  		break; 
; 1793:  		 
; 1794:  	case 1: 
; 1795:  		if (move_done(0x04))  
; 1796:  		{ 
; 1797:  			step++; 
; 1798:  		} 
; 1799:  		break; 
; 1800:   
; 1801:  	case 2: 
; 1802:  		if (IsStopped()) 
; 1803:  		{ 
; 1804:  			step++; 
; 1805:  		} 
; 1806:  		break; 
; 1807:   
; 1808:  	case 3: 
; 1809:  		SetHoldTorque(Z_AXIS); 
; 1810:  		g_MovePointDataNo = 0; 
; 1811:  		g_MoveOffset[Z_AXIS] = 0; 
; 1812:  		step = 0; 
; 1813:  		return NORMAL_FINISHED; 
; 1814:   
; 1815:  	default: 
; 1816:  		step = 0; 
; 1817:  		return NORMAL_FINISHED; 
; 1818:  	} 
; 1819:   
; 1820:  	CHECK_USER_STOP(); 
; 1821:   
; 1822:  	return 0; 
; 1823:  } 
