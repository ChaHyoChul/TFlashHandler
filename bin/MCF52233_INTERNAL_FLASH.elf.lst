;  359:  // 1ms Timer Interrupt ’┐Į’┐Į ’┐Į╠┐’┐Į’┐Į’┐Į ’┐Į’┐Į’┐Į ’┐Į’┐Į’┐Į’┐Į ─┐’┐Į’┐Į’┐Į ├│’┐Į’┐Į ’┐Į’┐ĮŲŠ 
;  360:  /////////////////////////////////////////////////////////// 
;  361:  void MainControl() 
;  362:  { 
;  363:  	char res = 0; 
;  364:  	 
;  365:  	switch (g_MotionCommand) 
;  366:  	{ 
;  367:  	case COMM_IDLE:		break; 
;  368:  	case COMM_ORIGIN:	res = CommOrigin();	UpdateState(res);	break; 
;  369:  	case COMM_PTP:		res = CommMove();	UpdateState(res);	break; 
;  370:  	case COMM_ORIGIN_A:	res = CommOriginAxis();	UpdateState(res);	break; 
;  371:  	case COMM_ERROR_STOP:	res = CommErrorStop();	UpdateState(res);	break; 
;  372:  	} 
;  373:  	 
;  374:  	if (g_UserStop > 0) 
;  375:  	{ 
;  376:  		--g_UserStop; 
;  377:  	} 
;  378:  	 
;  379:  	if (g_GoToError > 0) 
;  380:  	{ 
;  381:  		if (g_UserStop < 3) 
;  382:  		{ 
;  383:  			g_MotionCommand = COMM_ERROR_STOP; 
;  384:  			g_GoToError = 0; 
;  385:  		} 
;  386:  	} 
;  387:  } 
