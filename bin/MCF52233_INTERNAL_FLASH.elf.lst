;  483:  					StopMotors(); 
;  484:  					break;		 
;  485:  				} 
;  486:  			} 
;  487:  		} 
;  488:  	} 
;  489:  	else 
;  490:  	{ 
;  491:  		for (axis = 0; axis < MAX_AXIS; ++axis) 
