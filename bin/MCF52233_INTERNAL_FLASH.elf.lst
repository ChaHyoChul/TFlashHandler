; 1573:  	if (dir == 0)	// inverse 
; 1574:  	{ 
; 1575:  		dir = InverseDir(g_MotionParam[axis].m_ucMoveDir); 
; 1576:  	} 
; 1577:  	else 
; 1578:  	{ 
; 1579:  		dir = g_MotionParam[axis].m_ucMoveDir; 
