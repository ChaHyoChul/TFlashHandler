; 1644:   
; 1645:  void MotionStop() 
; 1646:  { 
; 1647:  	char axis = 0; 
; 1648:  	 
; 1649:  	for (axis = 0; axis < MAX_AXIS; ++axis) 
; 1650:  	{ 
; 1651:  		MoveStop(axis); 
; 1652:  		SetHoldTorque(axis); 
