; 1430:   
; 1431:  		SetOriginCompletedFlag(g_OriginAxis, 1); 
; 1432:   
; 1433:  		return NORMAL_FINISHED;	// ïŋ―ïŋ―ïŋ―ïŋ― : Move Origin ïŋ―ïŋ―ïŋ―ïŋ― ïŋ―Ï·ïŋ― 
