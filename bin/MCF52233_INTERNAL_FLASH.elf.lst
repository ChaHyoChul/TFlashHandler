; 1649:   
; 1650:  	if (scan_rate < 1 || scan_rate > 100) 
; 1651:  	{ 
; 1652:  		scan_rate = 100; 
; 1653:  	} 
; 1654:  	 
; 1655:  	if (axis < 0 || axis >= MAX_AXIS) 
; 1656:  	{ 
; 1657:  		return; 
; 1658:  	} 
; 1659:  	 
; 1660:  	switch (type) 
