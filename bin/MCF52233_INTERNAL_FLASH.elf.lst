; 1873:  		return NORMAL_FINISHED; 
; 1874:   
; 1875:  	default: 
; 1876:  		step = 0; 
; 1877:  		return NORMAL_FINISHED; 
; 1878:  	} 
; 1879:   
; 1880:  	CHECK_USER_STOP(); 
; 1881:   
; 1882:  	return NORMAL_RUNNING; 
; 1883:  } 
