;  331:   
;  332:  void UpdateState(char state) 
;  333:  { 
;  334:  	switch (state) 
;  335:  	{ 
;  336:  	case NORMAL_RUNNING: 
;  337:  		break; 
;  338:  	 
;  339:  	case NORMAL_FINISHED: 
;  340:  		if (g_ResponseSend == 0) 
;  341:  		{ 
;  342:  			SendResponse(); 
;  343:  		} 
;  344:  		else 
;  345:  		{ 
;  346:  			g_ResponseSend = 0; 
;  347:  		} 
;  348:  		GoToIdle(); 
;  349:  		break; 
;  350:  	 
;  351:  	case ERROR_STOPPED: 
;  352:  		SendResponse(); 
;  353:  		GoToIdle(); 
;  354:  		break; 
;  355:  	} 
;  356:  } 
;  357:   
;  358:  /////////////////////////////////////////////////////////// 
;  359:  // 1ms Timer Interrupt ’┐Į’┐Į ’┐Į╠┐’┐Į’┐Į’┐Į ’┐Į’┐Į’┐Į ’┐Į’┐Į’┐Į’┐Į ─┐’┐Į’┐Į’┐Į ├│’┐Į’┐Į ’┐Į’┐ĮŲŠ 
;  360:  /////////////////////////////////////////////////////////// 
;  361:  void MainControl() 
;  362:  { 
;  363:  	char res = 0; 
;  364:  	 
;  365:  	switch (g_MotionCommand) 
;  366:  	{ 
;  367:  	case COMM_IDLE:		break; 
;  368:  	case COMM_ORIGIN:	res = CommOrigin();	UpdateState(res);	break; 
;  369:  	case COMM_PTP:		res = CommMove();	UpdateState(res);	break; 
;  370:  	case COMM_ORIGIN_A:	res = CommOriginAxis();	UpdateState(res);	break; 
;  371:  	case COMM_ERROR_STOP:	res = CommErrorStop();	UpdateState(res);	break; 
;  372:  	} 
;  373:  	 
;  374:  	if (g_UserStop > 0) 
;  375:  	{ 
;  376:  		--g_UserStop; 
;  377:  	} 
;  378:  	 
;  379:  	if (g_GoToError > 0) 
;  380:  	{ 
;  381:  		if (g_UserStop < 3) 
;  382:  		{ 
;  383:  			g_MotionCommand = COMM_ERROR_STOP; 
;  384:  			g_GoToError = 0; 
;  385:  		} 
;  386:  	} 
;  387:  } 
;  388:   
;  389:  void SystemCheck() 
;  390:  { 
;  391:  	char res = 0; 
;  392:  	char axis = 0; 
;  393:  	char userEmo = 0; 
;  394:  	char is_stopped = 0; 
;  395:  	char use_UserEMO = 0; 
;  396:  	 
;  397:  	if (g_MotionCommand == COMM_IDLE && IsStopped()) 
;  398:  	{ 
;  399:  		is_stopped = 1; 
;  400:  	} 
;  401:  	 
;  402:  	// system out 
;  403:  	SetDO(0, is_stopped == 0); 
;  404:  	SetDO(1, is_stopped); 
;  405:  	SetDO(2, g_OriginCompleted); 
;  406:  	SetDO(3, g_ErrorCode == ERR_OVER_RUN); 
;  407:  	SetDO(4, g_ErrorCode != 0); 
;  408:  	 
;  409:  	 
;  410:  	if (use_UserEMO)	// currently not used (1.00.016) 
;  411:  	{ 
;  412:  		// User Emergency 
;  413:  		userEmo = GetDI(0); 
;  414:  	 
;  415:  		if (userEmo == 0) // reverse, 0=EMO, 1=Normal 
;  416:  		{ 
;  417:  			SetErrorCode(ERR_EMERGENCY); 
;  418:  			GoToError(); 
;  419:  			for (axis = 0; axis < MAX_AXIS; ++axis) 
;  420:  			{ 
;  421:  				MovVar[g_OriginAxis].m_uAcel = EMERGENCY_STOP_DECEL; 
;  422:  				MoveStop(axis); 
;  423:  			} 
;  424:  			g_OriginCompleted = 0; 
;  425:  			return; 
;  426:  		} 
;  427:  	} 
;  428:   
;  429:  	switch (g_MotionCommand) 
;  430:  	{ 
;  431:  	case COMM_IDLE: 
;  432:  		if (IsStopped()) 
;  433:  		{ 
;  434:  			return; 
;  435:  		} 
;  436:  		break; 
;  437:  	case COMM_ORIGIN: 
;  438:  	case COMM_ERROR_STOP: 
;  439:  		return; 
;  440:  	} 
;  441:  	 
;  442:  	// check limit sensor 
;  443:  	 
;  444:  	if (g_MotionCommand == COMM_IDLE) 
;  445:  	{ 
;  446:  		for (axis = 0; axis < MAX_AXIS; ++axis) 
;  447:  		{ 
;  448:  			if (GetMoveStatus(axis) != MOVE_STS_STOP) 
;  449:  			{ 
;  450:  				switch (get_axis_sensor(axis)) 
