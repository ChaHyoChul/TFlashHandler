; 1609:  unsigned char GetRawDir(char axis, unsigned char dir) 
; 1610:  { 
; 1611:  	unsigned char retDir = dir; 
; 1612:   
; 1613:  	// change the direction for X-axis 
; 1614:  	if (axis == X_AXIS) 
; 1615:  	{ 
; 1616:  		retDir = 1 - retDir; 
; 1617:  	} 
; 1618:  	 
; 1619:  	return retDir; 
; 1620:  } 
; 1621:   
; 1622:  unsigned char InverseDir(unsigned char dir) 
; 1623:  { 
; 1624:  	return 1 - dir; 
; 1625:  } 
