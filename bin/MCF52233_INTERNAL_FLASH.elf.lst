;  660:  unsigned char GetDIBit(char ch, char bit) 
;  661:  { 
;  662:  	unsigned char res = GetInput2(ch); 
;  663:  	 
;  664:  	res = (res >> bit) & 1; 
;  665:  	 
;  666:  	return res; 
;  667:  } 
;  668:   
;  669:  unsigned char GetDOBit(char ch, char bit) 
;  670:  { 
;  671:  	unsigned char res = GetOutput2(ch); 
;  672:  	 
;  673:  	res = (res >> bit) & 1; 
;  674:  	 
;  675:  	return res;	 
;  676:  } 
;  677:   
;  678:  void SetDOBit(char ch, char bit, char flag) 
;  679:  { 
;  680:  	unsigned char res = GetOutput2(ch); 
;  681:  	 
;  682:  	if (flag == 0) 
;  683:  	{ 
;  684:  		res = res & (unsigned char)(~(1 << bit)); 
;  685:  	} 
;  686:  	else 
;  687:  	{ 
;  688:  		res = res | (1 << bit); 
;  689:  	} 
;  690:  	 
;  691:  	SetOutput2(ch, res); 
;  692:  } 
