;  501:  					GoToError(); 
;  502:  				} 
;  503:  				break; 
;  504:  				 
;  505:  			default: 
;  506:  				SetErrorCode(ERR_OVER_RUN); 
;  507:  				GoToError(); 
;  508:  				break;		 
