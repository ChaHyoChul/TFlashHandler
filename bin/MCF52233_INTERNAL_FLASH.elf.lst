;  819:  	static int timerCount = 0; 
;  820:  	int res = 0; 
;  821:  	char move_status = 0; 
;  822:   
;  823:  	switch (step) 
;  824:  	{ 
;  825:  	// Error Handling 
;  826:  	case 91: 
;  827:  		StopMotors(); 
;  828:  		++step; 
;  829:  		break; 
;  830:  	 
;  831:  	case 92: 
;  832:  		if (IsStopped()) 
;  833:  		{ 
;  834:  			++step; 
;  835:  		} 
;  836:  		break; 
