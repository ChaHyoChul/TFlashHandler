; 1730:  		{ 
; 1731:  			step = 91; 
; 1732:  			return NORMAL_RUNNING; 
; 1733:  		} 
; 1734:  		else  
; 1735:  		{ 
; 1736:  			step++; 
; 1737:  		} 
; 1738:   
; 1739:  		DelayMoveStart(); 
; 1740:  		break; 
; 1741:   
; 1742:  		// Home ņä╝ņä£Ļ░Ć ON ļÉśļ®┤ ļ®łņČśļŗż  
