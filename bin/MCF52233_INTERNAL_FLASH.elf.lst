;  662:  	} 
;  663:  } 
;  664:   
;  665:  unsigned char GetDIBit(char ch, char bit) 
;  666:  { 
;  667:  	unsigned char res = GetInput2(ch); 
;  668:  	 
;  669:  	res = (res >> bit) & 1; 
;  670:  	 
;  671:  	return res; 
;  672:  } 
;  673:   
;  674:  unsigned char GetDOBit(char ch, char bit) 
;  675:  { 
;  676:  	unsigned char res = GetOutput2(ch); 
;  677:  	 
;  678:  	res = (res >> bit) & 1; 
;  679:  	 
;  680:  	return res;	 
;  681:  } 
;  682:   
;  683:  void SetDOBit(char ch, char bit, char flag) 
;  684:  { 
;  685:  	unsigned char res = GetOutput2(ch); 
;  686:  	 
;  687:  	if (flag == 0) 
;  688:  	{ 
;  689:  		res = res & (unsigned char)(~(1 << bit)); 
;  690:  	} 
;  691:  	else 
;  692:  	{ 
;  693:  		res = res | (1 << bit); 
;  694:  	} 
;  695:  	 
;  696:  	SetOutput2(ch, res); 
;  697:  } 
