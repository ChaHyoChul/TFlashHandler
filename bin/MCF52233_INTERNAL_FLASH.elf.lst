;  442:  	 
;  443:  	// check limit sensor 
;  444:  	 
;  445:  	if (g_MotionCommand == COMM_IDLE) 
;  446:  	{ 
;  447:  		for (axis = 0; axis < MAX_AXIS; ++axis) 
;  448:  		{ 
;  449:  			if (GetMoveStatus(axis) != MOVE_STS_STOP) 
;  450:  			{ 
;  451:  				switch (get_axis_sensor(axis)) 
