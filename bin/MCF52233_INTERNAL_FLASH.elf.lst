; 1691:    
; 1692:   	if (scan_rate < 1 || scan_rate > 100) 
; 1693:   	{ 
; 1694:   		scan_rate = 100; 
; 1695:   	} 
; 1696:   	 
; 1697:   	if (axis < 0 || axis >= MAX_AXIS) 
; 1698:   	{ 
; 1699:   		return; 
; 1700:   	} 
; 1701:   	 
; 1702:   	switch (type) 
; 1703:   	{ 
; 1704:   		case SPEED_ORG: 
; 1705:   			MovVar[axis].m_uVmax = g_MotionParam[axis].m_uOrgVmax; 
; 1706:   			MovVar[axis].m_uVmin = g_MotionParam[axis].m_uOrgVmax;	// ėëę° ëë Īė max ę°ė ėŽėĐíīë ëĻ  
; 1707:   			MovVar[axis].m_uAcel = g_MotionParam[axis].m_uOrgAcel; 
; 1708:   			break; 
