; 1645:  void SetSpeed(char axis, int type) 
; 1646:  { 
; 1647:  	int scan_rate = get_var(VAR_SCAN_SPEED); 
; 1648:   
; 1649:  	if (scan_rate < 1 || scan_rate > 100) 
; 1650:  	{ 
; 1651:  		scan_rate = 100; 
; 1652:  	} 
; 1653:  	 
; 1654:  	if (axis < 0 || axis >= MAX_AXIS) 
; 1655:  	{ 
; 1656:  		return; 
; 1657:  	} 
; 1658:  	 
; 1659:  	switch (type) 
; 1660:  	{ 
; 1661:  		case SPEED_ORG: 
; 1662:  			MovVar[axis].m_uVmax = g_MotionParam[axis].m_uOrgVmax; 
; 1663:  			MovVar[axis].m_uVmin = g_MotionParam[axis].m_uOrgVmax;	// ņåŹļÅäĻ░Ć ļŖÉļĀżņä£ max Ļ░ÆņØä ņé¼ņÜ®ĒĢ┤ļÅä ļÉ©  
; 1664:  			MovVar[axis].m_uAcel = g_MotionParam[axis].m_uOrgAcel; 
; 1665:  			break; 
; 1666:  			 
; 1667:  		case SPEED_JOG: 
; 1668:  			MovVar[axis].m_uVmax = g_MotionParam[axis].m_uJogVmax; 
; 1669:  			MovVar[axis].m_uVmin = g_MotionParam[axis].m_uJogVmin; 
; 1670:  			MovVar[axis].m_uAcel = g_MotionParam[axis].m_uJogAcel; 
; 1671:  			break; 
; 1672:  			 
; 1673:  		case SPEED_NORMAL: 
; 1674:  			MovVar[axis].m_uVmax = g_MotionParam[axis].m_uNorVmax; 
; 1675:  			MovVar[axis].m_uVmin = g_MotionParam[axis].m_uNorVmin; 
; 1676:  			MovVar[axis].m_uAcel = g_MotionParam[axis].m_uNorAcel; 
; 1677:  			break; 
; 1678:   
; 1679:  		case SPEED_SCAN: 
; 1680:  			MovVar[axis].m_uVmax = ((double)scan_rate/100) * g_MotionParam[axis].m_uNorVmax; 
; 1681:  			MovVar[axis].m_uVmin = ((double)scan_rate/100) * g_MotionParam[axis].m_uNorVmin; 
; 1682:  			MovVar[axis].m_uAcel = ((double)scan_rate/100) * g_MotionParam[axis].m_uNorAcel; 
; 1683:  			break; 
; 1684:  	} 
; 1685:  	 
; 1686:  	MovVar[axis].m_ucMoveTorq = g_MotionParam[axis].m_ucMoveTorque; //(axis == Z_AXIS) ? MOVE_TORQUE : MOVE_TORQUE_3A; 
; 1687:  } 
