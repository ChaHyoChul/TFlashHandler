; 1663:  			MovVar[axis].m_uVmax = g_MotionParam[axis].m_uOrgVmax; 
; 1664:  			MovVar[axis].m_uVmin = g_MotionParam[axis].m_uOrgVmax;	// ņåŹļÅäĻ░Ć ļŖÉļĀżņä£ max Ļ░ÆņØä ņé¼ņÜ®ĒĢ┤ļÅä ļÉ©  
; 1665:  			MovVar[axis].m_uAcel = g_MotionParam[axis].m_uOrgAcel; 
; 1666:  			break; 
; 1667:  			 
; 1668:  		case SPEED_JOG: 
; 1669:  			MovVar[axis].m_uVmax = g_MotionParam[axis].m_uJogVmax; 
; 1670:  			MovVar[axis].m_uVmin = g_MotionParam[axis].m_uJogVmin; 
; 1671:  			MovVar[axis].m_uAcel = g_MotionParam[axis].m_uJogAcel; 
; 1672:  			break; 
; 1673:  			 
; 1674:  		case SPEED_NORMAL: 
; 1675:  			MovVar[axis].m_uVmax = g_MotionParam[axis].m_uNorVmax; 
; 1676:  			MovVar[axis].m_uVmin = g_MotionParam[axis].m_uNorVmin; 
; 1677:  			MovVar[axis].m_uAcel = g_MotionParam[axis].m_uNorAcel; 
; 1678:  			break; 
; 1679:   
; 1680:  		case SPEED_SCAN: 
; 1681:  			MovVar[axis].m_uVmax = ((double)scan_rate/100) * g_MotionParam[axis].m_uNorVmax; 
; 1682:  			MovVar[axis].m_uVmin = ((double)scan_rate/100) * g_MotionParam[axis].m_uNorVmin; 
; 1683:  			MovVar[axis].m_uAcel = ((double)scan_rate/100) * g_MotionParam[axis].m_uNorAcel; 
; 1684:  			break; 
