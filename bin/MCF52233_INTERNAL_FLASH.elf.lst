; 1783:  		break; 
; 1784:   
; 1785:  		// ņä╝ņä£ ļ░®Ē¢źņ£╝ļĪ£ ļŗżņŗ£ ņØ┤ļÅÖ ņŗ£ņ×æ  
; 1786:  	case 9:  
; 1787:  		nNegLimitOutPos[org_axis] = CounterRead(org_axis); 
; 1788:  		MovVar[org_axis].m_ucDir = g_MotionParam[org_axis].m_ucOrgDir;	 
; 1789:  		MovVar[org_axis].m_uAcel = 0; 
