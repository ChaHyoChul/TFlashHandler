;  477:  						StopMotors(); 
;  478:  					} 
;  479:  					break; 
;  480:  					 
;  481:  				default: 
;  482:  					SetErrorCode(ERR_OVER_RUN); 
;  483:  					StopMotors(); 
;  484:  					break;		 
;  485:  				} 
;  486:  			} 
;  487:  		} 
;  488:  	} 
;  489:  	else 
;  490:  	{ 
;  491:  		for (axis = 0; axis < MAX_AXIS; ++axis) 
;  492:  		{ 
;  493:  			switch (get_axis_sensor(axis)) 
;  494:  			{ 
;  495:  			case 0: 
;  496:  				break; 
;  497:  				 
;  498:  			case 1:	// POS LIMIT 
;  499:  				if (g_MoveOffset[axis] > 0) 
