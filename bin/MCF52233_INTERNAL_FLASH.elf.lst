; 1098:   
; 1099:  		break; 
; 1100:   
; 1101:  	case 17 : 
; 1102:  		if (IsStopped()) 
; 1103:  		{ 
; 1104:  			++step; 
; 1105:  			debugf("step=%d", step); 
; 1106:  		} 
; 1107:   
; 1108:  		break; 
; 1109:  		 
; 1110:  	case 18 : 
; 1111:  		for (axis = 0; axis < MAX_AXIS; ++axis) 
; 1112:  		{ 
; 1113:  			CounterReset(axis);	// ’┐Į’┐Į’┐Į’┐Į’┐Į’┐Į’┐Į’┐Į ’┐Į’┐Į’┐Į’┐Į’┐Įč┤’┐Į. 
