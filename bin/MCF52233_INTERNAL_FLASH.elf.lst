;  771:  		++step; 
;  772:  		break; 
;  773:  	 
;  774:  	case 1: 
;  775:  		if (IsStopped()) 
;  776:  		{ 
;  777:  			++step; 
;  778:  		} 
;  779:  		break; 
;  780:  		 
;  781:  	case 2: 
