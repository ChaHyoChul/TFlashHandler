;  715:   
;  716:  void SetOriginCompletedFlag(char axis, char flag) 
;  717:  { 
;  718:  	if (axis < 0 || axis >= MAX_AXIS) 
;  719:  	{ 
;  720:  		return; 
;  721:  	} 
;  722:  	 
;  723:  	if (flag < 0 || flag > 1) 
;  724:  	{ 
;  725:  		return; 
;  726:  	} 
;  727:  	 
;  728:  	g_OriginCompletedAxes[axis] = flag; 
;  729:  	 
;  730:  	UpdateOriginCompletedStatus(); 
;  731:  } 
