; 1566:  void JogStart(char axis, char dir) 
; 1567:  { 
; 1568:  	static char str[128]; 
; 1569:  	 
; 1570:  	sprintf(str, "JogStart(%d, %d)", axis, dir); 
; 1571:  	debug(str); 
; 1572:  	 
; 1573:  	if (dir == 0)	// inverse 
; 1574:  	{ 
; 1575:  		dir = InverseDir(g_MotionParam[axis].m_ucMoveDir); 
; 1576:  	} 
; 1577:  	else 
; 1578:  	{ 
; 1579:  		dir = g_MotionParam[axis].m_ucMoveDir; 
