; 1744:  		if (HOME_SENSOR(org_axis) == SENS_ON) 
; 1745:  		{ 
; 1746:  			MoveStop(org_axis);  
; 1747:  			step++; 
; 1748:  		}	 
; 1749:  		break; 
; 1750:   
; 1751:  	case 5: 
; 1752:  		if (IsStopped()) { step++; }  
; 1753:  		break; 
; 1754:   
; 1755:  		// ļ░śļīĆ ļ░®Ē¢öņ£╝ļĪ£ ņØ┤ļÅÖ ņŗ£ņ×æ  
; 1756:  	case 6: 
; 1757:  		CounterReset(org_axis); 
; 1758:  		MovVar[org_axis].m_ucDir = (unsigned char)((~g_MotionParam[org_axis].m_ucOrgDir) & 1); 
; 1759:  		MovVar[org_axis].m_uAcel = 0;					 
; 1760:   
; 1761:  		if (MoveStart(org_axis)) 
; 1762:  		{ 
; 1763:  			step = 91; 
; 1764:  			SetErrorCode(ERR_MOTOR_ERROR); 
; 1765:  			return NORMAL_RUNNING; 
; 1766:  		} 
; 1767:   
; 1768:  		DelayMoveStart(); 
; 1769:  		step++; 
; 1770:  		break; 
; 1771:   
; 1772:  		// HOME ņä╝ņä£Ļ░Ć OFF ļÉśļ®┤ ļ®łņČśļŗż  
; 1773:  	case 7:	 
; 1774:  		if (HOME_SENSOR(org_axis) == SENS_OFF) 
; 1775:  		{ 
; 1776:  			MoveStop(org_axis); 
; 1777:  			step++; 
; 1778:  		} 
; 1779:  		break; 
; 1780:   
; 1781:  	case 8: 
; 1782:  		if (IsStopped()) { step++; }  
; 1783:  		break; 
; 1784:   
; 1785:  		// ņä╝ņä£ ļ░®Ē¢źņ£╝ļĪ£ ļŗżņŗ£ ņØ┤ļÅÖ ņŗ£ņ×æ  
; 1786:  	case 9:  
