;  253:  void SendResponseRaw(char* command, int errorCode) 
;  254:  { 
;  255:  	char str[64] = ""; 
;  256:  	 
;  257:  	if (strlen(command) < 2) 
;  258:  	{ 
;  259:  		return; 
;  260:  	} 
;  261:  	 
;  262:  	if (errorCode == 0) 
;  263:  	{ 
;  264:  		if (strstr(command, "ERR") != 0) 
;  265:  		{ 
;  266:  			sprintf(str, "%s 000\r\n", command);	 
;  267:  		} 
;  268:  		else 
;  269:  		{ 
;  270:  			sprintf(str, "%s\r\n", command); 
;  271:  		} 
;  272:  	} 
;  273:  	else if (errorCode < 1000) 
;  274:  	{ 
;  275:  		sprintf(str, "%s %03d\r\n", command, errorCode); 
;  276:  	} 
;  277:  	else 
;  278:  	{ 
;  279:  		sprintf(str, "%s E%02d\r\n", command, errorCode-1000); 
;  280:  	} 
;  281:   
;  282:  	send(str); 
;  283:  } 
