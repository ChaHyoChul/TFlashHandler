; 1756:  // g_MoveOffset[] ļ│ĆņłśņŚÉ ņ£äņ╣śļź╝ ņĀĆņ×źĒĢ┤ ļåōĻ│Ā, ĻĘĖ ņ£äņ╣śļĪ£ ņØ┤ļÅÖĒĢ£ļŗż  
; 1757:  char CommGripUngrip() 
; 1758:  { 
; 1759:  	static char step = 0; 
; 1760:  	int  axis = 0; 
; 1761:  	char flag = 1; 
; 1762:  	char move_start = 0; 
; 1763:  	char move_status = 0; 
; 1764:  	 
; 1765:  	switch (step) 
; 1766:  	{ 
; 1767:  		// Error handling  
; 1768:  	case 91: StopMotors(); step++; break; 
; 1769:  	case 92: if (IsStopped()) { step++; } break; 
; 1770:  	case 93: HoldMotors(); step = 0; return ERROR_STOPPED; 
; 1771:   
; 1772:  		// Start 
; 1773:  		// move_offset Ļ░ÆņØ┤ 0ņØ┤ļ®┤ MoveStart() ĒĢ©ņłśņŚÉņä£ 3ļ▓ł ņŚÉļ¤¼ ļ░£ņāØ   
; 1774:  		// offset = target_pos - current_pos  
; 1775:  		// point data 2ļ▓ł. ZņČĢ ņ£äņ╣ś ņé¼ņÜ®  
; 1776:  	case 0: 
; 1777:  		if (g_MovePointDataNo != 0) 
; 1778:  		{ 
; 1779:  			move_start = move_pd(g_MovePointDataNo, 0x04); 
; 1780:  			if (move_start)  
; 1781:  			{ 
; 1782:  				SetErrorCode(ERR_MOTOR_ERROR); 
; 1783:  				step = 91; 
; 1784:  				return NORMAL_RUNNING; 
; 1785:  			} 
; 1786:  			DelayMoveStart(); 
; 1787:  			step++; 
; 1788:  		} 
; 1789:  		else  
; 1790:  		{ 
; 1791:  			step = 3; 
; 1792:  		} 
; 1793:  		break; 
; 1794:  		 
; 1795:  	case 1: 
; 1796:  		if (move_done(0x04))  
; 1797:  		{ 
; 1798:  			step++; 
; 1799:  		} 
; 1800:  		break; 
; 1801:   
; 1802:  	case 2: 
; 1803:  		if (IsStopped()) 
; 1804:  		{ 
; 1805:  			step++; 
; 1806:  		} 
; 1807:  		break; 
; 1808:   
; 1809:  	case 3: 
; 1810:  		SetHoldTorque(Z_AXIS); 
; 1811:  		g_MovePointDataNo = 0; 
; 1812:  		g_MoveOffset[Z_AXIS] = 0; 
; 1813:  		step = 0; 
; 1814:  		return NORMAL_FINISHED; 
; 1815:   
; 1816:  	default: 
; 1817:  		step = 0; 
; 1818:  		return NORMAL_FINISHED; 
; 1819:  	} 
; 1820:   
; 1821:  	CHECK_USER_STOP(); 
; 1822:   
; 1823:  	return 0; 
; 1824:  } 
