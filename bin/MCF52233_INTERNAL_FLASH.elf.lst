;  433:  		if (IsStopped()) 
;  434:  		{ 
;  435:  			return; 
;  436:  		} 
;  437:  		break; 
;  438:  	case COMM_ORIGIN: 
;  439:  	case COMM_ERROR_STOP: 
;  440:  		return; 
;  441:  	} 
;  442:  	 
;  443:  	// check limit sensor 
;  444:  	 
;  445:  	if (g_MotionCommand == COMM_IDLE) 
;  446:  	{ 
;  447:  		for (axis = 0; axis < MAX_AXIS; ++axis) 
;  448:  		{ 
;  449:  			if (GetMoveStatus(axis) != MOVE_STS_STOP) 
;  450:  			{ 
;  451:  				switch (get_axis_sensor(axis)) 
;  452:  				{ 
;  453:  				case 0: 
;  454:  					break; 
;  455:  					 
;  456:  				case 1:	// POS LIMIT 
;  457:  					if (MovVar[axis].m_ucDir == g_MotionParam[axis].m_ucMoveDir) 
;  458:  					{ 
;  459:  						SetErrorCode(ERR_OVER_RUN); 
;  460:  						StopMotors(); 
;  461:  					} 
;  462:  					break; 
;  463:  					 
;  464:  				case 2: // NEG LIMIT 
;  465:  					if (MovVar[axis].m_ucDir != g_MotionParam[axis].m_ucMoveDir) 
;  466:  					{ 
;  467:  						SetErrorCode(ERR_OVER_RUN); 
;  468:  						StopMotors(); 
;  469:  					} 
;  470:  					break; 
;  471:  					 
;  472:  				default: 
;  473:  					SetErrorCode(ERR_OVER_RUN); 
;  474:  					StopMotors(); 
;  475:  					break;		 
;  476:  				} 
;  477:  			} 
;  478:  		} 
;  479:  	} 
;  480:  	else 
;  481:  	{ 
;  482:  		for (axis = 0; axis < MAX_AXIS; ++axis) 
;  483:  		{ 
;  484:  			switch (get_axis_sensor(axis)) 
;  485:  			{ 
;  486:  			case 0: 
;  487:  				break; 
;  488:  				 
;  489:  			case 1:	// POS LIMIT 
;  490:  				if (g_MoveOffset[axis] > 0) 
;  491:  				{ 
;  492:  					SetErrorCode(ERR_OVER_RUN); 
;  493:  					GoToError(); 
;  494:  				} 
;  495:  				break; 
;  496:  				 
;  497:  			case 2: // NEG LIMIT 
;  498:  				if (g_MoveOffset[axis] < 0) 
;  499:  				{ 
