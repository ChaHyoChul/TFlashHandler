; 1720:   
; 1721:  	case 3: 
; 1722:  		MovVar[Z_AXIS].m_uS = g_MotionParam[Z_AXIS].m_uOrgSLimit; 
; 1723:  		MovVar[Z_AXIS].m_ucDir = g_MotionParam[Z_AXIS].m_ucOrgDir; 
; 1724:  		SetSpeed(Z_AXIS, SPEED_ORG); 
; 1725:   
; 1726:  		if (NEG_LIMIT(Z_AXIS) != SENS_ON && MoveStart(Z_AXIS))  
; 1727:  		{ 
; 1728:  			step = 91; 
; 1729:  			return NORMAL_RUNNING; 
; 1730:  		} 
; 1731:  		else  
; 1732:  		{ 
; 1733:  			step++; 
; 1734:  		} 
; 1735:   
; 1736:  		DelayMoveStart(); 
; 1737:  		break; 
; 1738:   
; 1739:  	case 4: 
; 1740:  		if (HOME_SENSOR(Z_AXIS) == SENS_ON) 
; 1741:  		{ 
; 1742:  			MoveStop(Z_AXIS);  
