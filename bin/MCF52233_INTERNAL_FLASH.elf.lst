; 1794:  		 
; 1795:  	case 1: 
; 1796:  		if (move_done(0x04))  
; 1797:  		{ 
; 1798:  			step++; 
; 1799:  		} 
; 1800:  		break; 
; 1801:   
; 1802:  	case 2: 
