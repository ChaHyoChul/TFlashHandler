;  337:   
;  338:  void UpdateState(char state) 
;  339:  { 
;  340:  	switch (state) 
;  341:  	{ 
;  342:  	case NORMAL_RUNNING: 
;  343:  		break; 
;  344:  	 
;  345:  	case NORMAL_FINISHED: 
;  346:  		if (g_ResponseSend == 0) 
;  347:  		{ 
;  348:  			SendResponse(); 
;  349:  		} 
;  350:  		else 
;  351:  		{ 
;  352:  			g_ResponseSend = 0; 
;  353:  		} 
;  354:  		GoToIdle(); 
;  355:  		break; 
;  356:  	 
;  357:  	case ERROR_STOPPED: 
;  358:  		SendResponse(); 
;  359:  		GoToIdle(); 
;  360:  		break; 
;  361:  	} 
;  362:  } 
;  363:   
;  364:  /////////////////////////////////////////////////////////// 
;  365:  // 1ms Timer Interrupt ’┐Į’┐Į ’┐Į╠┐’┐Į’┐Į’┐Į ’┐Į’┐Į’┐Į ’┐Į’┐Į’┐Į’┐Į ─┐’┐Į’┐Į’┐Į ├│’┐Į’┐Į ’┐Į’┐ĮŲŠ 
;  366:  /////////////////////////////////////////////////////////// 
;  367:  void MainControl() 
;  368:  { 
;  369:  	char res = 0; 
;  370:   
;  371:  	switch (g_MotionCommand) 
;  372:  	{ 
;  373:  	case COMM_IDLE:		break; 
;  374:  	case COMM_ORIGIN:	res = CommOrigin();	UpdateState(res);	break; 
;  375:  	case COMM_PTP:		res = CommMove();	UpdateState(res);	break; 
;  376:  	case COMM_ORIGIN_A:	res = CommOriginAxis();	UpdateState(res);	break; 
;  377:  	case COMM_ERROR_STOP:	res = CommErrorStop();	UpdateState(res);	break; 
;  378:   
;  379:  	case COMM_HOME:		res = CommHome(); UpdateState(res); break; 
;  380:  	case COMM_MGRI:		res = CommGripUngrip(); UpdateState(res); break; 
;  381:  	case COMM_MUNG:		res = CommGripUngrip(); UpdateState(res); break; 
;  382:  	case COMM_MLOA:		res = CommMoveXY(); UpdateState(res); break; 
;  383:  	case COMM_MASP:		res = CommMoveXY(); UpdateState(res); break; 
;  384:  	case COMM_MDIS:		res = CommMoveXY(); UpdateState(res); break; 
;  385:  	case COMM_MSHA:		res = CommShake(); UpdateState(res); break; 
;  386:  	case COMM_MWAS:		res = CommWaste(); UpdateState(res); break; 
;  387:  	case COMM_MSEP:		res = CommSeparate(); UpdateState(res); break; 
;  388:  	} 
;  389:  	 
;  390:  	if (g_UserStop > 0) 
;  391:  	{ 
;  392:  		--g_UserStop; 
;  393:  	} 
;  394:  	 
;  395:  	if (g_GoToError > 0) 
;  396:  	{ 
;  397:  		if (g_UserStop < 3) 
;  398:  		{ 
;  399:  			g_MotionCommand = COMM_ERROR_STOP; 
;  400:  			g_GoToError = 0; 
;  401:  		} 
;  402:  	} 
;  403:  } 
;  404:   
;  405:  void SystemCheck() 
;  406:  { 
;  407:  	char res = 0; 
;  408:  	char axis = 0; 
;  409:  	char userEmo = 0; 
;  410:  	char is_stopped = 0; 
;  411:  	char use_UserEMO = 0; 
;  412:  	 
;  413:  	if (g_MotionCommand == COMM_IDLE && IsStopped()) 
;  414:  	{ 
;  415:  		is_stopped = 1; 
;  416:  	} 
;  417:  	 
;  418:  	// system out 
;  419:  	SetDO(0, is_stopped == 0); 
;  420:  	SetDO(1, is_stopped); 
;  421:  	SetDO(2, g_OriginCompleted); 
;  422:  	SetDO(3, g_ErrorCode == ERR_OVER_RUN); 
;  423:  	SetDO(4, g_ErrorCode != 0); 
;  424:  	 
;  425:  	 
;  426:  	if (use_UserEMO)	// currently not used (1.00.016) 
;  427:  	{ 
;  428:  		// User Emergency 
;  429:  		userEmo = GetDI(0); 
;  430:  	 
;  431:  		if (userEmo == 0) // reverse, 0=EMO, 1=Normal 
;  432:  		{ 
;  433:  			SetErrorCode(ERR_EMERGENCY); 
;  434:  			GoToError(); 
;  435:  			for (axis = 0; axis < MAX_AXIS; ++axis) 
;  436:  			{ 
;  437:  				MovVar[g_OriginAxis].m_uAcel = EMERGENCY_STOP_DECEL; 
;  438:  				MoveStop(axis); 
;  439:  			} 
;  440:  			g_OriginCompleted = 0; 
;  441:  			return; 
;  442:  		} 
;  443:  	} 
;  444:   
;  445:  	switch (g_MotionCommand) 
;  446:  	{ 
;  447:  	case COMM_IDLE: 
;  448:  		if (IsStopped()) 
;  449:  		{ 
;  450:  			return; 
;  451:  		} 
;  452:  		break; 
;  453:  	case COMM_ORIGIN: 
;  454:  	case COMM_ERROR_STOP: 
;  455:  		return; 
;  456:  	} 
;  457:  	 
;  458:  	// check limit sensor 
;  459:  	 
;  460:  	if (g_MotionCommand == COMM_IDLE) 
;  461:  	{ 
;  462:  		for (axis = 0; axis < MAX_AXIS; ++axis) 
;  463:  		{ 
;  464:  			if (GetMoveStatus(axis) != MOVE_STS_STOP) 
;  465:  			{ 
;  466:  				switch (get_axis_sensor(axis)) 
;  467:  				{ 
;  468:  				case 0: 
;  469:  					break; 
;  470:  					 
;  471:  				case 1:	// POS LIMIT 
;  472:  					if (MovVar[axis].m_ucDir == g_MotionParam[axis].m_ucMoveDir) 
;  473:  					{ 
;  474:  						SetErrorCode(ERR_OVER_RUN); 
;  475:  						StopMotors(); 
;  476:  					} 
;  477:  					break; 
;  478:  					 
;  479:  				case 2: // NEG LIMIT 
;  480:  					if (MovVar[axis].m_ucDir != g_MotionParam[axis].m_ucMoveDir) 
;  481:  					{ 
;  482:  						SetErrorCode(ERR_OVER_RUN); 
;  483:  						StopMotors(); 
;  484:  					} 
;  485:  					break; 
;  486:  					 
;  487:  				default: 
;  488:  					SetErrorCode(ERR_OVER_RUN); 
;  489:  					StopMotors(); 
;  490:  					break;		 
;  491:  				} 
;  492:  			} 
;  493:  		} 
;  494:  	} 
;  495:  	else 
;  496:  	{ 
;  497:  		for (axis = 0; axis < MAX_AXIS; ++axis) 
;  498:  		{ 
;  499:  			switch (get_axis_sensor(axis)) 
;  500:  			{ 
;  501:  			case 0: 
;  502:  				break; 
;  503:  				 
;  504:  			case 1:	// POS LIMIT 
;  505:  				if (g_MoveOffset[axis] > 0) 
;  506:  				{ 
;  507:  					SetErrorCode(ERR_OVER_RUN); 
;  508:  					GoToError(); 
;  509:  				} 
;  510:  				break; 
;  511:  				 
;  512:  			case 2: // NEG LIMIT 
;  513:  				if (g_MoveOffset[axis] < 0) 
;  514:  				{ 
;  515:  					SetErrorCode(ERR_OVER_RUN); 
;  516:  					GoToError(); 
;  517:  				} 
;  518:  				break; 
;  519:  				 
;  520:  			default: 
;  521:  				SetErrorCode(ERR_OVER_RUN); 
;  522:  				GoToError(); 
;  523:  				break;		 
;  524:  			} 
;  525:  		} 
;  526:  	} 
;  527:  } 
;  528:   
;  529:  unsigned char GetInput(char ch) 
;  530:  { 
;  531:  	unsigned char res = 0; 
;  532:  	unsigned short val = 0; 
;  533:  	 
;  534:  	if (ch < 0 || ch > 1) 
;  535:  	{ 
;  536:  		return res; 
;  537:  	} 
;  538:  	 
;  539:  	val = ~GetInput16(); 
;  540:  	 
;  541:  	res = (val >> (8*ch)) & 0xFF; 
;  542:  	 
;  543:  	return res; 
;  544:  } 
;  545:   
;  546:  unsigned char GetOutput(char ch) 
;  547:  { 
;  548:  	unsigned char res = 0; 
;  549:  	unsigned short val = 0; 
;  550:  	 
;  551:  	if (ch < 0 || ch > 1) 
;  552:  	{ 
;  553:  		return res; 
;  554:  	} 
;  555:  	 
;  556:  	//val = ~GetOutput12(); 
;  557:  	val = ~GetOutput8(); 
;  558:  	 
;  559:  	res = (val >> (8*ch)) & 0xFF; 
;  560:  	 
;  561:  	return res; 
;  562:  } 
;  563:   
;  564:  void SetOutput(char ch, unsigned char data) 
;  565:  { 
;  566:  	//unsigned short cur = GetOutput12();		// active low 
;  567:  	unsigned short cur = GetOutput8(); 
;  568:  	unsigned short data2 = 0xFF & (~data);	// active high -> active low 
;  569:  	 
;  570:  	if (ch < 0 || ch > 1) 
;  571:  	{ 
;  572:  		return; 
;  573:  	} 
;  574:  	 
;  575:  	cur = cur & (unsigned short)(~(0xFF << (8*ch))); 
;  576:  	data2 = cur | (unsigned short)(data2 << (8*ch)); 
;  577:  	 
;  578:  	// SetOutput12(data2); 
;  579:  	SetOutput8(data2); 
;  580:  } 
;  581:   
;  582:  unsigned char GetInput2(char ch) 
;  583:  { 
;  584:  	unsigned char res = 0; 
;  585:   
;  586:  	if (ch < 1 || ch > MAX_DI) 
;  587:  	{ 
;  588:  		return res; 
;  589:  	} 
;  590:  	 
;  591:  	res = GetInput(ch-1);	// GetInput() : ch = 0-base 
;  592:  	 
;  593:  	return res; 
;  594:  } 
;  595:   
;  596:  unsigned char GetOutput2(char ch) 
;  597:  { 
;  598:  	unsigned char res = 0; 
;  599:   
;  600:  	if (ch < 1 || ch > MAX_DO) 
;  601:  	{ 
;  602:  		return res; 
;  603:  	} 
;  604:  	 
;  605:  	res = GetOutput(ch-1);	// GetOutput() : ch = 0-base 
;  606:   
;  607:  	return res;	 
;  608:  } 
;  609:   
;  610:  void SetOutput2(char ch, unsigned char data) 
;  611:  { 
;  612:  	if (ch < 1 || ch > MAX_DO) 
;  613:  	{ 
;  614:  		return; 
;  615:  	} 
;  616:  	 
;  617:  	SetOutput(ch-1, data); 
;  618:  } 
;  619:   
;  620:  char GetDI(char ch) 
;  621:  { 
;  622:  	char res = 0; 
;  623:   
;  624:  	if (ch >= 0 && ch < MAX_DI) 
;  625:  	{ 
;  626:  		res = (((GetInput16() >> ch) & 1) == SENS_ON); 
;  627:  	} 
;  628:  	 
;  629:  	return res; 
;  630:  } 
;  631:   
;  632:  char GetDO(char ch) 
;  633:  { 
;  634:  	char res = 0; 
;  635:   
;  636:  	if (ch >= 0 && ch < MAX_DO) 
;  637:  	{ 
;  638:  		//res = (((GetOutput12() >> ch) & 1) == SENS_ON); 
;  639:  		res = (((GetOutput8() >> ch) & 1) == SENS_ON); 
;  640:  	} 
;  641:  	 
;  642:  	return res; 
;  643:  } 
;  644:   
;  645:  void SetDO(char ch, char flag) 
;  646:  { 
;  647:  	char res = 0; 
;  648:  	int value = 0; 
;  649:   
;  650:  	if (ch >= 0 && ch < MAX_DO) 
;  651:  	{ 
;  652:  		value = (1 << ch); 
;  653:  		if (flag) 
;  654:  		{ 
;  655:  			//SetOutput12(GetOutput12() & ~value); 
;  656:  			SetOutput8(GetOutput8() & ~value); 
;  657:  		} 
;  658:  		else 
;  659:  		{ 
;  660:  			//SetOutput12(GetOutput12() | value); 
;  661:  			SetOutput8(GetOutput8() | value); 
;  662:  		} 
;  663:  	} 
;  664:  } 
;  665:   
;  666:  unsigned char GetDIBit(char ch, char bit) 
;  667:  { 
;  668:  	unsigned char res = GetInput2(ch); 
;  669:  	 
;  670:  	res = (res >> bit) & 1; 
;  671:  	 
;  672:  	return res; 
;  673:  } 
;  674:   
;  675:  unsigned char GetDOBit(char ch, char bit) 
;  676:  { 
;  677:  	unsigned char res = GetOutput2(ch); 
;  678:  	 
;  679:  	res = (res >> bit) & 1; 
;  680:  	 
;  681:  	return res;	 
;  682:  } 
;  683:   
;  684:  void SetDOBit(char ch, char bit, char flag) 
;  685:  { 
;  686:  	unsigned char res = GetOutput2(ch); 
;  687:  	 
;  688:  	if (flag == 0) 
;  689:  	{ 
;  690:  		res = res & (unsigned char)(~(1 << bit)); 
;  691:  	} 
;  692:  	else 
;  693:  	{ 
;  694:  		res = res | (1 << bit); 
;  695:  	} 
;  696:  	 
;  697:  	SetOutput2(ch, res); 
;  698:  } 
;  699:   
;  700:  void UpdateOriginCompletedStatus() 
;  701:  { 
;  702:  	char axis = 0; 
;  703:  	char flag = 1; 
;  704:   
;  705:  	for (axis = 0; axis < MAX_AXIS; ++axis) 
;  706:  	{ 
;  707:  		if (g_OriginNeed[axis] && g_OriginCompletedAxes[axis] == 0) 
;  708:  		{ 
;  709:  			flag = 0; 
;  710:  			break; 
;  711:  		} 
;  712:  	} 
;  713:  	 
;  714:  	g_OriginCompleted = flag; 
;  715:  } 
;  716:   
;  717:  void SetOriginCompletedFlag(char axis, char flag) 
;  718:  { 
;  719:  	if (axis < 0 || axis >= MAX_AXIS) 
;  720:  	{ 
;  721:  		return; 
;  722:  	} 
;  723:  	 
;  724:  	if (flag < 0 || flag > 1) 
;  725:  	{ 
;  726:  		return; 
;  727:  	} 
;  728:  	 
;  729:  	g_OriginCompletedAxes[axis] = flag; 
;  730:  	 
;  731:  	UpdateOriginCompletedStatus(); 
;  732:  } 
;  733:   
;  734:  char IsOriginCompleted() 
;  735:  { 
;  736:  	return g_OriginCompleted; 
;  737:  } 
;  738:   
;  739:  char IsStopped() 
;  740:  { 
;  741:  	char axis = 0; 
;  742:  	char moveStatus = 0; 
;  743:  	 
;  744:  	for (axis = 0; axis < MAX_AXIS; ++axis) 
;  745:  	{ 
;  746:  		moveStatus = GetMoveStatus(axis); 
;  747:  		if (moveStatus != MOVE_STS_STOP) 
;  748:  		{ 
;  749:  			return 0; 
;  750:  		} 
;  751:  	} 
;  752:  	 
;  753:  	return 1; 
;  754:  } 
;  755:   
;  756:  void HoldMotors() 
;  757:  { 
;  758:  	char axis = 0; 
;  759:  	 
;  760:  	for (axis = 0; axis < MAX_AXIS; ++axis) 
;  761:  	{ 
;  762:  		SetHoldTorque(axis); 
;  763:  	} 
;  764:  } 
;  765:   
;  766:  void StopMotors() 
;  767:  { 
;  768:  	char axis = 0; 
;  769:  	 
;  770:  	for (axis = 0; axis < MAX_AXIS; ++axis) 
;  771:  	{ 
;  772:  		MoveStop(axis); 
;  773:  	} 
;  774:  } 
;  775:   
;  776:   
