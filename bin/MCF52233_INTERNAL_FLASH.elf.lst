; 1609:  unsigned char GetRawDir(char axis, unsigned char dir) 
; 1610:  { 
; 1611:  	unsigned char retDir = dir; 
; 1612:   
; 1613:  	// change the direction for X-axis 
; 1614:  	if (axis == X_AXIS) 
; 1615:  	{ 
; 1616:  		retDir = 1 - retDir; 
; 1617:  	} 
; 1618:  	 
; 1619:  	return retDir; 
; 1620:  } 
; 1621:   
; 1622:  unsigned char InverseDir(unsigned char dir) 
; 1623:  { 
; 1624:  	return 1 - dir; 
; 1625:  } 
; 1626:   
; 1627:  void SetMoveOffset(char axis, int offset) 
; 1628:  { 
; 1629:  	unsigned char dir = g_MotionParam[axis].m_ucMoveDir; 
; 1630:  	if (offset < 0) 
; 1631:  	{ 
; 1632:  		dir = InverseDir(dir); 
; 1633:  		offset = -offset; 
; 1634:  	} 
; 1635:  	 
; 1636:  	MovVar[axis].m_uS    = offset; 
; 1637:  	MovVar[axis].m_ucDir = dir; 
; 1638:  } 
; 1639:   
; 1640:  void SetSpeed(char axis, int type) 
; 1641:  { 
; 1642:  	int scan_rate = get_var(VAR_SCAN_SPEED); 
; 1643:   
; 1644:  	if (scan_rate < 1 || scan_rate > 100) 
; 1645:  	{ 
; 1646:  		scan_rate = 100; 
; 1647:  	} 
; 1648:  	 
; 1649:  	if (axis < 0 || axis >= MAX_AXIS) 
; 1650:  	{ 
; 1651:  		return; 
; 1652:  	} 
; 1653:  	 
; 1654:  	switch (type) 
; 1655:  	{ 
; 1656:  		case SPEED_ORG: 
; 1657:  			MovVar[axis].m_uVmax = g_MotionParam[axis].m_uOrgVmax; 
; 1658:  			MovVar[axis].m_uVmin = g_MotionParam[axis].m_uOrgVmax;	// ņåŹļÅäĻ░Ć ļŖÉļĀżņä£ max Ļ░ÆņØä ņé¼ņÜ®ĒĢ┤ļÅä ļÉ©  
; 1659:  			MovVar[axis].m_uAcel = g_MotionParam[axis].m_uOrgAcel; 
; 1660:  			break; 
; 1661:  			 
; 1662:  		case SPEED_JOG: 
; 1663:  			MovVar[axis].m_uVmax = g_MotionParam[axis].m_uJogVmax; 
; 1664:  			MovVar[axis].m_uVmin = g_MotionParam[axis].m_uJogVmin; 
; 1665:  			MovVar[axis].m_uAcel = g_MotionParam[axis].m_uJogAcel; 
; 1666:  			break; 
; 1667:  			 
; 1668:  		case SPEED_NORMAL: 
; 1669:  			MovVar[axis].m_uVmax = g_MotionParam[axis].m_uNorVmax; 
; 1670:  			MovVar[axis].m_uVmin = g_MotionParam[axis].m_uNorVmin; 
; 1671:  			MovVar[axis].m_uAcel = g_MotionParam[axis].m_uNorAcel; 
; 1672:  			break; 
; 1673:   
; 1674:  		case SPEED_SCAN: 
; 1675:  			MovVar[axis].m_uVmax = ((double)scan_rate/100) * g_MotionParam[axis].m_uNorVmax; 
; 1676:  			MovVar[axis].m_uVmin = ((double)scan_rate/100) * g_MotionParam[axis].m_uNorVmin; 
; 1677:  			MovVar[axis].m_uAcel = ((double)scan_rate/100) * g_MotionParam[axis].m_uNorAcel; 
; 1678:  			break; 
; 1679:  	} 
; 1680:  	 
; 1681:  	MovVar[axis].m_ucMoveTorq = g_MotionParam[axis].m_ucMoveTorque; //(axis == Z_AXIS) ? MOVE_TORQUE : MOVE_TORQUE_3A; 
; 1682:  } 
