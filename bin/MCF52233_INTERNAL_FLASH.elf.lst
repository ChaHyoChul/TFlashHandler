; 1565:  void JogStart(char axis, char dir) 
; 1566:  { 
; 1567:  	static char str[128]; 
; 1568:  	 
; 1569:  	sprintf(str, "JogStart(%d, %d)", axis, dir); 
; 1570:  	debug(str); 
; 1571:  	 
; 1572:  	if (dir == 0)	// inverse 
; 1573:  	{ 
; 1574:  		dir = InverseDir(g_MotionParam[axis].m_ucMoveDir); 
; 1575:  	} 
; 1576:  	else 
; 1577:  	{ 
; 1578:  		dir = g_MotionParam[axis].m_ucMoveDir; 
; 1579:  	} 
; 1580:  	 
; 1581:   
; 1582:  	MovVar[axis].m_uS    = g_MotionParam[axis].m_uOrgSLimit; 
