;  337:   
;  338:  void UpdateState(char state) 
;  339:  { 
;  340:  	switch (state) 
;  341:  	{ 
;  342:  	case NORMAL_RUNNING: 
;  343:  		break; 
;  344:  	 
;  345:  	case NORMAL_FINISHED: 
;  346:  		if (g_ResponseSend == 0) 
;  347:  		{ 
;  348:  			SendResponse(); 
;  349:  		} 
;  350:  		else 
;  351:  		{ 
;  352:  			g_ResponseSend = 0; 
;  353:  		} 
;  354:  		GoToIdle(); 
;  355:  		break; 
;  356:  	 
;  357:  	case ERROR_STOPPED: 
;  358:  		SendResponse(); 
;  359:  		GoToIdle(); 
;  360:  		break; 
;  361:  	} 
;  362:  } 
;  363:   
;  364:  /////////////////////////////////////////////////////////// 
;  365:  // 1ms Timer Interrupt ’┐Į’┐Į ’┐Į╠┐’┐Į’┐Į’┐Į ’┐Į’┐Į’┐Į ’┐Į’┐Į’┐Į’┐Į ─┐’┐Į’┐Į’┐Į ├│’┐Į’┐Į ’┐Į’┐ĮŲŠ 
;  366:  /////////////////////////////////////////////////////////// 
;  367:  void MainControl() 
;  368:  { 
;  369:  	char res = 0; 
;  370:   
;  371:  	switch (g_MotionCommand) 
;  372:  	{ 
;  373:  	case COMM_IDLE:		break; 
;  374:  	case COMM_ORIGIN:	res = CommOrigin();	UpdateState(res);	break; 
;  375:  	case COMM_PTP:		res = CommMove();	UpdateState(res);	break; 
;  376:  	case COMM_ORIGIN_A:	res = CommOriginAxis();	UpdateState(res);	break; 
;  377:  	case COMM_ERROR_STOP:	res = CommErrorStop();	UpdateState(res);	break; 
;  378:   
;  379:  	case COMM_HOME:		res = CommHome(); UpdateState(res); break; 
;  380:  	case COMM_MGRI:		res = CommGripUngrip(); UpdateState(res); break; 
;  381:  	case COMM_MUNG:		res = CommGripUngrip(); UpdateState(res); break; 
;  382:  	case COMM_MLOA:		res = CommMoveXY(); UpdateState(res); break; 
;  383:  	case COMM_MASP:		res = CommMoveXY(); UpdateState(res); break; 
;  384:  	case COMM_MDIS:		res = CommMoveXY(); UpdateState(res); break; 
;  385:  	case COMM_MSHA:		res = CommShake(); UpdateState(res); break; 
;  386:  	case COMM_MWAS:		res = CommWaste(); UpdateState(res); break; 
;  387:  	case COMM_MSEP:		res = CommSeparate(); UpdateState(res); break; 
;  388:  	} 
;  389:  	 
;  390:  	if (g_UserStop > 0) 
;  391:  	{ 
;  392:  		--g_UserStop; 
;  393:  	} 
;  394:  	 
;  395:  	if (g_GoToError > 0) 
;  396:  	{ 
;  397:  		if (g_UserStop < 3) 
;  398:  		{ 
;  399:  			g_MotionCommand = COMM_ERROR_STOP; 
;  400:  			g_GoToError = 0; 
;  401:  		} 
;  402:  	} 
;  403:  } 
;  404:   
;  405:  void SystemCheck() 
;  406:  { 
;  407:  	char res = 0; 
;  408:  	char axis = 0; 
;  409:  	char userEmo = 0; 
;  410:  	char is_stopped = 0; 
;  411:  	char use_UserEMO = 0; 
;  412:  	 
;  413:  	if (g_MotionCommand == COMM_IDLE && IsStopped()) 
;  414:  	{ 
;  415:  		is_stopped = 1; 
;  416:  	} 
;  417:  	 
;  418:  	// system out 
;  419:  	SetDO(0, is_stopped == 0); 
;  420:  	SetDO(1, is_stopped); 
;  421:  	SetDO(2, g_OriginCompleted); 
;  422:  	SetDO(3, g_ErrorCode == ERR_OVER_RUN); 
;  423:  	SetDO(4, g_ErrorCode != 0); 
;  424:  	 
;  425:  	 
;  426:  	if (use_UserEMO)	// currently not used (1.00.016) 
;  427:  	{ 
;  428:  		// User Emergency 
;  429:  		userEmo = GetDI(0); 
;  430:  	 
;  431:  		if (userEmo == 0) // reverse, 0=EMO, 1=Normal 
;  432:  		{ 
;  433:  			SetErrorCode(ERR_EMERGENCY); 
;  434:  			GoToError(); 
;  435:  			for (axis = 0; axis < MAX_AXIS; ++axis) 
;  436:  			{ 
;  437:  				MovVar[g_OriginAxis].m_uAcel = EMERGENCY_STOP_DECEL; 
;  438:  				MoveStop(axis); 
;  439:  			} 
;  440:  			g_OriginCompleted = 0; 
;  441:  			return; 
;  442:  		} 
;  443:  	} 
;  444:   
;  445:  	switch (g_MotionCommand) 
;  446:  	{ 
;  447:  	case COMM_IDLE: 
;  448:  		if (IsStopped()) 
;  449:  		{ 
;  450:  			return; 
;  451:  		} 
;  452:  		break; 
;  453:  	case COMM_ORIGIN: 
;  454:  	case COMM_ERROR_STOP: 
;  455:  		return; 
;  456:  	} 
;  457:  	 
;  458:  	// check limit sensor 
;  459:  	 
;  460:  	if (g_MotionCommand == COMM_IDLE) 
;  461:  	{ 
;  462:  		for (axis = 0; axis < MAX_AXIS; ++axis) 
;  463:  		{ 
;  464:  			if (GetMoveStatus(axis) != MOVE_STS_STOP) 
;  465:  			{ 
;  466:  				switch (get_axis_sensor(axis)) 
;  467:  				{ 
;  468:  				case 0: 
;  469:  					break; 
;  470:  					 
;  471:  				case 1:	// POS LIMIT 
;  472:  					if (MovVar[axis].m_ucDir == g_MotionParam[axis].m_ucMoveDir) 
;  473:  					{ 
;  474:  						SetErrorCode(ERR_OVER_RUN); 
;  475:  						StopMotors(); 
;  476:  					} 
;  477:  					break; 
;  478:  					 
;  479:  				case 2: // NEG LIMIT 
;  480:  					if (MovVar[axis].m_ucDir != g_MotionParam[axis].m_ucMoveDir) 
;  481:  					{ 
;  482:  						SetErrorCode(ERR_OVER_RUN); 
;  483:  						StopMotors(); 
;  484:  					} 
;  485:  					break; 
;  486:  					 
;  487:  				default: 
;  488:  					SetErrorCode(ERR_OVER_RUN); 
;  489:  					StopMotors(); 
;  490:  					break;		 
;  491:  				} 
;  492:  			} 
;  493:  		} 
;  494:  	} 
;  495:  	else 
;  496:  	{ 
;  497:  		for (axis = 0; axis < MAX_AXIS; ++axis) 
;  498:  		{ 
;  499:  			switch (get_axis_sensor(axis)) 
;  500:  			{ 
;  501:  			case 0: 
;  502:  				break; 
;  503:  				 
;  504:  			case 1:	// POS LIMIT 
;  505:  				if (g_MoveOffset[axis] > 0) 
;  506:  				{ 
;  507:  					SetErrorCode(ERR_OVER_RUN); 
;  508:  					GoToError(); 
;  509:  				} 
;  510:  				break; 
;  511:  				 
;  512:  			case 2: // NEG LIMIT 
;  513:  				if (g_MoveOffset[axis] < 0) 
;  514:  				{ 
;  515:  					SetErrorCode(ERR_OVER_RUN); 
;  516:  					GoToError(); 
;  517:  				} 
;  518:  				break; 
;  519:  				 
;  520:  			default: 
