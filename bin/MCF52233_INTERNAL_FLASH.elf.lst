; 1688:  void SetSpeed(char axis, int type) 
; 1689:  { 
; 1690:  	int scan_rate = get_var(VAR_SCAN_SPEED); 
; 1691:   
; 1692:  	if (scan_rate < 1 || scan_rate > 100) 
; 1693:  	{ 
; 1694:  		scan_rate = 100; 
; 1695:  	} 
; 1696:  	 
; 1697:  	if (axis < 0 || axis >= MAX_AXIS) 
; 1698:  	{ 
; 1699:  		return; 
; 1700:  	} 
; 1701:  	 
; 1702:  	switch (type) 
; 1703:  	{ 
; 1704:  		case SPEED_ORG: 
; 1705:  			MovVar[axis].m_uVmax = g_MotionParam[axis].m_uOrgVmax; 
; 1706:  			MovVar[axis].m_uVmin = g_MotionParam[axis].m_uOrgVmax;	// ėëę° ëë Īė max ę°ė ėŽėĐíīë ëĻ  
; 1707:  			MovVar[axis].m_uAcel = g_MotionParam[axis].m_uOrgAcel; 
; 1708:  			break; 
; 1709:  			 
; 1710:  		case SPEED_JOG: 
; 1711:  			MovVar[axis].m_uVmax = g_MotionParam[axis].m_uJogVmax; 
; 1712:  			MovVar[axis].m_uVmin = g_MotionParam[axis].m_uJogVmin; 
; 1713:  			MovVar[axis].m_uAcel = g_MotionParam[axis].m_uJogAcel; 
; 1714:  			break; 
; 1715:  			 
; 1716:  		case SPEED_NORMAL: 
; 1717:  			MovVar[axis].m_uVmax = g_MotionParam[axis].m_uNorVmax; 
; 1718:  			MovVar[axis].m_uVmin = g_MotionParam[axis].m_uNorVmin; 
; 1719:  			MovVar[axis].m_uAcel = g_MotionParam[axis].m_uNorAcel; 
; 1720:  			break; 
; 1721:   
; 1722:  		case SPEED_SCAN: 
; 1723:  			MovVar[axis].m_uVmax = ((double)scan_rate/100) * g_MotionParam[axis].m_uNorVmax; 
; 1724:  			MovVar[axis].m_uVmin = ((double)scan_rate/100) * g_MotionParam[axis].m_uNorVmin; 
; 1725:  			MovVar[axis].m_uAcel = ((double)scan_rate/100) * g_MotionParam[axis].m_uNorAcel; 
; 1726:  			break; 
; 1727:  	} 
; 1728:  	 
; 1729:  	MovVar[axis].m_ucMoveTorq = g_MotionParam[axis].m_ucMoveTorque; //(axis == Z_AXIS) ? MOVE_TORQUE : MOVE_TORQUE_3A; 
; 1730:  } 
