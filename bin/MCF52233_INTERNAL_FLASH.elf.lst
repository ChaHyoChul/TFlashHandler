;  488:  					StopMotors(); 
;  489:  					break;		 
;  490:  				} 
;  491:  			} 
;  492:  		} 
;  493:  	} 
;  494:  	else 
;  495:  	{ 
;  496:  		for (axis = 0; axis < MAX_AXIS; ++axis) 
