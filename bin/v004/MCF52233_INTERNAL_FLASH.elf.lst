;  583:  	 
;  584:  	if (ch < 0 || ch > 1) 
;  585:  	{ 
;  586:  		return; 
;  587:  	} 
;  588:  	 
;  589:  	cur = cur & (unsigned short)(~(0xFF << (8*ch))); 
