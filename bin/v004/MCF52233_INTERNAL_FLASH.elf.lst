;  542:   
;  543:  unsigned char GetInput(char ch) 
;  544:  { 
;  545:  	unsigned char res = 0; 
;  546:  	unsigned short val = 0; 
;  547:  	 
;  548:  	if (ch < 0 || ch > 1) 
;  549:  	{ 
;  550:  		return res; 
;  551:  	} 
;  552:  	 
;  553:  	val = ~GetInput16(); 
;  554:  	 
;  555:  	res = (val >> (8*ch)) & 0xFF; 
;  556:  	 
;  557:  	return res; 
;  558:  } 
;  559:   
;  560:  unsigned char GetOutput(char ch) 
;  561:  { 
;  562:  	unsigned char res = 0; 
;  563:  	unsigned short val = 0; 
;  564:  	 
;  565:  	if (ch < 0 || ch > 1) 
;  566:  	{ 
;  567:  		return res; 
;  568:  	} 
;  569:  	 
;  570:  	//val = ~GetOutput12(); 
;  571:  	val = ~GetOutput8(); 
;  572:  	 
;  573:  	res = (val >> (8*ch)) & 0xFF; 
;  574:  	 
;  575:  	return res; 
;  576:  } 
;  577:   
;  578:  void SetOutput(char ch, unsigned char data) 
;  579:  { 
;  580:  	//unsigned short cur = GetOutput12();		// active low 
;  581:  	unsigned short cur = GetOutput8(); 
;  582:  	unsigned short data2 = 0xFF & (~data);	// active high -> active low 
;  583:  	 
;  584:  	if (ch < 0 || ch > 1) 
;  585:  	{ 
;  586:  		return; 
;  587:  	} 
;  588:  	 
;  589:  	cur = cur & (unsigned short)(~(0xFF << (8*ch))); 
;  590:  	data2 = cur | (unsigned short)(data2 << (8*ch)); 
;  591:  	 
;  592:  	// SetOutput12(data2); 
;  593:  	SetOutput8(data2); 
;  594:  } 
;  595:   
;  596:  unsigned char GetInput2(char ch) 
;  597:  { 
;  598:  	unsigned char res = 0; 
;  599:   
;  600:  	if (ch < 1 || ch > MAX_DI) 
;  601:  	{ 
;  602:  		return res; 
;  603:  	} 
;  604:  	 
;  605:  	res = GetInput(ch-1);	// GetInput() : ch = 0-base 
;  606:  	 
;  607:  	return res; 
;  608:  } 
;  609:   
;  610:  unsigned char GetOutput2(char ch) 
;  611:  { 
;  612:  	unsigned char res = 0; 
;  613:   
;  614:  	if (ch < 1 || ch > MAX_DO) 
;  615:  	{ 
;  616:  		return res; 
;  617:  	} 
;  618:  	 
;  619:  	res = GetOutput(ch-1);	// GetOutput() : ch = 0-base 
;  620:   
;  621:  	return res;	 
;  622:  } 
;  623:   
;  624:  void SetOutput2(char ch, unsigned char data) 
;  625:  { 
;  626:  	if (ch < 1 || ch > MAX_DO) 
;  627:  	{ 
;  628:  		return; 
;  629:  	} 
;  630:  	 
;  631:  	SetOutput(ch-1, data); 
;  632:  } 
;  633:   
;  634:  char GetDI(char ch) 
;  635:  { 
;  636:  	char res = 0; 
;  637:   
;  638:  	if (ch >= 0 && ch < MAX_DI) 
;  639:  	{ 
;  640:  		res = (((GetInput16() >> ch) & 1) == SENS_ON); 
;  641:  	} 
;  642:  	 
;  643:  	return res; 
;  644:  } 
;  645:   
;  646:  char GetDO(char ch) 
;  647:  { 
;  648:  	char res = 0; 
;  649:   
;  650:  	if (ch >= 0 && ch < MAX_DO) 
;  651:  	{ 
;  652:  		//res = (((GetOutput12() >> ch) & 1) == SENS_ON); 
;  653:  		res = (((GetOutput8() >> ch) & 1) == SENS_ON); 
;  654:  	} 
;  655:  	 
;  656:  	return res; 
;  657:  } 
;  658:   
;  659:  void SetDO(char ch, char flag) 
;  660:  { 
;  661:  	char res = 0; 
;  662:  	int value = 0; 
;  663:   
;  664:  	if (ch >= 0 && ch < MAX_DO) 
;  665:  	{ 
;  666:  		value = (1 << ch); 
;  667:  		if (flag) 
;  668:  		{ 
;  669:  			//SetOutput12(GetOutput12() & ~value); 
;  670:  			SetOutput8(GetOutput8() & ~value); 
;  671:  		} 
;  672:  		else 
;  673:  		{ 
;  674:  			//SetOutput12(GetOutput12() | value); 
;  675:  			SetOutput8(GetOutput8() | value); 
;  676:  		} 
;  677:  	} 
;  678:  } 
;  679:   
;  680:  unsigned char GetDIBit(char ch, char bit) 
;  681:  { 
;  682:  	unsigned char res = GetInput2(ch); 
;  683:  	 
;  684:  	res = (res >> bit) & 1; 
;  685:  	 
;  686:  	return res; 
;  687:  } 
;  688:   
;  689:  unsigned char GetDOBit(char ch, char bit) 
;  690:  { 
;  691:  	unsigned char res = GetOutput2(ch); 
;  692:  	 
;  693:  	res = (res >> bit) & 1; 
;  694:  	 
;  695:  	return res;	 
;  696:  } 
;  697:   
;  698:  void SetDOBit(char ch, char bit, char flag) 
;  699:  { 
;  700:  	unsigned char res = GetOutput2(ch); 
;  701:  	 
;  702:  	if (flag == 0) 
;  703:  	{ 
;  704:  		res = res & (unsigned char)(~(1 << bit)); 
;  705:  	} 
;  706:  	else 
;  707:  	{ 
;  708:  		res = res | (1 << bit); 
;  709:  	} 
;  710:  	 
;  711:  	SetOutput2(ch, res); 
;  712:  } 
