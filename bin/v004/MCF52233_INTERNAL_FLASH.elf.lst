; 1996:   
; 1997:  // g_MoveOffset[] ліҖмҲҳм—җ мң„м№ҳлҘј м ҖмһҘн•ҙ лҶ“кі , к·ё мң„м№ҳлЎң мқҙлҸҷн•ңлӢӨ  
; 1998:  char CommGripUngrip() 
; 1999:  { 
; 2000:  	static char step = 0; 
; 2001:  	int  axis = 0; 
; 2002:  	char flag = 1; 
; 2003:  	char move_start = 0; 
; 2004:  	char move_status = 0; 
; 2005:  	 
; 2006:  	switch (step) 
; 2007:  	{ 
; 2008:  		// Error handling  
