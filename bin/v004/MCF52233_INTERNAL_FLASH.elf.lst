;  378:  void MainControl() 
;  379:  { 
;  380:  	char res = 0; 
;  381:   
;  382:  	switch (g_MotionCommand) 
;  383:  	{ 
;  384:  	case COMM_IDLE:		break; 
;  385:  	case COMM_ORIGIN:	res = CommOrigin();	UpdateState(res);	break; 
;  386:  	case COMM_PTP:		res = CommMove();	UpdateState(res);	break; 
;  387:  	case COMM_ORIGIN_A:	res = CommOriginAxis();	UpdateState(res);	break; 
;  388:  	case COMM_ERROR_STOP:	res = CommErrorStop();	UpdateState(res);	break; 
;  389:   
;  390:  	case COMM_HOME:		res = CommHome(); UpdateState(res); break; 
;  391:  	case COMM_MGRI:		res = CommGripUngrip(); UpdateState(res); break; 
;  392:  	case COMM_MUNG:		res = CommGripUngrip(); UpdateState(res); break; 
;  393:  	case COMM_MLOA:		res = CommMoveXY(); UpdateState(res); break; 
;  394:  	case COMM_MASP:		res = CommMoveXY(); UpdateState(res); break; 
;  395:  	case COMM_MDIS:		res = CommMoveXY(); UpdateState(res); break; 
;  396:  	case COMM_MSHA:		res = CommShake(); UpdateState(res); break; 
;  397:  	case COMM_MWAS:		res = CommWaste(); UpdateState(res); break; 
;  398:  	case COMM_MSEP:		res = CommSeparate(); UpdateState(res); break; 
;  399:  	case COMM_AWAS:		res = CommAsyncWaste(); UpdateState(res); break; 
;  400:  	} 
;  401:  	 
;  402:  	if (g_UserStop > 0) 
;  403:  	{ 
;  404:  		--g_UserStop; 
;  405:  	} 
;  406:  	 
;  407:  	if (g_GoToError > 0) 
;  408:  	{ 
;  409:  		if (g_UserStop < 3) 
;  410:  		{ 
;  411:  			g_MotionCommand = COMM_ERROR_STOP; 
;  412:  			g_GoToError = 0; 
;  413:  		} 
;  414:  	} 
;  415:  } 
;  416:   
;  417:  void SystemCheck() 
;  418:  { 
;  419:  	char res = 0; 
;  420:  	char axis = 0; 
;  421:  	char userEmo = 0; 
;  422:  	char is_stopped = 0; 
;  423:  	char use_UserEMO = 0; 
;  424:  	 
;  425:  	if (g_MotionCommand == COMM_IDLE && IsStopped()) 
;  426:  	{ 
