;  812:  		step = 0; 
;  813:  		return ERROR_STOPPED; 
;  814:  		 
;  815:  	default: 
;  816:  		step = 0; 
;  817:  		return NORMAL_FINISHED; 
;  818:  	} 
;  819:  	 
;  820:  	return NORMAL_RUNNING; 
;  821:  } 
