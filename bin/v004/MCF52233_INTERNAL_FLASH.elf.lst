; 1747:  // Gripper(3) -> Rotation(2) -> Tile(1) мҲңм„ңлЎң Origin н•ңлӢӨ  
; 1748:  char CommHome() 
; 1749:  { 
; 1750:  	static int nNegLimitOutPos[MAX_AXIS] = {0, 0, 0}; 
; 1751:  	static int nNegLimitInPos[MAX_AXIS]  = {0, 0, 0}; 
; 1752:  	//static int org_axis = 0;	//  мӣҗм җліөк·Җ н•ҳлҠ” м¶• лІҲнҳё Z->Y->X мҲңм„ң  
; 1753:  	static int step = 0; 
; 1754:  	 
; 1755:  	int axis = 0; 
; 1756:  	int temp = 0; 
; 1757:  	char move_status = 0; 
; 1758:  	char move_start = 0; 
; 1759:  	double org_offset = 0; 
; 1760:  	POINT_DATA pd_org_offset; 
; 1761:  	 
; 1762:  	switch (step) 
