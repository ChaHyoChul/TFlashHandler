;  378:  void MainControl() 
;  379:  { 
;  380:  	char res = 0; 
;  381:   
;  382:  	switch (g_MotionCommand) 
;  383:  	{ 
;  384:  	case COMM_IDLE:		break; 
;  385:  	case COMM_ORIGIN:	res = CommOrigin();	UpdateState(res);	break; 
;  386:  	case COMM_PTP:		res = CommMove();	UpdateState(res);	break; 
;  387:  	case COMM_ORIGIN_A:	res = CommOriginAxis();	UpdateState(res);	break; 
;  388:  	case COMM_ERROR_STOP:	res = CommErrorStop();	UpdateState(res);	break; 
;  389:   
;  390:  	case COMM_HOME:		res = CommHome(); UpdateState(res); break; 
;  391:  	case COMM_MGRI:		res = CommGripUngrip(); UpdateState(res); break; 
;  392:  	case COMM_MUNG:		res = CommGripUngrip(); UpdateState(res); break; 
;  393:  	case COMM_MLOA:		res = CommMoveXY(); UpdateState(res); break; 
;  394:  	case COMM_MASP:		res = CommMoveXY(); UpdateState(res); break; 
;  395:  	case COMM_MDIS:		res = CommMoveXY(); UpdateState(res); break; 
;  396:  	case COMM_MSHA:		res = CommShake(); UpdateState(res); break; 
;  397:  	case COMM_MWAS:		res = CommWaste(); UpdateState(res); break; 
;  398:  	case COMM_MSEP:		res = CommSeparate(); UpdateState(res); break; 
;  399:  	case COMM_AWAS:		res = CommAsyncWaste(); UpdateState(res); break; 
;  400:  	} 
;  401:  	 
;  402:  	if (g_UserStop > 0) 
;  403:  	{ 
;  404:  		--g_UserStop; 
;  405:  	} 
;  406:  	 
;  407:  	if (g_GoToError > 0) 
;  408:  	{ 
;  409:  		if (g_UserStop < 3) 
;  410:  		{ 
;  411:  			g_MotionCommand = COMM_ERROR_STOP; 
;  412:  			g_GoToError = 0; 
;  413:  		} 
;  414:  	} 
;  415:  } 
;  416:   
;  417:  void SystemCheck() 
;  418:  { 
;  419:  	char res = 0; 
;  420:  	char axis = 0; 
;  421:  	char userEmo = 0; 
;  422:  	char is_stopped = 0; 
;  423:  	char use_UserEMO = 0; 
;  424:  	 
;  425:  	if (g_MotionCommand == COMM_IDLE && IsStopped()) 
;  426:  	{ 
;  427:  		is_stopped = 1; 
;  428:  	} 
;  429:  	 
;  430:  	// system out 
;  431:  	SetDO(0, is_stopped == 0); 
;  432:  	SetDO(1, is_stopped); 
;  433:  	SetDO(2, g_OriginCompleted); 
;  434:  	SetDO(3, g_ErrorCode == ERR_OVER_RUN); 
;  435:  	SetDO(4, g_ErrorCode != 0); 
;  436:  	 
;  437:  	 
;  438:  	if (use_UserEMO)	// currently not used (1.00.016) 
;  439:  	{ 
;  440:  		// User Emergency 
;  441:  		userEmo = GetDI(0); 
;  442:  	 
;  443:  		if (userEmo == 0) // reverse, 0=EMO, 1=Normal 
;  444:  		{ 
;  445:  			SetErrorCode(ERR_EMERGENCY); 
;  446:  			GoToError(); 
;  447:  			for (axis = 0; axis < MAX_AXIS; ++axis) 
;  448:  			{ 
;  449:  				MovVar[g_OriginAxis].m_uAcel = EMERGENCY_STOP_DECEL; 
;  450:  				MoveStop(axis); 
;  451:  			} 
;  452:  			g_OriginCompleted = 0; 
;  453:  			return; 
;  454:  		} 
;  455:  	} 
;  456:   
;  457:  	switch (g_MotionCommand) 
;  458:  	{ 
;  459:  	case COMM_IDLE: 
;  460:  		if (IsStopped()) 
;  461:  		{ 
;  462:  			return; 
;  463:  		} 
;  464:  		break; 
;  465:  	case COMM_ORIGIN: 
;  466:  	case COMM_ERROR_STOP: 
;  467:  	case COMM_ORIGIN_A: 
;  468:  	case COMM_HOME: 
;  469:  		return; 
;  470:  	} 
;  471:  	 
;  472:  	// check limit sensor 
;  473:  	 
;  474:  	if (g_MotionCommand == COMM_IDLE) 
;  475:  	{ 
;  476:  		for (axis = 0; axis < MAX_AXIS; ++axis) 
;  477:  		{ 
;  478:  			if (GetMoveStatus(axis) != MOVE_STS_STOP) 
;  479:  			{ 
;  480:  				switch (get_axis_sensor(axis)) 
;  481:  				{ 
;  482:  				case 0: 
;  483:  					break; 
;  484:  					 
;  485:  				case 1:	// POS LIMIT 
;  486:  					if (MovVar[axis].m_ucDir == g_MotionParam[axis].m_ucMoveDir) 
;  487:  					{ 
;  488:  						SetErrorCode(ERR_OVER_RUN); 
;  489:  						StopMotors(); 
;  490:  					} 
;  491:  					break; 
;  492:  					 
;  493:  				case 2: // NEG LIMIT 
;  494:  					if (MovVar[axis].m_ucDir != g_MotionParam[axis].m_ucMoveDir) 
;  495:  					{ 
