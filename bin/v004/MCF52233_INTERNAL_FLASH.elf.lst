; 1674:  	} 
; 1675:  	 
; 1676:  	return retDir; 
; 1677:  } 
; 1678:   
; 1679:  unsigned char InverseDir(unsigned char dir) 
; 1680:  { 
; 1681:  	return 1 - dir; 
; 1682:  } 
