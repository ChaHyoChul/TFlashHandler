;  624:  void SetOutput2(char ch, unsigned char data) 
;  625:  { 
;  626:  	if (ch < 1 || ch > MAX_DO) 
;  627:  	{ 
;  628:  		return; 
;  629:  	} 
;  630:  	 
;  631:  	SetOutput(ch-1, data); 
;  632:  } 
;  633:   
;  634:  char GetDI(char ch) 
;  635:  { 
;  636:  	char res = 0; 
;  637:   
;  638:  	if (ch >= 0 && ch < MAX_DI) 
;  639:  	{ 
;  640:  		res = (((GetInput16() >> ch) & 1) == SENS_ON); 
;  641:  	} 
;  642:  	 
;  643:  	return res; 
;  644:  } 
;  645:   
;  646:  char GetDO(char ch) 
;  647:  { 
;  648:  	char res = 0; 
;  649:   
;  650:  	if (ch >= 0 && ch < MAX_DO) 
;  651:  	{ 
;  652:  		//res = (((GetOutput12() >> ch) & 1) == SENS_ON); 
;  653:  		res = (((GetOutput8() >> ch) & 1) == SENS_ON); 
;  654:  	} 
;  655:  	 
;  656:  	return res; 
;  657:  } 
;  658:   
;  659:  void SetDO(char ch, char flag) 
;  660:  { 
;  661:  	char res = 0; 
;  662:  	int value = 0; 
;  663:   
;  664:  	if (ch >= 0 && ch < MAX_DO) 
;  665:  	{ 
;  666:  		value = (1 << ch); 
;  667:  		if (flag) 
;  668:  		{ 
;  669:  			//SetOutput12(GetOutput12() & ~value); 
;  670:  			SetOutput8(GetOutput8() & ~value); 
;  671:  		} 
;  672:  		else 
;  673:  		{ 
;  674:  			//SetOutput12(GetOutput12() | value); 
;  675:  			SetOutput8(GetOutput8() | value); 
;  676:  		} 
;  677:  	} 
;  678:  } 
;  679:   
;  680:  unsigned char GetDIBit(char ch, char bit) 
;  681:  { 
;  682:  	unsigned char res = GetInput2(ch); 
;  683:  	 
;  684:  	res = (res >> bit) & 1; 
;  685:  	 
;  686:  	return res; 
;  687:  } 
;  688:   
;  689:  unsigned char GetDOBit(char ch, char bit) 
;  690:  { 
;  691:  	unsigned char res = GetOutput2(ch); 
;  692:  	 
;  693:  	res = (res >> bit) & 1; 
;  694:  	 
;  695:  	return res;	 
;  696:  } 
;  697:   
;  698:  void SetDOBit(char ch, char bit, char flag) 
;  699:  { 
;  700:  	unsigned char res = GetOutput2(ch); 
;  701:  	 
;  702:  	if (flag == 0) 
;  703:  	{ 
;  704:  		res = res & (unsigned char)(~(1 << bit)); 
;  705:  	} 
;  706:  	else 
;  707:  	{ 
;  708:  		res = res | (1 << bit); 
;  709:  	} 
;  710:  	 
;  711:  	SetOutput2(ch, res); 
;  712:  } 
