;  499:  					break; 
;  500:  					 
;  501:  				default: 
;  502:  					SetErrorCode(ERR_OVER_RUN); 
;  503:  					StopMotors(); 
;  504:  					break;		 
;  505:  				} 
;  506:  			} 
;  507:  		} 
;  508:  	} 
;  509:  	else 
;  510:  	{ 
;  511:  		for (axis = 0; axis < MAX_AXIS; ++axis) 
;  512:  		{ 
;  513:  			switch (get_axis_sensor(axis)) 
;  514:  			{ 
;  515:  			case 0: 
;  516:  				break; 
;  517:  				 
;  518:  			case 1:	// POS LIMIT 
;  519:  				if (g_MoveOffset[axis] > 0) 
;  520:  				{ 
;  521:  					SetErrorCode(ERR_OVER_RUN); 
;  522:  					GoToError(); 
;  523:  				} 
;  524:  				break; 
;  525:  				 
;  526:  			case 2: // NEG LIMIT 
;  527:  				if (g_MoveOffset[axis] < 0) 
