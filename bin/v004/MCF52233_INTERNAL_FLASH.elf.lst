; 1666:  unsigned char GetRawDir(char axis, unsigned char dir) 
; 1667:  { 
; 1668:  	unsigned char retDir = dir; 
; 1669:   
; 1670:  	// change the direction for X-axis 
; 1671:  	if (axis == X_AXIS) 
; 1672:  	{ 
; 1673:  		retDir = 1 - retDir; 
; 1674:  	} 
; 1675:  	 
; 1676:  	return retDir; 
; 1677:  } 
; 1678:   
; 1679:  unsigned char InverseDir(unsigned char dir) 
; 1680:  { 
; 1681:  	return 1 - dir; 
; 1682:  } 
