; 1440:  		SetOriginCompletedFlag(g_OriginAxis, 1); 
; 1441:   
; 1442:  		return NORMAL_FINISHED;	// пҝҪпҝҪпҝҪпҝҪ : Move Origin пҝҪпҝҪпҝҪпҝҪ пҝҪП·пҝҪ 
; 1443:   
; 1444:  	default: 
; 1445:  		return NORMAL_FINISHED; 
; 1446:   
; 1447:  	} 
; 1448:  	 
; 1449:  	CHECK_USER_STOP(); 
; 1450:  	 
; 1451:  	return NORMAL_RUNNING; 
; 1452:  } 
